# =============================================================================
# Kealee Platform - Production Environment Variables Template
# =============================================================================
# Copy this file to .env.production and fill in the values
# NEVER commit .env.production to version control
# =============================================================================

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=production
APP_ENV=production

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_HOST=your-production-db.example.com
DATABASE_PORT=5432
DATABASE_NAME=kealee_production
DATABASE_USER=kealee_admin
DATABASE_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?sslmode=require

# =============================================================================
# REDIS (Caching & Sessions)
# =============================================================================
REDIS_HOST=your-redis-host.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# =============================================================================
# AUTHENTICATION
# =============================================================================
# JWT secret - must be at least 32 characters, use strong random string
JWT_SECRET=generate-a-secure-random-string-at-least-32-characters
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# =============================================================================
# STRIPE (Payment Processing)
# =============================================================================
# Use live keys for production (sk_live_ and pk_live_)
STRIPE_SECRET_KEY=sk_live_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret

# Platform commission rate (3.5%)
PLATFORM_COMMISSION_RATE=0.035

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM_ADDRESS=noreply@kealee.com
EMAIL_FROM_NAME=Kealee Platform

# =============================================================================
# AWS (File Storage)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=kealee-production

# =============================================================================
# CDN
# =============================================================================
CDN_URL=https://cdn.kealee.com

# =============================================================================
# MONITORING (Sentry)
# =============================================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production

# =============================================================================
# APPLICATION URLs
# =============================================================================
API_BASE_URL=https://api.kealee.com
APP_URL=https://app.kealee.com
PORTAL_URL=https://portal.kealee.com
MARKETING_URL=https://kealee.com

# =============================================================================
# CORS (Allowed Origins)
# =============================================================================
CORS_ORIGINS=https://kealee.com,https://www.kealee.com,https://app.kealee.com,https://portal.kealee.com

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_DEFAULT=100
RATE_LIMIT_MAX_PAYMENT=10
RATE_LIMIT_MAX_AUTH=10

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# =============================================================================
# DOCUSIGN (Optional - for contract signing)
# =============================================================================
DOCUSIGN_BASE_PATH=https://www.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=your_docusign_account_id
DOCUSIGN_INTEGRATION_KEY=your_integration_key

# =============================================================================
# SUPABASE (Optional - if using Supabase)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# =============================================================================
# FEATURE FLAGS (Override defaults if needed)
# =============================================================================
# FEATURE_M_MARKETPLACE_ENABLED=true
# FEATURE_M_MARKETPLACE_ROLLOUT=50
# FEATURE_M_ENGINEER_ENABLED=true
# FEATURE_M_ENGINEER_ROLLOUT=25

# =============================================================================
# APM (Application Performance Monitoring - Optional)
# =============================================================================
# APM_SERVER_URL=https://your-apm-server
# APM_SERVICE_NAME=kealee-api
