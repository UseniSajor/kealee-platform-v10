# ============================================================
# PRODUCTION ENV — command-center service (Railway)
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@ballast.proxy.rlwy.net:46074/railway

# ─── Redis + BullMQ ──────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@containers-us-west-xxx.railway.app:PORT

# ─── Internal API bridge ─────────────────────────────────────
# command-center calls api service for Zoho CRM operations.
# On Railway, use the internal private networking hostname.
# Railway internal URL format: http://SERVICE_NAME.railway.internal:PORT
INTERNAL_API_URL=http://api.railway.internal:3000
# Must match INTERNAL_API_KEY in the api service exactly
INTERNAL_API_KEY=REPLACE_WITH_SAME_64_CHAR_HEX_TOKEN_AS_API_SERVICE

# ─── SendGrid ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=hello@kealee.com
SENDGRID_FROM_NAME=Kealee Platform

# Optional: SendGrid Dynamic Template IDs
# Leave empty to use inline HTML templates (default)
SENDGRID_TEMPLATE_RECRUIT_1=
SENDGRID_TEMPLATE_RECRUIT_2=
SENDGRID_TEMPLATE_RECRUIT_3=
SENDGRID_TEMPLATE_ONBOARDING_WELCOME=
SENDGRID_TEMPLATE_REGISTRATION_REMINDER=
SENDGRID_TEMPLATE_VERIFICATION_REMINDER=
SENDGRID_TEMPLATE_ACTIVATION_WELCOME=

# ─── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# E.164 format required
TWILIO_PHONE_NUMBER=+14155552671
# Optional: Messaging Service SID for higher throughput
TWILIO_MESSAGING_SERVICE_SID=

# ─── App URLs ────────────────────────────────────────────────
WEB_MAIN_URL=https://kealee.com
PORTAL_CONTRACTOR_URL=https://contractor.kealee.com

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Slack alerts (optional) ─────────────────────────────────
SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/...
