# ============================================================
# PRODUCTION ENV — api service (Railway)
# ============================================================
# Copy this to Railway Environment Variables for the `api` service.
# NEVER commit real secrets to git.
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@ballast.proxy.rlwy.net:46074/railway

# ─── Supabase Auth ───────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Zoho CRM ────────────────────────────────────────────────
# Obtain via: accounts.zoho.com → Developer Console → Self-Client
# Scopes: ZohoCRM.modules.ALL,ZohoCRM.settings.ALL
ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_REFRESH_TOKEN=1000.XXXXXXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXX
ZOHO_DOMAIN=com

# Generate with: openssl rand -hex 32
ZOHO_WEBHOOK_TOKEN=REPLACE_WITH_64_CHAR_HEX_TOKEN

# ─── Internal service auth ────────────────────────────────────
# Must match the value in command-center service
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=REPLACE_WITH_64_CHAR_HEX_TOKEN

# ─── Stripe (existing) ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── GHL (existing) ──────────────────────────────────────────
GHL_API_KEY=...
GHL_LOCATION_ID=...
GHL_WEBHOOK_SECRET=...

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@containers-us-west-xxx.railway.app:PORT

# ─── Resend (existing email for transactional) ───────────────
RESEND_API_KEY=re_...

# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── App URLs ────────────────────────────────────────────────
WEB_MAIN_URL=https://kealee.com
PORTAL_CONTRACTOR_URL=https://contractor.kealee.com
PORTAL_OWNER_URL=https://owner.kealee.com
