# ============================================================
# .dockerignore - Optimize Docker Build Performance
# ============================================================
# Excludes files/folders that aren't needed in the Docker image
# This reduces build context size and speeds up COPY commands
# ============================================================

# Dependencies (installed in container)
node_modules/
.pnpm-store/
.npm/
.yarn/
.pnp.*

# Build outputs (built in container)
dist/
.next/
.turbo/
build/
out/
*.tsbuildinfo

# Environment files (set via Railway env vars)
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Testing
coverage/
.nyc_output/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
__tests__/
**/__tests__/
**/*.test.*
**/*.spec.*

# Development files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Documentation (not needed in production)
docs/
_docs/
*.md
README.md
CHANGELOG.md
LICENSE

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Railway config (not needed in image)
railway.json
nixpacks.toml*

# Docker files themselves
Dockerfile*
.dockerignore
docker-compose*.yml

# Scripts (not needed in production)
scripts/
*.sh
*.ps1

# TypeScript config (only needed for build)
tsconfig*.json
!tsconfig.json

# Misc
.editorconfig
.prettierrc*
.eslintrc*
.prettierignore
.eslintignore

# Temporary files
*.tmp
*.temp
.cache/




