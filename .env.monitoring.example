# ============================================================================
# MONITORING & OBSERVABILITY ENVIRONMENT VARIABLES
# ============================================================================
# Copy these to your Railway dashboard or local .env file
#
# Usage:
#   1. Go to Railway dashboard
#   2. Select service (kealee-api, kealee-worker, web-main)
#   3. Navigate to "Variables" section
#   4. Add the variables below
#
# OR locally:
#   1. Copy to .env.local or packages/database/.env
#   2. Restart your service
# ============================================================================

# ============================================================================
# SENTRY - Error Tracking (ESSENTIAL)
# ============================================================================
# Get your Sentry DSN from: https://sentry.io/settings/organizations/kealee/projects/

# API & Worker error tracking
SENTRY_DSN=https://YOUR_PUBLIC_KEY@sentry.io/YOUR_PROJECT_ID

# Web-main source map uploads (optional)
SENTRY_ORG=kealee
SENTRY_PROJECT=web-main
SENTRY_AUTH_TOKEN=your_auth_token_from_sentry

# ============================================================================
# SLACK ALERTS (RECOMMENDED)
# ============================================================================
# Get Slack webhook URL from: https://api.slack.com/apps → Create New App → Incoming Webhooks

# Send alerts to Slack channel when errors occur
SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# EMAIL ALERTS (OPTIONAL)
# ============================================================================
# Using Resend for transactional emails

# Email address to receive alerts
ALERT_EMAIL_TO=alerts@kealee.com

# Get Resend API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# ============================================================================
# SERVICE CONTEXT (OPTIONAL)
# ============================================================================
# For alert messages and logs

SERVICE_NAME=kealee-api
LOG_LEVEL=info  # debug, info, warn, error

# ============================================================================
# TRACING & TELEMETRY (OPTIONAL)
# ============================================================================
# For OpenTelemetry (advanced)

# OTEL_EXPORTER_OTLP_ENDPOINT=http://collector:4317
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer YOUR_TOKEN

# ============================================================================
# NOTES
# ============================================================================
#
# Required for any monitoring:
#   - SENTRY_DSN (set on all 3 services)
#
# Recommended for production:
#   - SLACK_ALERT_WEBHOOK_URL (ops team notifications)
#   - ALERT_EMAIL_TO (backup notifications)
#   - RESEND_API_KEY (for email)
#
# What each variable enables:
#   - SENTRY_DSN → Captures errors, exceptions, performance traces
#   - SLACK_ALERT_WEBHOOK_URL → Sends alerts to Slack #alerts channel
#   - ALERT_EMAIL_TO → Sends critical errors to email
#   - RESEND_API_KEY → Powers email notifications
#   - LOG_LEVEL → Controls console/file log verbosity
#
# Testing:
#   1. Set all variables in Railway
#   2. Redeploy service
#   3. Trigger error: curl POST /test-error
#   4. Check Sentry dashboard: https://sentry.io/organizations/kealee/
#   5. Check Slack channel for alert
#   6. Check email inbox for alert
#
# ============================================================================
