{
  "name": "@kealee/intake",
  "version": "1.0.0",
  "description": "Public intake system for Kealee — config, schemas, scoring, routing, and submission logic",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas": {
