  @@index([milestoneId])
}

model EscrowAgreement {
  id              String       @id @default(uuid())
  contractId      String       @unique
  projectId       String
  totalAmount     Decimal
  currentBalance  Decimal      @default(0)
  holdbackPercent Int          @default(10)
  status          EscrowStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  contract     ContractAgreement   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transactions EscrowTransaction[]
  disputes     Dispute[]

  @@index([contractId])
  @@index([projectId])
  @@index([status])
}

model EscrowTransaction {
  id              String    @id @default(uuid())
  escrowId        String
  type            String // DEPOSIT, RELEASE, RELEASE_FINAL, REFUND, FEE
  amount          Decimal
  balanceBefore   Decimal
  balanceAfter    Decimal
  status          String // PENDING, COMPLETED, FAILED, CANCELLED
  stripePaymentId String?
  processedAt     DateTime?
  createdAt       DateTime  @default(now())

  escrow EscrowAgreement @relation(fields: [escrowId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([status])
}

// ============================================================================
// DOUBLE-ENTRY LEDGER SYSTEM (Stage 5 - Finance & Trust)
// ============================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountSubType {
  // Assets
  CASH
  ESCROW_HOLDINGS
  ACCOUNTS_RECEIVABLE
  // Liabilities
  ACCOUNTS_PAYABLE
  ESCROW_LIABILITIES
  PLATFORM_FEES_PAYABLE
  // Equity
  RETAINED_EARNINGS
  // Revenue
  PLATFORM_FEES
  TRANSACTION_FEES
  // Expenses
  PROCESSING_FEES
  OPERATING_EXPENSES
}

model Account {
  id          String        @id @default(uuid())
  code        String        @unique // Chart of accounts code (e.g., "1000", "2000")
  name        String
  type        AccountType
  subType     AccountSubType?
  description String?
  parentId    String? // For account hierarchy
  isActive    Boolean       @default(true)
  balance     Decimal       @default(0) // Current balance (debit - credit)
  currency    String        @default("USD")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  parent   Account?          @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[]       @relation("AccountHierarchy")
  lines     JournalEntryLine[]

  @@index([type])
  @@index([subType])
  @@index([isActive])
}

model JournalEntry {
  id          String   @id @default(uuid())
  entryNumber String   @unique // Sequential entry number
  description String
  reference   String? // Reference to source transaction (escrow, milestone, etc.)
  referenceId String? // ID of source transaction
  entryDate   DateTime @default(now())
  postedAt    DateTime? // When entry was posted (null = draft)
  postedBy    String? // User who posted the entry
  createdAt   DateTime @default(now())
  createdBy   String
  updatedAt   DateTime @updatedAt

  lines JournalEntryLine[]

  @@index([entryDate])
  @@index([postedAt])
  @@index([reference, referenceId])
}

model JournalEntryLine {
  id            String        @id @default(uuid())
  journalEntryId String
  accountId     String
  debit         Decimal       @default(0)
  credit        Decimal       @default(0)
  description   String?
  createdAt     DateTime      @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model Dispute {
  id              String        @id @default(uuid())
  projectId       String
  contractId      String?
  escrowId        String?
  milestoneId     String?
  initiatedBy     String
  initiatedByRole String // OWNER, CONTRACTOR
  reason          String
  description     String
  priority        String // low, normal, high, urgent
  status          DisputeStatus @default(FILED)
  resolution      String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project  Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract ContractAgreement? @relation(fields: [contractId], references: [id])
  escrow   EscrowAgreement?   @relation(fields: [escrowId], references: [id])

  @@index([projectId])
  @@index([contractId])
  @@index([status])
}

model Lead {
  id                 String     @id @default(uuid())
  projectId          String?
  category           String
  description        String
  estimatedValue     Decimal?
  budget             Decimal?
  location           String
  city               String?
  state              String?
  stage              LeadStatus @default(OPEN)
  status             String? // Alternative status field
  distributedTo      String[] // Array of profile IDs
  assignedSalesRepId String?
  lostAt             DateTime?
  lostReason         String?
  stageChangedAt     DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  project Project? @relation(fields: [projectId], references: [id])
  quotes  Quote[]

  @@index([projectId])
  @@index([stage])
  @@index([status])
}

model MarketplaceProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  businessName         String
  description          String?
  serviceArea          Json?
  specialties          String[]
  rating               Float?    @default(0)
  reviewCount          Int       @default(0)
  projectsCompleted    Int       @default(0)
  performanceScore     Int?
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  subscriptionTier     String?
  leadCredits          Int       @default(0)
  acceptingLeads       Boolean   @default(true)
  maxPipelineValue     Decimal?
  currentPipelineValue Decimal?  @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user      User        @relation("MarketplaceProfileUser", fields: [userId], references: [id])
  portfolio Portfolio[]
  quotes    Quote[]

  @@index([verified])
  @@index([subscriptionTier])
  @@index([acceptingLeads])
}

model Portfolio {
  id          String    @id @default(uuid())
  profileId   String
  projectName String
  description String?
  category    String
  imageUrls   String[]
  completedAt DateTime?

  profile MarketplaceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Quote {
  id          String   @id @default(uuid())
  leadId      String
  profileId   String
  amount      Decimal
  timeline    String?
  details     String?
  status      String // SUBMITTED, ACCEPTED, REJECTED
  submittedAt DateTime @default(now())

  lead    Lead               @relation(fields: [leadId], references: [id])
  profile MarketplaceProfile @relation(fields: [profileId], references: [id])

  @@index([leadId])
  @@index([profileId])
  @@index([status])
}

// ============================================================================
// UNIFIED API PLATFORM (Prompt 3.1)
// ============================================================================

// API Key Management
model ApiKey {
  id             String  @id @default(uuid())
  keyHash        String  @unique // SHA-256 hash of the actual API key
  name           String
  jurisdictionId String?
  userId         String?
  organizationId String?

  // Permissions
  scopes    String[] // e.g., ["read", "write", "admin"]
  rateLimit Int      @default(100) // requests per minute

  // Status
  active     Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  usage     ApiKeyUsage[]
  auditLogs SecurityAuditLog[]

  @@index([keyHash])
  @@index([userId])
  @@index([organizationId])
  @@index([jurisdictionId])
  @@index([active])
}

// API Key Usage Tracking
model ApiKeyUsage {
  id           String   @id @default(uuid())
  apiKeyId     String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds
  timestamp    DateTime @default(now())

  // Context
  ipAddress      String?
  userAgent      String?
  jurisdictionId String?
  organizationId String?

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@index([endpoint])
}

// Webhook Management
model Webhook {
  id     String   @id @default(uuid())
  url    String
  secret String // HMAC secret for signing
  events String[] // Event types to subscribe to

  // Ownership
  jurisdictionId String?
  organizationId String?
  userId         String?

  // Status
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  deliveries WebhookDelivery[]

  @@index([jurisdictionId])
  @@index([organizationId])
  @@index([active])
}

// Webhook Delivery Tracking
model WebhookDelivery {
  id        String @id @default(uuid())
  webhookId String
  event     String
  payload   Json

  // Delivery status
  status        WebhookDeliveryStatus @default(PENDING)
  attempts      Int                   @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?

  // Response
  responseCode Int?
  responseBody String? // Truncated response body

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([nextRetryAt])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// API Usage Analytics (consolidated usage tracking)
model ApiUsage {
  id             String  @id @default(uuid())
  apiKeyId       String?
  userId         String?
  organizationId String?
  jurisdictionId String?

  // Request details
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds

  // Context
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([apiKeyId])
  @@index([userId])
  @@index([organizationId])
  @@index([jurisdictionId])
  @@index([timestamp])
  @@index([endpoint])
}

// Security Audit Logging
model SecurityAuditLog {
  id        String            @id @default(uuid())
  eventType SecurityEventType
  severity  SecuritySeverity

  // Actor
  userId    String?
  apiKeyId  String?
  ipAddress String
  userAgent String

  // Action
  endpoint   String
  method     String
  statusCode Int

  // Data
  requestBody  Json?
  responseBody Json?

  // Context
  jurisdictionId String?
  organizationId String?
  metadata       Json?

  timestamp DateTime @default(now())

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([severity])
  @@index([userId])
  @@index([apiKeyId])
  @@index([jurisdictionId])
  @@index([organizationId])
  @@index([timestamp])
}

enum SecurityEventType {
  API_ACCESS
  AUTHENTICATION
  AUTHORIZATION
  DATA_ACCESS
  CONFIG_CHANGE
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================================
// STRIPE BILLING MODELS
// ============================================================================

model Payment {
  id                    String    @id @default(uuid())
  orgId                 String?
  projectId             String?
  subscriptionId        String?
  stripeInvoiceId       String?
  stripePaymentIntentId String?   @unique
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("usd")
  status                String // completed, failed, pending, refunded
  paidAt                DateTime?
  failedAt              DateTime?
  refundedAt            DateTime?
  refundAmount          Decimal?  @db.Decimal(10, 2)
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // org          Org?              @relation(fields: [orgId], references: [id], onDelete: SetNull)
  // subscription ServiceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([projectId])
  @@index([subscriptionId])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id               String    @id @default(uuid())
  orgId            String?
  subscriptionId   String?
  stripeInvoiceId  String    @unique
  invoiceNumber    String?
  amount           Decimal   @db.Decimal(10, 2)
  currency         String    @default("usd")
  status           String // draft, open, paid, uncollectible, void
  periodStart      DateTime?
  periodEnd        DateTime?
  paidAt           DateTime?
  hostedInvoiceUrl String?
  invoicePdf       String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // org          Org?              @relation(fields: [orgId], references: [id], onDelete: SetNull)
  // subscription ServiceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([subscriptionId])
  @@index([stripeInvoiceId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================================
// APPROVAL WORKFLOW
// ============================================================================

enum ApprovalRequestType {
  EXPENSE
  TIME_OFF
  PURCHASE
  DOCUMENT
  CUSTOM
}

enum ApprovalRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  type        ApprovalRequestType
  subtype     String?
  status      ApprovalRequestStatus @default(DRAFT)
  priority    ApprovalPriority      @default(MEDIUM)
  title       String
  description String?
  requesterId String
  amount      Decimal?              @db.Decimal(12, 2)
  currency    String?               @default("usd")
  startDate   DateTime?
  endDate     DateTime?
  metadata    Json? // Additional metadata
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  requester     User                 @relation("ApprovalRequestRequester", fields: [requesterId], references: [id])
  approvalSteps ApprovalStep[]
  attachments   ApprovalAttachment[]
  comments      ApprovalComment[]

  @@index([requesterId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([submittedAt])
}

model ApprovalStep {
  id                String             @id @default(uuid())
  approvalRequestId String
  approverId        String
  approverRole      String?
  status            ApprovalStepStatus @default(PENDING)
  comments          String?
  order             Int // Order in approval chain
  required          Boolean            @default(true)
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver        User            @relation("ApprovalStepApprover", fields: [approverId], references: [id])

  @@index([approvalRequestId])
  @@index([approverId])
  @@index([status])
  @@index([order])
}

model ApprovalRule {
  id            String            @id @default(uuid())
  name          String
  type          String
  subtype       String?
  conditions    Json // Array of condition objects
  approvalChain Json // Array of approval chain steps
  priority      ApprovalPriority?
  sla           Int? // SLA in hours
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([type])
  @@index([active])
  @@index([createdAt])
}

model ApprovalAttachment {
  id                String   @id @default(uuid())
  approvalRequestId String
  fileId            String? // Reference to File model
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int // Bytes
  uploadedAt        DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
}

model ApprovalComment {
  id                String   @id @default(uuid())
  approvalRequestId String
  userId            String
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  user            User            @relation("ApprovalCommentUser", fields: [userId], references: [id])

  @@index([approvalRequestId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// MISSING MODELS - Added for API compatibility
// ============================================================================

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  assignedPM String? // PM user ID
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects          Project[]
  tasks             Task[]
  assignmentRequests AssignmentRequest[]

  @@index([assignedPM])
  @@index([status])
}

model Task {
  id          String   @id @default(uuid())
  projectId   String?
  clientId    String?
  title       String
  description String?
  status      String   @default("PENDING")
  priority    String   @default("NORMAL")
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client  Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  comments TaskComment[]

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([assignedTo])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Report {
  id          String   @id @default(uuid())
  type        String
  title       String
  description String?
  data        Json?
  status      String   @default("DRAFT")
  generatedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AssignmentRequest {
  id        String   @id @default(uuid())
  clientId  String
  pmUserId  String
  status    String   @default("PENDING")
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([pmUserId])
  @@index([status])
}

