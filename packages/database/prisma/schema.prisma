  INFILL_DEVELOPMENT
  SMALL_SCALE_HOUSING
  PREVIOUSLY_DEVELOPED
  CATEGORICAL_EXCLUSION
  NONE
}

enum DevelopmentPackageStatus {
  INTAKE
