}

// File upload record with validation metadata
model FileUpload {
  id String @id @default(uuid())

  // File information
  fileName String
  fileUrl  String // S3 URL
  fileSize Int // Bytes
  mimeType String
  category FileCategory

  // Context
  projectId      String?
  propertyId     String?
  milestoneId    String?
  leadId         String?
  organizationId String?

  // Upload metadata
  uploadedById   String
  uploadedByRole UploadedByRole

  // Validation
  isValidated Boolean   @default(false)
  validatedAt DateTime?
  validatedBy String?

  // AI Analysis (for photos)
  aiAnalysis    Json? // QA findings, defects, etc.
  aiProcessed   Boolean   @default(false)
  aiProcessedAt DateTime?

  // OCR Results (for receipts)
  ocrData        Json? // Vendor, amount, date, etc.
  ocrProcessed   Boolean   @default(false)
  ocrProcessedAt DateTime?

  // Tags & Search
  tags        String[]
  description String?  @db.Text
  location    String? // "Kitchen - North Wall"

  // Metadata
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploadedBy User       @relation("FileUploadUser", fields: [uploadedById], references: [id])
  project    Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
