  frequency       String    @default("IMMEDIATE") // IMMEDIATE, DAILY_DIGEST, WEEKLY_DIGEST
  quietHoursStart String?   // HH:MM format
  quietHoursEnd   String?   // HH:MM format

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation("UserNotificationPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("notification_preferences")
}

// APP-10: Document Generator - Additional Models

model Document {
  id              String    @id @default(uuid())
  projectId       String?
  templateId      String?
  type            String    // CONTRACT, PROPOSAL, REPORT, INVOICE, LIEN_WAIVER, CHANGE_ORDER, RFI, SUBMITTAL
  category        String    // CONTRACTS, PROPOSALS, REPORTS, FINANCIAL, LEGAL, ADMINISTRATIVE
  name            String
  description     String?
  version         Int       @default(1)
  content         Json?     // Structured content for generation
  fileUrl         String?
  format          String    @default("PDF") // PDF, DOCX, XLSX
  size            Int?      // File size in bytes
  status          String    @default("DRAFT") // DRAFT, GENERATED, REVIEW, APPROVED, SIGNED, ARCHIVED
  signatureStatus String?   // PENDING, PARTIALLY_SIGNED, SIGNED, DECLINED
  docusignEnvelopeId String?
  signedAt        DateTime?
  signedBy        String?
  approvedAt      DateTime?
  approvedBy      String?
  expiresAt       DateTime?
  metadata        Json?
  tags            String[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  template        DocumentTemplate? @relation(fields: [templateId], references: [id])
  distributions   DocumentDistribution[]

  @@index([projectId])
  @@index([templateId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("documents")
}

model DocumentTemplate {
  id              String    @id @default(uuid())
  name            String
  description     String?
  type            String    // CONTRACT, PROPOSAL, REPORT, INVOICE, etc.
  category        String    // CONTRACTS, PROPOSALS, etc.
  content         String    @db.Text  // Template content with placeholders
  format          String    @default("PDF")
  variables       Json?     // Schema for required variables
  sections        Json?     // Template sections
  styling         Json?     // Styling configuration
  isActive        Boolean   @default(true)
  isSystem        Boolean   @default(false)
  organizationId  String?
  version         Int       @default(1)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  documents       Document[]

  @@unique([name, organizationId, version])
  @@index([type])
  @@index([category])
  @@index([isActive])
  @@map("document_templates")
}

model DocumentDistribution {
  id              String    @id @default(uuid())
  documentId      String
  recipientId     String?
  recipientEmail  String
  recipientName   String?
  method          String    // EMAIL, PORTAL, DOCUSIGN
  status          String    @default("PENDING") // PENDING, SENT, DELIVERED, VIEWED, SIGNED
  sentAt          DateTime?
  deliveredAt     DateTime?
  viewedAt        DateTime?
  signedAt        DateTime?
  accessLink      String?
  accessExpires   DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  document        Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([recipientEmail])
  @@index([status])
  @@map("document_distributions")
}

// Project Manager relation table for many-to-many

model ProjectManager {
