  paymentTerms Json? // Party-specific payment terms

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contract ContractAgreement @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([userId])
  @@index([orgId])
  @@index([role])
  @@map("contract_parties")
}

// ============================================================================
// V10 SPEC: FINANCIAL TRANSACTION (generic ledger)
// ============================================================================

enum FinancialTransactionType {
  INVOICE
  PAYMENT
  REFUND
  CREDIT
  DEBIT
  ESCROW_DEPOSIT
  ESCROW_RELEASE
  FEE
  ADJUSTMENT
  WRITE_OFF
}

enum FinancialTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
  DISPUTED
}

model FinancialTransaction {
  id        String  @id @default(uuid())
  orgId     String
  projectId String?

  // Transaction details
  transactionType FinancialTransactionType
  status          FinancialTransactionStatus @default(PENDING)
  referenceNumber String                     @unique
  description     String

  // Amounts
  amount    Decimal  @db.Decimal(14, 2)
  currency  String   @default("USD")
  taxAmount Decimal? @db.Decimal(14, 2)
  feeAmount Decimal? @db.Decimal(14, 2)
  netAmount Decimal? @db.Decimal(14, 2)

  // Parties
  fromAccountId String?
  toAccountId   String?
  payerId       String?
  payeeId       String?

  // Related entities
  invoiceId         String?
  paymentId         String?
  contractId        String?
  changeOrderId     String?
  escrowAgreementId String?

  // Payment method
  paymentMethod   String? // CARD, ACH, CHECK, WIRE, CASH
  stripePaymentId String?

  // Dates
  transactionDate DateTime  @default(now())
  dueDate         DateTime?
  clearedDate     DateTime?

  // Reconciliation
  isReconciled  Boolean   @default(false)
  reconciledAt  DateTime?
  reconciledBy  String?
  bankReference String?

  // Metadata
  metadata Json?
  notes    String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
  @@index([transactionType])
  @@index([status])
  @@index([referenceNumber])
  @@index([transactionDate])
  @@index([isReconciled])
  @@map("financial_transactions")
}

// ============================================================================
// V10 SPEC: AUTOMATION EVENT
// Event tracking for Command Center mini-apps
// ============================================================================

enum AutomationEventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model AutomationEvent {
  id    String  @id @default(uuid())
  orgId String?

  // Event identification
  eventType String // e.g., 'kealee.bid.analysis_complete'
  source    String // APP-01, APP-02, etc.
  severity  AutomationEventSeverity @default(INFO)

  // Context
  projectId  String?
  userId     String?
  jobId      String?
  entityType String? // 'ChangeOrder', 'Permit', etc.
  entityId   String?

  // Event data
  title       String
  description String? @db.Text
  payload     Json?
  metadata    Json?

  // Processing
  isProcessed      Boolean   @default(false)
  processedAt      DateTime?
  processingResult Json?

  // Acknowledgment
  isAcknowledged Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([eventType])
  @@index([source])
  @@index([severity])
  @@index([projectId])
  @@index([isProcessed])
  @@index([createdAt])
  @@map("automation_events")
}

// ============================================================================
// V10 SPEC: BID EVALUATION (formal scoring for bid analysis)
// ============================================================================

model BidEvaluation {
  id              String  @id @default(uuid())
  bidRequestId    String
  bidSubmissionId String
  evaluatorId     String?

  // Scoring (1-100 scale)
  overallScore       Int
  priceScore         Int?
  qualificationScore Int?
  scheduleScore      Int?
  safetyScore        Int?
  referencesScore    Int?
  complianceScore    Int?

  // Weighted scores
  weightedTotal       Decimal? @db.Decimal(8, 4)
  priceWeight         Decimal? @default(0.35) @db.Decimal(5, 4)
  qualificationWeight Decimal? @default(0.25) @db.Decimal(5, 4)
  scheduleWeight      Decimal? @default(0.15) @db.Decimal(5, 4)
  safetyWeight        Decimal? @default(0.10) @db.Decimal(5, 4)
  referencesWeight    Decimal? @default(0.10) @db.Decimal(5, 4)
  complianceWeight    Decimal? @default(0.05) @db.Decimal(5, 4)

  // AI analysis
  aiRecommendation String? // AWARD, SHORTLIST, REJECT, NEEDS_REVIEW
  aiConfidence     Decimal? @db.Decimal(5, 4) // 0.0 - 1.0
  aiReasoning      String?  @db.Text
  riskFlags        String[] // Array of risk identifiers

  // Price analysis
  priceVariance   Decimal? @db.Decimal(8, 4) // % from engineer's estimate
  isLowBid        Boolean  @default(false)
  isBelowEstimate Boolean  @default(false)

  // Evaluator notes
  notes          String? @db.Text
  strengthNotes  String? @db.Text
  weaknessNotes  String? @db.Text
  conditionNotes String? @db.Text

  // Status
  status      String    @default("DRAFT") // DRAFT, SUBMITTED, FINALIZED
  submittedAt DateTime?
  finalizedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest    BidRequest    @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  bidSubmission BidSubmission @relation(fields: [bidSubmissionId], references: [id], onDelete: Cascade)

  @@unique([bidRequestId, bidSubmissionId])
  @@index([bidRequestId])
  @@index([bidSubmissionId])
  @@index([overallScore])
  @@index([aiRecommendation])
  @@map("bid_evaluations")
}

// ============================================================================
// V10 SPEC: WEEKLY REPORT
// Automated weekly report generation and distribution
// ============================================================================

enum WeeklyReportStatus {
  GENERATING
  DRAFT
  REVIEW
  APPROVED
  SENT
  FAILED
}

model WeeklyReport {
  id        String @id @default(uuid())
  projectId String
  orgId     String

  // Report identification
  reportNumber  Int
  weekStartDate DateTime
  weekEndDate   DateTime

  // Status
  status      WeeklyReportStatus @default(GENERATING)
  generatedAt DateTime?
  reviewedAt  DateTime?
  reviewedBy  String?
  approvedAt  DateTime?
  approvedBy  String?
  sentAt      DateTime?

  // Content sections (generated by APP-04)
  executiveSummary    String? @db.Text
  scheduleUpdate      Json? // { percentComplete, daysAhead/Behind, milestones }
  budgetSummary       Json? // { spent, remaining, variance, projectedTotal }
  workCompleted       Json? // Array of completed work items
  workPlanned         Json? // Array of upcoming work items
  issuesAndRisks      Json? // Array of { issue, severity, mitigation }
  changeOrderSummary  Json? // { pending, approved, totalImpact }
  safetyReport        Json? // { incidents, nearMisses, toolboxTalks }
  weatherImpact       Json? // { daysLost, outlook }
  photos              Json? // Array of { url, caption, category }
  subcontractorStatus Json? // Array of { name, trade, status }

  // Distribution
  recipients      String[] // Email addresses
  ccRecipients    String[]
  documentUrl     String? // Generated PDF URL
  clientPortalUrl String? // Link for client portal

  // AI insights
  aiInsights        String? @db.Text
  aiRiskScore       Int? // 0-100
  aiRecommendations Json? // Array of recommendations

  // Metadata
  dataSnapshotAt DateTime? // When data was captured
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, weekStartDate])
  @@index([projectId])
  @@index([orgId])
  @@index([status])
  @@index([weekStartDate])
  @@map("weekly_reports")
}

// ============================================================================
// V10 SPEC: QA INSPECTION RESULT
// Quality assurance inspection tracking (APP-13)
// ============================================================================

enum QAResultStatus {
  SCHEDULED
  IN_PROGRESS
  PASS
  FAIL
  CONDITIONAL_PASS
  NEEDS_REINSPECTION
  CANCELLED
}

enum QASeverity {
  MINOR
  MODERATE
  MAJOR
  CRITICAL
}

model QAInspectionResult {
  id        String @id @default(uuid())
  projectId String
  orgId     String

  // Inspection details
  inspectionType   String // ROUGH_IN, FRAMING, ELECTRICAL, PLUMBING, FIRE, FINAL, etc.
  inspectionNumber Int
  inspectorId      String?
  inspectorName    String?

  // Location
  location      String? // Building/floor/area
  tradeCategory String? // MECHANICAL, ELECTRICAL, PLUMBING, STRUCTURAL, etc.

  // Schedule
  scheduledDate DateTime?
  completedDate DateTime?
  duration      Int? // minutes

  // Results
  status       QAResultStatus @default(SCHEDULED)
  overallScore Int? // 0-100

  // Checklist results
  checklistItems Json? // Array of { item, category, pass, notes, photos }
  totalItems     Int   @default(0)
  passedItems    Int   @default(0)
  failedItems    Int   @default(0)
  naItems        Int   @default(0)

  // Deficiencies
  deficiencies    Json? // Array of { id, description, severity, location, photo, dueDate, status }
  deficiencyCount Int   @default(0)
  criticalCount   Int   @default(0)

  // AI analysis (APP-13)
  aiAnalysis       String? @db.Text
  aiRiskAssessment Json? // { score, factors, recommendations }
  predictedIssues  Json? // AI-predicted potential issues

  // Follow-up
  reinspectionRequired Boolean   @default(false)
  reinspectionDate     DateTime?
  reinspectionId       String? // Link to follow-up inspection
  correctiveActions    Json? // Array of { action, assignedTo, dueDate, status }

  // Documentation
  photos        String[] // URLs
  documentUrl   String? // Generated report PDF
  notes         String?  @db.Text
  clientVisible Boolean  @default(false)

  // Sign-off
  signedOffBy  String?
  signedOffAt  DateTime?
  signatureUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([orgId])
  @@index([inspectionType])
  @@index([status])
  @@index([scheduledDate])
  @@index([inspectorId])
  @@map("qa_inspection_results")
}

// ============================================================================
// V10 SPEC: DECISION QUEUE
// Approval workflow queue for Command Center (APP-14)
// ============================================================================

enum DecisionStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DEFERRED
  ESCALATED
  AUTO_APPROVED
  EXPIRED
}

enum DecisionPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum DecisionCategory {
  CHANGE_ORDER
  BUDGET_ADJUSTMENT
  SCHEDULE_CHANGE
  MATERIAL_SUBSTITUTION
  SUBCONTRACTOR_APPROVAL
  SAFETY_CONCERN
  PERMIT_ISSUE
  DESIGN_CHANGE
  PAYMENT_RELEASE
  CONTRACT_AMENDMENT
  RFI_RESPONSE
  OTHER
}

model DecisionQueue {
  id        String  @id @default(uuid())
  projectId String?
  orgId     String

  // Decision details
  title       String
  description String           @db.Text
  category    DecisionCategory
  priority    DecisionPriority @default(NORMAL)
  status      DecisionStatus   @default(PENDING)

  // Related entity
  entityType String? // ChangeOrder, BudgetLine, etc.
  entityId   String?

  // Requester
  requestedById String
  requestedAt   DateTime @default(now())

  // Assignment
  assignedToId String?
  assignedAt   DateTime?

  // Decision
  decidedById String?
  decidedAt   DateTime?
  decision    String? // Free-text decision rationale
  conditions  String[] // Array of conditions for approval

  // Escalation
  escalatedFromId  String? // Previous DecisionQueue id
  escalatedToId    String? // User id escalated to
  escalationReason String?
  escalatedAt      DateTime?

  // AI recommendation (APP-14)
  aiRecommendation String? // APPROVE, REJECT, DEFER, ESCALATE
  aiConfidence     Decimal?  @db.Decimal(5, 4)
  aiReasoning      String?   @db.Text
  aiAnalyzedAt     DateTime?

  // Impact analysis
  costImpact     Decimal? @db.Decimal(14, 2)
  scheduleImpact Int? // days
  riskLevel      String? // LOW, MEDIUM, HIGH, CRITICAL

  // SLA tracking
  dueDate           DateTime?
  slaDeadline       DateTime?
  isOverdue         Boolean   @default(false)
  overdueNotifiedAt DateTime?

  // Metadata
  attachments String[] // URLs
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([projectId])
  @@index([category])
  @@index([priority])
  @@index([status])
  @@index([assignedToId])
  @@index([requestedById])
  @@index([dueDate])
  @@index([isOverdue])
  @@map("decision_queue")
}

// ============================================================================
// V10 SPEC: APP HEALTH METRIC
// Application health monitoring for Command Center (APP-15)
// ============================================================================

enum HealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
  OFFLINE
  MAINTENANCE
}

model AppHealthMetric {
  id String @id @default(uuid())

  // App identification
  appId       String // APP-01, APP-02, etc.
  appName     String
  environment String @default("production") // production, staging, development

  // Health status
  status        HealthStatus @default(HEALTHY)
  statusMessage String?

  // Performance metrics
  uptime         Decimal? @db.Decimal(8, 4) // percentage 0-100
  responseTimeMs Int? // average response time
  p95ResponseMs  Int? // 95th percentile
  p99ResponseMs  Int? // 99th percentile
  errorRate      Decimal? @db.Decimal(8, 6) // percentage 0-100
  throughput     Int? // requests per minute

  // Resource utilization
  cpuUsagePercent Decimal? @db.Decimal(5, 2)
  memoryUsageMB   Int?
  memoryLimitMB   Int?
  diskUsageMB     Int?

  // Queue metrics (BullMQ)
  queueDepth           Int? // Jobs waiting
  activeJobs           Int?
  completedJobs24h     Int? // Last 24 hours
  failedJobs24h        Int?
  averageJobDurationMs Int?

  // Error tracking
  lastErrorMessage  String?
  lastErrorAt       DateTime?
  consecutiveErrors Int       @default(0)

  // Dependencies
  databaseConnected Boolean @default(true)
  redisConnected    Boolean @default(true)
  externalApisUp    Boolean @default(true)
  dependencyStatus  Json? // { service: status }

  // Version
  version       String?
  deployedAt    DateTime?
  lastRestartAt DateTime?

  // Alerting
  alertsSent    Int       @default(0)
  lastAlertAt   DateTime?
  isSilenced    Boolean   @default(false)
  silencedUntil DateTime?

  // Snapshot timestamp
  recordedAt DateTime @default(now())

  @@index([appId])
  @@index([status])
  @@index([environment])
  @@index([recordedAt])
  @@map("app_health_metrics")
}
