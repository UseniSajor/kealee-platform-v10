// ============================================================
// CORE PERMIT SCHEMA - Stage 7.5 Base + Dual-Side Extensions
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Add after CONSTRUCTION ADMINISTRATION HANDOFF END

// ============================================================================
// ARCHITECT ONBOARDING & TEMPLATE LIBRARY (Prompt 2.10)
// ============================================================================

enum OnboardingStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TemplateCategory {
  DETAIL
  SCHEDULE
  SHEET
  SPECIFICATION
  CALCULATION
  STANDARD_DETAIL
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Architect onboarding workflow
model ArchitectOnboarding {
  id     String @id @default(uuid())
  userId String @unique

  // Onboarding information
  currentStep          Int     @default(0)
  totalSteps           Int     @default(10)
  completedSteps       Int     @default(0)
  completionPercentage Decimal @default(0) @db.Decimal(5, 2)

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  // Steps tracking (JSON array of step statuses)
  steps Json? // Array of { stepId, name, status, completedAt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("ArchitectOnboarding", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCompleted])
}

// Template library (details, schedules, sheets, etc.)
model DesignTemplate {
  id String @id @default(uuid())

  // Template information
  templateName     String
  templateCategory TemplateCategory
  description      String?
  tags             String[] // Searchable tags

  // Template content
  templateContent Json // Template structure/content
  templateFileUrl String? // URL to template file (DWG, PDF, etc.)
  thumbnailUrl    String? // Preview thumbnail

  // Organization
  organizationId String? // Org-specific template
  isPublic       Boolean @default(false) // Public template library
  isStandard     Boolean @default(false) // Standard detail library

  // Status
  status      TemplateStatus @default(DRAFT)
  publishedAt DateTime?
  version     String         @default("1.0.0")

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  // organization Org? @relation("DesignTemplateOrg", fields: [organizationId], references: [id], onDelete: SetNull) // Org model not defined yet
  createdBy User                     @relation("DesignTemplateCreated", fields: [createdById], references: [id], onDelete: Cascade)
  instances DesignTemplateInstance[]

  @@index([templateCategory])
  @@index([isPublic])
  @@index([isStandard])
  @@index([status])
  @@index([organizationId])
}

// Template instance (usage of template in project)
model DesignTemplateInstance {
  id              String  @id @default(uuid())
  templateId      String
  designProjectId String?

  // Instance information
  instanceName   String
  customizations Json? // Customizations made to template

  // Usage tracking
  usedAt   DateTime @default(now())
  usedById String

  template DesignTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // designProject DesignProject? @relation(fields: [designProjectId], references: [id], onDelete: SetNull) // DesignProject model not defined yet
  usedBy   User           @relation("DesignTemplateInstanceUsed", fields: [usedById], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([designProjectId])
  @@index([usedAt])
}

// Standard detail library entry
model StandardDetail {
  id String @id @default(uuid())

  // Detail information
  detailNumber   String  @unique // e.g., "SD-001", "SD-002"
  detailName     String
  detailCategory String // WALL, ROOF, FOUNDATION, WINDOW, DOOR, etc.
  description    String?

  // Detail content
  detailFileUrl          String // URL to detail drawing (DWG, PDF)
  thumbnailUrl           String?
  applicableCodes        String[] // Building codes this detail applies to
  applicableProjectTypes String[] // Project types this detail is for

  // Organization
  sourceOrganization String? // Organization that created/owns this detail
  isPublic           Boolean @default(true) // Standard details are typically public

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User                     @relation("StandardDetailCreated", fields: [createdById], references: [id], onDelete: Cascade)
  instances StandardDetailInstance[]

  @@index([detailNumber])
  @@index([detailCategory])
  @@index([isPublic])
}

// Standard detail instance (usage in project)
model StandardDetailInstance {
  id               String  @id @default(uuid())
  standardDetailId String
  designProjectId  String
  drawingSheetId   String? // Sheet where detail is placed

  // Instance information
  sheetReference String? // Reference on sheet (e.g., "Detail 1/A2.1")
  customizations Json? // Any customizations made

  // Usage tracking
  placedAt   DateTime @default(now())
  placedById String

  standardDetail StandardDetail @relation(fields: [standardDetailId], references: [id], onDelete: Cascade)
  // designProject DesignProject @relation(fields: [designProjectId], references: [id], onDelete: Cascade) // DesignProject model not defined yet
  // drawingSheet DrawingSheet? @relation(fields: [drawingSheetId], references: [id], onDelete: SetNull) // DrawingSheet model not defined yet
  placedBy       User           @relation("StandardDetailInstancePlaced", fields: [placedById], references: [id], onDelete: Cascade)

  @@index([standardDetailId])
  @@index([designProjectId])
  @@index([drawingSheetId])
}

// Performance benchmark record
model PerformanceBenchmark {
  id              String  @id @default(uuid())
  designProjectId String?

  // Benchmark information
  benchmarkType     String // FILE_UPLOAD, VERSION_COMPARISON, LARGE_FILE_VIEW, etc.
  operationName     String
  operationDuration Int // Milliseconds

  // Context
  fileSize        Int? // Bytes
  fileType        String?
  recordCount     Int? // Number of records processed
  concurrentUsers Int? // Number of concurrent users

  // Results
  success      Boolean @default(true)
  errorMessage String?

  recordedAt DateTime @default(now())

  // designProject DesignProject? @relation(fields: [designProjectId], references: [id], onDelete: SetNull) // DesignProject model not defined yet

  @@index([benchmarkType])
  @@index([recordedAt])
  @@index([designProjectId])
}

// Backup and disaster recovery record
model BackupRecord {
  id String @id @default(uuid())

  // Backup information
  backupType  String // FULL, INCREMENTAL, DATABASE_ONLY, FILES_ONLY
  backupScope String // ALL, PROJECT, ORG, USER
  scopeId     String? // ID of scope (project, org, user)

  // Backup details
  backupLocation String // S3 bucket, local path, etc.
  backupSize     Int? // Bytes
  fileCount      Int?
  recordCount    Int?

  // Status
  status       String // IN_PROGRESS, COMPLETED, FAILED
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  // Verification
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  checksum   String? // Backup integrity checksum

  createdAt   DateTime @default(now())
  createdById String

  createdBy User @relation("BackupRecordCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([backupType])
  @@index([status])
  @@index([startedAt])
  @@index([scopeId])
}

// Disaster recovery plan
model DisasterRecoveryPlan {
  id String @id @default(uuid())

  // Plan information
  planName    String
  planType    String // RTO_PLAN, RPO_PLAN, FULL_DR_PLAN
  description String?

  // Recovery objectives
  recoveryTimeObjective    Int? // Minutes (RTO)
  recoveryPointObjective   Int? // Minutes (RPO)
  maximumTolerableDowntime Int? // Minutes (MTD)

  // Procedures
  procedures         Json? // Step-by-step recovery procedures
  contactInformation Json? // Emergency contacts
  escalationPath     Json? // Escalation procedures

  // Testing
  lastTestedAt DateTime?
  testResults  Json?
  nextTestDate DateTime?

  // Status
  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User @relation("DisasterRecoveryPlanCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([planType])
  @@index([isActive])
}

// ============================================================================
// ARCHITECT ONBOARDING & TEMPLATE LIBRARY END
// ============================================================================

// ============================================================================
// PERMITS & INSPECTIONS HUB - JURISDICTION ADMINISTRATION (Prompt 1.1)
// ============================================================================

enum JurisdictionStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum StaffRole {
  PLAN_REVIEWER
  INSPECTOR
  PERMIT_COORDINATOR
  ADMINISTRATOR
}

model Jurisdiction {
  id     String  @id @default(uuid())
  name   String // "Montgomery County, MD"
  code   String  @unique // "US-MD-MONT"
  state  String
  county String?
  city   String?

  // Dual-Side Extension
  subscriptionTier   String? // BASIC, PRO, ENTERPRISE, CUSTOM
  monthlyFee         Decimal?  @db.Decimal(10, 2)
  subscribedAt       DateTime?
  subscriptionStatus String    @default("TRIAL")

  // Integration
  integrationType String // API_DIRECT, PORTAL_SCRAPE, MANUAL_ENTRY
  apiProvider     String? // ACCELA, TYLER, GOVOS, CUSTOM
  apiUrl          String?
  apiKey          String?
  portalUrl       String?

  // Requirements
  requiredDocuments Json // JSON array of required doc types by permit type
  feeSchedule       Json // Fee calculation rules
  formTemplates     Json // Jurisdiction-specific form schemas

  // Performance Stats
  avgReviewDays         Int?
  firstTimeApprovalRate Float?
  totalPermitsProcessed Int    @default(0)

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  // Relationships
  permits               Permit[]
  staff                 JurisdictionStaff[]
  templates             JurisdictionFormTemplate[]
  inspections           Inspection[]
  integrations          APIIntegration[]
  analytics             JurisdictionAnalytics[]
  usageMetrics          JurisdictionUsageMetrics[]
  permitTemplates       PermitTemplate[]
  integrationLogs       JurisdictionIntegrationLog[] @relation("JurisdictionIntegrationLogJurisdiction")
  routingRules          RoutingRule[]                @relation("RoutingRuleJurisdiction")
  reviewAssignments     ReviewAssignment[]
  inspectionAssignments InspectionAssignment[]

  @@index([code])
  @@index([state, county])
  @@index([subscriptionStatus])
}

// ============================================================
// DUAL-SIDE EXTENSION MODELS
// ============================================================

model JurisdictionStaff {
  id             String  @id @default(uuid())
  jurisdictionId String
  userId         String? // Null if not a Kealee user

  // Staff Info
  firstName  String
  lastName   String
  email      String  @unique
  phone      String?
  employeeId String? // Jurisdiction employee ID

  // Role & Specialty
  role           String // PLAN_REVIEWER, INSPECTOR, PERMIT_TECH, ADMIN, SUPERVISOR
  disciplines    String[] // ["BUILDING", "ELECTRICAL", "FIRE"]
  certifications String[] // ["ICC_CERTIFIED", "PE_LICENSE"]

  // Workload Management
  currentWorkload Int     @default(0) // Active assignments
  maxWorkload     Int     @default(25)
  avgReviewTime   Int? // Minutes average
  isActive        Boolean @default(true)

  // Performance
  reviewsCompleted     Int    @default(0)
  inspectionsCompleted Int    @default(0)
  avgAccuracy          Float? // Based on supervisor reviews

  // Availability
  workingHours  Json // Weekly schedule
  timezone      String @default("America/New_York")
  vacationDates Json // Array of date ranges

  // Mobile
  mobileDeviceId String?
  lastLocation   Json? // {lat, lng, timestamp}
  lastActive     DateTime?

  // Metadata
  hiredDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  jurisdiction          Jurisdiction           @relation(fields: [jurisdictionId], references: [id])
  reviewAssignments     ReviewAssignment[]
  inspectionAssignments InspectionAssignment[]
  inspections           Inspection[]
  remoteInspections     RemoteInspection[]

  @@index([jurisdictionId])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

// Usage metrics tracking (monthly snapshots)
model JurisdictionUsageMetrics {
  id             String @id @default(uuid())
  jurisdictionId String

  // Metrics period
  year  Int
  month Int // 1-12

  // Permit metrics
  permitsSubmitted Int @default(0)
  permitsApproved  Int @default(0)
  permitsIssued    Int @default(0)
  permitsCompleted Int @default(0)

  // Revenue metrics
  permitFeesCollected    Decimal @default(0) @db.Decimal(12, 2)
  expeditedFeesCollected Decimal @default(0) @db.Decimal(12, 2)
  totalRevenue           Decimal @default(0) @db.Decimal(12, 2)

  // Processing metrics
  averageProcessingTime Int? // Days
  averageReviewTime     Int? // Days
  averageInspectionTime Int? // Days

  // Staff metrics
  activeStaffCount     Int @default(0)
  reviewsCompleted     Int @default(0)
  inspectionsCompleted Int @default(0)

  recordedAt DateTime @default(now())

  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  @@unique([jurisdictionId, year, month])
  @@index([jurisdictionId])
  @@index([year, month])
}

// Permit template (jurisdiction-specific)
model PermitTemplate {
  id             String @id @default(uuid())
  jurisdictionId String

  templateName String
  permitType   String // BUILDING, ELECTRICAL, etc.
  templateData Json // Form fields, requirements, etc.

  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("PermitTemplateCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([jurisdictionId])
  @@index([permitType])
}

// ============================================================
// FORM GENERATION & TEMPLATE MODELS
// ============================================================

model JurisdictionFormTemplate {
  id             String     @id @default(uuid())
  jurisdictionId String
  permitType     PermitType

  // Template Info
  formName    String // "Building Permit Application"
  formVersion String  @default("1.0")
  formCode    String? // Jurisdiction form code

  // Structure
  formSchema      Json // JSON Schema definition
  fieldMappings   Json // Kealee fields → Jurisdiction fields
  validationRules Json // Required fields, formats, conditions

  // Generation
  templateUrl      String? // PDF template URL
  generationMethod String // PDF_FILL, HTML_RENDER, API_CALL

  // Status
  isActive     Boolean   @default(true)
  lastUpdated  DateTime  @default(now())
  lastVerified DateTime?

  // Relationships
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, permitType, formVersion])
  @@index([jurisdictionId])
  @@index([permitType])
  @@index([isActive])
}

// Expedited permit service (premium processing)
model ExpeditedPermitService {
  id                  String @id @default(uuid())
  permitApplicationId String

  serviceType String // EXPEDITED_REVIEW, CONCIERGE

  jurisdictionFee Decimal @db.Decimal(10, 2) // What jurisdiction charges
  kealeeMarkup    Decimal @db.Decimal(10, 2) // Our markup (15-25%)
  totalCharge     Decimal @db.Decimal(10, 2)

  guaranteedDays Int // Guaranteed turnaround time in days
  actualDays     Int? // Actual processing days
  metGuarantee   Boolean? // Whether guarantee was met

  status       String    @default("PENDING") // PENDING, ACTIVE, COMPLETED, REFUNDED
  startedAt    DateTime?
  completedAt  DateTime?
  refundIssued Boolean   @default(false)
  refundAmount Decimal?  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // permitApplication PermitApplication @relation("ExpeditedPermitServiceApplication", fields: [permitApplicationId], references: [id], onDelete: Cascade) // PermitApplication replaced by Permit in Stage 7.5

  @@index([permitApplicationId])
  @@index([serviceType])
  @@index([status])
}

// Jurisdiction integration log (tracks API/scraping/email interactions)
model JurisdictionIntegrationLog {
  id                  String  @id @default(uuid())
  jurisdictionId      String
  permitApplicationId String?

  action String // SUBMIT, STATUS_CHECK, UPDATE, RETRIEVE
  method String // API, SCRAPING, EMAIL, PORTAL

  requestData  Json? // Request payload/data sent
  responseData Json? // Response received
  success      Boolean
  errorMessage String?

  executedAt DateTime @default(now())

  jurisdiction                   Jurisdiction         @relation("JurisdictionIntegrationLogJurisdiction", fields: [jurisdictionId], references: [id], onDelete: Cascade)
  // permitApplication PermitApplication? @relation("JurisdictionIntegrationLogApplication", fields: [permitApplicationId], references: [id], onDelete: SetNull) // PermitApplication replaced by Permit in Stage 7.5
  permitApplicationNotifications PermitNotification[] @relation("PermitNotificationApplication")

  @@index([jurisdictionId])
  @@index([permitApplicationId])
  @@index([action])
  @@index([method])
  @@index([success])
  @@index([executedAt])
}

// ============================================================
// CORE PERMIT SCHEMA - Stage 7.5 Base + Dual-Side Extensions
// ============================================================

// ENUMS
enum PermitType {
  BUILDING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE
  GRADING
  DEMOLITION
  SIGN
  FENCE
  ROOFING
  HVAC
  SOLAR
  POOL
}

enum PermitStatus {
  DRAFT
  AI_PRE_REVIEW
  READY_TO_SUBMIT
  SUBMITTED
  UNDER_REVIEW
  CORRECTIONS_REQUESTED
  RESUBMITTED
  APPROVED
  ISSUED
  ACTIVE
  INSPECTION_HOLD
  EXPIRED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ApplicantType {
  OWNER
  CONTRACTOR
  ARCHITECT
  ENGINEER
  DESIGN_BUILDER
  DEVELOPER
}

enum ReviewDiscipline {
  ZONING
  BUILDING
  STRUCTURAL
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE
  ENERGY
  ACCESSIBILITY
  ENVIRONMENTAL
  HEALTH
  TRANSPORTATION
}

enum InspectionType {
  SITE
  FOOTING
  FOUNDATION
  SLAB
  UNDER_SLAB_PLUMBING
  ROUGH_FRAMING
  ROUGH_ELECTRICAL
  ROUGH_PLUMBING
  ROUGH_MECHANICAL
  INSULATION
  GYPSUM_BOARD
  FINAL_ELECTRICAL
  FINAL_PLUMBING
  FINAL_MECHANICAL
  FINAL_BUILDING
  FINAL_FIRE
  CERTIFICATE_OF_OCCUPANCY
  SPECIAL_INSPECTION
  REINSPECTION
}

enum InspectionResult {
  PASS
  PASS_WITH_COMMENTS
  FAIL
  PARTIAL_PASS
  CANCELLED
  NOT_READY
}

enum AIReviewSource {
  CLIENT_SIDE_PRE_REVIEW
  JURISDICTION_SIDE_ASSIST
  REMOTE_INSPECTION_ANALYSIS
  DOCUMENT_COMPLIANCE_CHECK
}

enum DocumentType {
  SITE_PLAN
  FLOOR_PLAN
  ELEVATION
  STRUCTURAL_CALCS
  ENERGY_CALCS
  SURVEY
  PROOF_OF_OWNERSHIP
  HOA_APPROVAL
  ENGINEERING_STAMP
  ARCHITECTURAL_STAMP
  OTHER
}

// ============================================================
// CORE MODELS (Stage 7.5)
// ============================================================

model Permit {
  id             String  @id @default(uuid())
  permitNumber   String? @unique // Auto-generated after submission
  projectId      String
  clientId       String
  jurisdictionId String
  pmUserId       String // Kealee PM assigned

  // Basic Info
  permitType    PermitType
  subtype       String? // "Kitchen Remodel", "New Deck", etc.
  scope         String
  valuation     Decimal    @db.Decimal(12, 2) // For fee calculation
  squareFootage Int?
  units         Int? // For multi-family
  stories       Int?

  // Property Info
  propertyId   String?
  address      String
  parcelNumber String?
  zoning       String?

  // Applicant Info
  applicantId    String
  applicantType  ApplicantType
  applicantName  String
  applicantEmail String
  applicantPhone String

  // Professionals
  architectId       String?
  architectName     String?
  architectLicense  String?
  engineerId        String?
  engineerName      String?
  engineerLicense   String?
  contractorId      String?
  contractorName    String?
  contractorLicense String?

  // Status Tracking (Client-Side)
  status          PermitStatus @default(DRAFT) // Alias for kealeeStatus, used by Command Center
  kealeeStatus    PermitStatus @default(DRAFT)
  aiReviewScore   Int? // 0-100 score from AI pre-review
  aiIssuesFound   Json? // JSON array of issues detected
  autoCorrections Json? // Corrections made before submission
  readyToSubmit   Boolean      @default(false)

  // Jurisdiction Tracking (Dual-Side)
  jurisdictionRefNumber String? // Jurisdiction's permit number
  jurisdictionStatus    String? // Status in jurisdiction's system
  submittedVia          String? // API, PORTAL, EMAIL, MANUAL
  submittedAt           DateTime?
  reviewStartedAt       DateTime?
  approvedAt            DateTime?
  issuedAt              DateTime?
  expiresAt             DateTime?
  completedAt           DateTime?

  // Fees
  calculatedFee Decimal?  @db.Decimal(10, 2)
  paidAmount    Decimal?  @default(0) @db.Decimal(10, 2)
  feePaid       Boolean   @default(false)
  feePaidAt     DateTime?

  // Expedited Processing
  expedited              Boolean  @default(false)
  expeditedFee           Decimal? @db.Decimal(10, 2)
  expeditedGuaranteeDays Int? // 2, 5, 10 day guarantee

  // Documents
  plans          String[] // Array of S3 URLs
  calculations   String[]
  reports        String[]
  otherDocuments String[]

  // Relationships
  jurisdiction        Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  project             Project              @relation(fields: [projectId], references: [id])
  property            Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  aiReviews           AIReviewResult[]
  submissions         PermitSubmission[]
  corrections         PermitCorrection[]
  reviewAssignments   ReviewAssignment[]
  inspections         Inspection[]
  events              PermitEvent[]
  permitRoutings      PermitRouting[]      @relation("PermitRoutingPermit")
  permitNotifications PermitNotification[] @relation("PermitNotificationPermit")
  activities          PermitActivity[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([clientId])
  @@index([jurisdictionId])
  @@index([kealeeStatus])
  @@index([jurisdictionStatus])
  @@index([submittedAt])
  @@index([permitNumber])
}

model AIReviewResult {
  id            String         @id @default(uuid())
  permitId      String
  reviewSource  AIReviewSource
  overallScore  Int // 0-100
  readyToSubmit Boolean

  // Findings
  planIssues       Json // Array of plan-related issues
  codeViolations   Json // Array of code violations
  missingDocuments Json // Array of missing required docs
  suggestedFixes   Json // Array of suggested fixes

  // Metadata
  modelVersion     String
  processingTimeMs Int
  confidenceScores Json // Per-issue confidence scores

  reviewedAt DateTime @default(now())
  reviewedBy String? // NULL for AI, user ID for human

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([reviewSource])
  @@index([reviewedAt])
}

model PermitSubmission {
  id       String @id @default(uuid())
  permitId String

  submissionType String // INITIAL, RESUBMITTAL, SUPPLEMENTAL
  submittedVia   String // API, PORTAL, EMAIL, MANUAL, FAX
  submittedBy    String // User ID
  submittedAt    DateTime @default(now())

  // Submission Data
  documents Json // Array of document metadata
  formData  Json // Form field values
  notes     String?

  // Jurisdiction Response
  confirmationNumber   String?
  jurisdictionResponse Json? // Raw response from jurisdiction
  submissionStatus     String? // RECEIVED, PROCESSING, REJECTED

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([submittedAt])
  @@index([confirmationNumber])
}

model PermitCorrection {
  id       String @id @default(uuid())
  permitId String

  source     String // JURISDICTION_EMAIL, PORTAL_COMMENT, PHONE_CALL, AI_DETECTION
  receivedAt DateTime @default(now())
  rawText    String // Original correction text

  // Parsed Data
  parsedIssues   Json // Array of structured issues
  affectedSheets String[] // Drawing sheet references
  severity       String // MINOR, MAJOR, CRITICAL
  discipline     ReviewDiscipline?

  // Assignment & Tracking
  assignedTo      String // ARCHITECT, ENGINEER, CONTRACTOR, OWNER
  assignedUserId  String? // Kealee user assigned to fix
  dueDate         DateTime
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, OVERDUE
  resolvedAt      DateTime?
  resolutionNotes String?

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedTo])
}

// ============================================================
// EVENT & AUDIT MODELS
// ============================================================

model PermitEvent {
  id       String  @id @default(uuid())
  permitId String
  userId   String? // NULL for system events

  eventType   String // STATUS_CHANGE, DOCUMENT_UPLOAD, FEE_PAID, etc.
  description String
  metadata    Json? // Additional event data

  // Source
  source    String  @default("SYSTEM") // SYSTEM, USER, API, WEBHOOK
  ipAddress String?
  userAgent String?

  occurredAt DateTime @default(now())

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([userId])
}

model Inspection {
  id               String  @id @default(uuid())
  inspectionNumber String? @unique
  permitId         String
  projectId        String
  jurisdictionId   String

  inspectionType InspectionType
  description    String?
  phaseRequired  String? // Construction phase

  // Preparation (Client-Side)
  checklistId     String?
  sitePhotos      String[] // Pre-inspection photos
  pmPreInspection DateTime? // PM verification date
  readyToSchedule Boolean   @default(false)
  notes           String? // Contractor notes about readiness

  // Scheduling (Jurisdiction-Side)
  requestedDate         DateTime
  requestedBy           String // User ID
  scheduledDate         DateTime?
  scheduledWindow       String? // "8:00-12:00", "1:00-5:00"
  inspectorId           String? // Jurisdiction inspector
  jurisdictionRefNumber String?

  // Remote Inspection (Dual-Side Extension)
  isRemote          Boolean @default(false)
  videoSessionId    String?
  videoRecordingUrl String?
  liveStreamUrl     String?
  aiVideoAnalysis   Json?

  // Results
  result         InspectionResult?
  inspectorNotes String?
  deficiencies   Json? // Array of deficiencies found
  passedItems    Int?
  failedItems    Int?
  totalItems     Int?
  completedAt    DateTime?

  // Reinspection Tracking
  parentInspectionId String?
  isReinspection     Boolean @default(false)

  // Relationships
  permit               Permit                @relation(fields: [permitId], references: [id])
  project              Project               @relation(fields: [projectId], references: [id])
  jurisdiction         Jurisdiction          @relation(fields: [jurisdictionId], references: [id])
  inspector            JurisdictionStaff?    @relation(fields: [inspectorId], references: [id])
  remoteSession        RemoteInspection?
  inspectionAssignment InspectionAssignment?

  // Command Center relations
  preparationItems     InspectionPreparationItem[]
  findings             InspectionFinding[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permitId])
  @@index([projectId])
  @@index([jurisdictionId])
  @@index([scheduledDate])
  @@index([inspectorId])
  @@index([result])
}

