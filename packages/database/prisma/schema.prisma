// ============================================================================
// V10 SPEC: PROJECT MEMBERSHIP
// Explicit project-level team membership and role tracking
// ============================================================================

enum ProjectMemberRole {
  PROJECT_MANAGER
  SUPERINTENDENT
  ESTIMATOR
  FOREMAN
  FIELD_WORKER
  SUBCONTRACTOR
  CLIENT_REP
  ARCHITECT
  ENGINEER
  INSPECTOR
  OBSERVER
}

model ProjectMembership {
  id        String  @id @default(uuid())
  projectId String
  userId    String
  orgId     String?

  role        ProjectMemberRole
  permissions Json? // Granular permissions override

  // Status
  isActive  Boolean   @default(true)
  invitedAt DateTime  @default(now())
  joinedAt  DateTime?
  removedAt DateTime?
  removedBy String?

  // Notification preferences per project
  notifyOnRFI         Boolean @default(true)
  notifyOnChangeOrder Boolean @default(true)
  notifyOnDailyLog    Boolean @default(true)
  notifyOnSubmittal   Boolean @default(true)
  notifyOnSchedule    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([role])
  @@index([isActive])
  @@map("project_memberships")
}

// ============================================================================
// V10 SPEC: SUBSCRIPTION (generic platform subscription)
// ============================================================================

enum PlatformSubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum PlatformSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

model Subscription {
  id     String  @id @default(uuid())
  orgId  String
  userId String? // Account owner

  tier   PlatformSubscriptionTier
  status PlatformSubscriptionStatus @default(TRIALING)

  // Pricing
  monthlyPrice    Decimal  @db.Decimal(10, 2)
  annualPrice     Decimal? @db.Decimal(10, 2)
  billingInterval String   @default("MONTHLY") // MONTHLY, ANNUAL

  // Dates
  trialStartDate DateTime?
  trialEndDate   DateTime?
  startDate      DateTime?
  endDate        DateTime?
  cancelledAt    DateTime?
  cancelReason   String?

  // Stripe integration
  stripeSubscriptionId String? @unique
  stripeCustomerId     String?
  stripePriceId        String?

  // Feature limits
  maxProjects      Int      @default(3)
  maxUsers         Int      @default(5)
  maxStorageGB     Int      @default(10)
  maxApiCalls      Int      @default(1000) // per day
  aiCreditsMonthly Int      @default(100)
  aiCreditsUsed    Int      @default(0)
  includedApps     String[] // APP-01, APP-06, etc.

  // Usage tracking
  currentProjects Int @default(0)
  currentUsers    Int @default(0)
  storageUsedMB   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ============================================================================
// V10 SPEC: REVIEW (contractor/service provider ratings)
// ============================================================================

enum ReviewTargetType {
  CONTRACTOR
  SUBCONTRACTOR
  PM
  PROJECT
  SERVICE
}

model Review {
  id        String  @id @default(uuid())
  projectId String?
  orgId     String?

  // Who
  reviewerId   String // User who left the review
  targetType   ReviewTargetType
  targetId     String // Contractor ID, User ID, or Project ID
  targetUserId String? // If reviewing a specific user

  // Ratings (1-5 scale)
  overallRating         Int // 1-5
  qualityRating         Int? // Quality of work
  timelinessRating      Int? // On-time delivery
  communicationRating   Int? // Communication quality
  budgetRating          Int? // Budget adherence
  safetyRating          Int? // Safety practices
  professionalismRating Int? // Professionalism

  // Content
  title       String?
  comment     String    @db.Text
  response    String?   @db.Text // Response from reviewed party
  respondedAt DateTime?

  // Verification
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  verificationMethod String? // PROJECT_COMPLETION, PAYMENT_CONFIRMED, MANUAL

  // Moderation
  isPublic    Boolean   @default(true)
  isFlagged   Boolean   @default(false)
  flagReason  String?
  moderatedAt DateTime?
  moderatedBy String?

  // Helpfulness
  helpfulCount    Int @default(0)
  notHelpfulCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviewer User @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([reviewerId])
  @@index([projectId])
  @@index([overallRating])
  @@index([isPublic, isVerified])
  @@map("reviews")
}

// ============================================================================
// V10 SPEC: PROPOSAL & PROPOSAL LINE ITEM
// ============================================================================

enum ProposalStatus {
  DRAFT
  INTERNAL_REVIEW
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  REVISED
  WITHDRAWN
}

model Proposal {
  id        String  @id @default(uuid())
  projectId String?
  orgId     String
  clientId  String?
  leadId    String?

  // Identification
  proposalNumber String  @unique
  version        Int     @default(1)
  parentId       String? // For revisions

  // Content
  title       String
  summary     String? @db.Text
  scopeOfWork String? @db.Text
  exclusions  String? @db.Text
  assumptions String? @db.Text
  terms       String? @db.Text

  // Financial
  subtotal    Decimal  @db.Decimal(14, 2)
  taxRate     Decimal? @db.Decimal(5, 4)
  taxAmount   Decimal? @db.Decimal(14, 2)
  discount    Decimal? @db.Decimal(14, 2)
  totalAmount Decimal  @db.Decimal(14, 2)

  // Schedule
  estimatedStartDate DateTime?
  estimatedEndDate   DateTime?
  estimatedDuration  Int? // working days
  validUntil         DateTime?

  // Status
  status          ProposalStatus @default(DRAFT)
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?

  // Document
  documentUrl  String?
  signatureUrl String?
  signedAt     DateTime?
  signedBy     String?

  // Metadata
  preparedById String?
  templateId   String?
  tags         String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lineItems ProposalLineItem[]

  @@index([orgId])
  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([proposalNumber])
  @@map("proposals")
}

model ProposalLineItem {
  id         String @id @default(uuid())
  proposalId String

  // Item details
  sortOrder   Int     @default(0)
  category    String? // Division/section
  description String
  quantity    Decimal @db.Decimal(12, 4)
  unit        String  @default("EA") // EA, SF, LF, HR, etc.
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(14, 2)

  // Cost breakdown
  materialCost  Decimal? @db.Decimal(12, 2)
  laborCost     Decimal? @db.Decimal(12, 2)
  equipmentCost Decimal? @db.Decimal(12, 2)
  markup        Decimal? @db.Decimal(5, 4)
  marginPercent Decimal? @db.Decimal(5, 4)

  // Categorization
  csiCode     String? // CSI MasterFormat
  trade       String? // Plumbing, Electrical, etc.
  isOptional  Boolean @default(false)
  isAlternate Boolean @default(false)
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([category])
  @@map("proposal_line_items")
}

// ============================================================================
// V10 SPEC: CONTRACT PARTY
// Multi-party contract linkage for complex construction agreements
// ============================================================================

enum ContractPartyRole {
  OWNER
  GENERAL_CONTRACTOR
  SUBCONTRACTOR
  ARCHITECT
  ENGINEER
  CONSULTANT
  SURETY
  LENDER
  INSPECTOR
}

model ContractParty {
  id           String  @id @default(uuid())
  contractId   String
  userId       String?
  orgId        String?
  contractorId String?

  role              ContractPartyRole
  isPrimary         Boolean           @default(false)
  signatureRequired Boolean           @default(true)

  // Signature
  signedAt     DateTime?
  signedBy     String?
  signatureUrl String?
  signatureIp  String?

  // Contact info override
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Obligations
