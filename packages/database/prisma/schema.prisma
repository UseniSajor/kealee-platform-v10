// ============================================================
// CORE PERMIT SCHEMA - Stage 7.5 Base + Dual-Side Extensions
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Add after CONSTRUCTION ADMINISTRATION HANDOFF END

// ============================================================================
// ARCHITECT ONBOARDING & TEMPLATE LIBRARY (Prompt 2.10)
// ============================================================================

enum OnboardingStepStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum TemplateCategory {
  DETAIL
  SCHEDULE
  SHEET
  SPECIFICATION
  CALCULATION
  STANDARD_DETAIL
}

enum TemplateStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Architect onboarding workflow
model ArchitectOnboarding {
  id     String @id @default(uuid())
  userId String @unique

  // Onboarding information
  currentStep          Int     @default(0)
  totalSteps           Int     @default(10)
  completedSteps       Int     @default(0)
  completionPercentage Decimal @default(0) @db.Decimal(5, 2)

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  startedAt   DateTime  @default(now())

  // Steps tracking (JSON array of step statuses)
  steps Json? // Array of { stepId, name, status, completedAt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("ArchitectOnboarding", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isCompleted])
}

// Template library (details, schedules, sheets, etc.)
model DesignTemplate {
  id String @id @default(uuid())

  // Template information
  templateName     String
  templateCategory TemplateCategory
  description      String?
  tags             String[] // Searchable tags

  // Template content
  templateContent Json // Template structure/content
  templateFileUrl String? // URL to template file (DWG, PDF, etc.)
  thumbnailUrl    String? // Preview thumbnail

  // Organization
  organizationId String? // Org-specific template
  isPublic       Boolean @default(false) // Public template library
  isStandard     Boolean @default(false) // Standard detail library

  // Status
  status      TemplateStatus @default(DRAFT)
  publishedAt DateTime?
  version     String         @default("1.0.0")

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  // organization Org? @relation("DesignTemplateOrg", fields: [organizationId], references: [id], onDelete: SetNull) // Org model not defined yet
  createdBy User                     @relation("DesignTemplateCreated", fields: [createdById], references: [id], onDelete: Cascade)
  instances DesignTemplateInstance[]

  @@index([templateCategory])
  @@index([isPublic])
  @@index([isStandard])
  @@index([status])
  @@index([organizationId])
}

// Template instance (usage of template in project)
model DesignTemplateInstance {
  id              String  @id @default(uuid())
  templateId      String
  designProjectId String?

  // Instance information
  instanceName   String
  customizations Json? // Customizations made to template

  // Usage tracking
  usedAt   DateTime @default(now())
  usedById String

  template DesignTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // designProject DesignProject? @relation(fields: [designProjectId], references: [id], onDelete: SetNull) // DesignProject model not defined yet
  usedBy   User           @relation("DesignTemplateInstanceUsed", fields: [usedById], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([designProjectId])
  @@index([usedAt])
}

// Standard detail library entry
model StandardDetail {
  id String @id @default(uuid())

  // Detail information
  detailNumber   String  @unique // e.g., "SD-001", "SD-002"
  detailName     String
  detailCategory String // WALL, ROOF, FOUNDATION, WINDOW, DOOR, etc.
  description    String?

  // Detail content
  detailFileUrl          String // URL to detail drawing (DWG, PDF)
  thumbnailUrl           String?
  applicableCodes        String[] // Building codes this detail applies to
  applicableProjectTypes String[] // Project types this detail is for

  // Organization
  sourceOrganization String? // Organization that created/owns this detail
  isPublic           Boolean @default(true) // Standard details are typically public

  // Usage tracking
  usageCount Int       @default(0)
  lastUsedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User                     @relation("StandardDetailCreated", fields: [createdById], references: [id], onDelete: Cascade)
  instances StandardDetailInstance[]

  @@index([detailNumber])
  @@index([detailCategory])
  @@index([isPublic])
}

// Standard detail instance (usage in project)
model StandardDetailInstance {
  id               String  @id @default(uuid())
  standardDetailId String
  designProjectId  String
  drawingSheetId   String? // Sheet where detail is placed

  // Instance information
  sheetReference String? // Reference on sheet (e.g., "Detail 1/A2.1")
  customizations Json? // Any customizations made

  // Usage tracking
  placedAt   DateTime @default(now())
  placedById String

  standardDetail StandardDetail @relation(fields: [standardDetailId], references: [id], onDelete: Cascade)
  // designProject DesignProject @relation(fields: [designProjectId], references: [id], onDelete: Cascade) // DesignProject model not defined yet
  // drawingSheet DrawingSheet? @relation(fields: [drawingSheetId], references: [id], onDelete: SetNull) // DrawingSheet model not defined yet
  placedBy       User           @relation("StandardDetailInstancePlaced", fields: [placedById], references: [id], onDelete: Cascade)

  @@index([standardDetailId])
  @@index([designProjectId])
  @@index([drawingSheetId])
}

// Performance benchmark record
model PerformanceBenchmark {
  id              String  @id @default(uuid())
  designProjectId String?

  // Benchmark information
  benchmarkType     String // FILE_UPLOAD, VERSION_COMPARISON, LARGE_FILE_VIEW, etc.
  operationName     String
  operationDuration Int // Milliseconds

  // Context
  fileSize        Int? // Bytes
  fileType        String?
  recordCount     Int? // Number of records processed
  concurrentUsers Int? // Number of concurrent users

  // Results
  success      Boolean @default(true)
  errorMessage String?

  recordedAt DateTime @default(now())

  // designProject DesignProject? @relation(fields: [designProjectId], references: [id], onDelete: SetNull) // DesignProject model not defined yet

  @@index([benchmarkType])
  @@index([recordedAt])
  @@index([designProjectId])
}

// Backup and disaster recovery record
model BackupRecord {
  id String @id @default(uuid())

  // Backup information
  backupType  String // FULL, INCREMENTAL, DATABASE_ONLY, FILES_ONLY
  backupScope String // ALL, PROJECT, ORG, USER
  scopeId     String? // ID of scope (project, org, user)

  // Backup details
  backupLocation String // S3 bucket, local path, etc.
  backupSize     Int? // Bytes
  fileCount      Int?
  recordCount    Int?

  // Status
  status       String // IN_PROGRESS, COMPLETED, FAILED
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  errorMessage String?

  // Verification
  isVerified Boolean   @default(false)
  verifiedAt DateTime?
  checksum   String? // Backup integrity checksum

  createdAt   DateTime @default(now())
  createdById String

  createdBy User @relation("BackupRecordCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([backupType])
  @@index([status])
  @@index([startedAt])
  @@index([scopeId])
}

// Disaster recovery plan
model DisasterRecoveryPlan {
  id String @id @default(uuid())

  // Plan information
  planName    String
  planType    String // RTO_PLAN, RPO_PLAN, FULL_DR_PLAN
  description String?

  // Recovery objectives
  recoveryTimeObjective    Int? // Minutes (RTO)
  recoveryPointObjective   Int? // Minutes (RPO)
  maximumTolerableDowntime Int? // Minutes (MTD)

  // Procedures
  procedures         Json? // Step-by-step recovery procedures
  contactInformation Json? // Emergency contacts
  escalationPath     Json? // Escalation procedures

  // Testing
  lastTestedAt DateTime?
  testResults  Json?
  nextTestDate DateTime?

  // Status
  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  createdBy User @relation("DisasterRecoveryPlanCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([planType])
  @@index([isActive])
}

// ============================================================================
// ARCHITECT ONBOARDING & TEMPLATE LIBRARY END
// ============================================================================

// ============================================================================
// PERMITS & INSPECTIONS HUB - JURISDICTION ADMINISTRATION (Prompt 1.1)
// ============================================================================

enum JurisdictionStatus {
  ACTIVE
  INACTIVE
  PENDING_SETUP
}

enum SubscriptionTier {
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum StaffRole {
  PLAN_REVIEWER
  INSPECTOR
  PERMIT_COORDINATOR
  ADMINISTRATOR
}

model Jurisdiction {
  id     String  @id @default(uuid())
  name   String // "Montgomery County, MD"
  code   String  @unique // "US-MD-MONT"
  state  String
  county String?
  city   String?

  // Dual-Side Extension
  subscriptionTier   String? // BASIC, PRO, ENTERPRISE, CUSTOM
  monthlyFee         Decimal?  @db.Decimal(10, 2)
  subscribedAt       DateTime?
  subscriptionStatus String    @default("TRIAL")

  // Integration
  integrationType String // API_DIRECT, PORTAL_SCRAPE, MANUAL_ENTRY
  apiProvider     String? // ACCELA, TYLER, GOVOS, CUSTOM
  apiUrl          String?
  apiKey          String?
  portalUrl       String?

  // Requirements
  requiredDocuments Json // JSON array of required doc types by permit type
  feeSchedule       Json // Fee calculation rules
  formTemplates     Json // Jurisdiction-specific form schemas

  // Performance Stats
  avgReviewDays         Int?
  firstTimeApprovalRate Float?
  totalPermitsProcessed Int    @default(0)

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastSyncedAt DateTime?

  // Relationships
  permits               Permit[]
  staff                 JurisdictionStaff[]
  templates             JurisdictionFormTemplate[]
  inspections           Inspection[]
  integrations          APIIntegration[]
  analytics             JurisdictionAnalytics[]
  usageMetrics          JurisdictionUsageMetrics[]
  permitTemplates       PermitTemplate[]
  integrationLogs       JurisdictionIntegrationLog[] @relation("JurisdictionIntegrationLogJurisdiction")
  routingRules          RoutingRule[]                @relation("RoutingRuleJurisdiction")
  reviewAssignments     ReviewAssignment[]
  inspectionAssignments InspectionAssignment[]

  // Housing Act – Zoning, Pattern Book, Municipal Dashboard
  zoningProfiles     ZoningProfile[]            @relation("JurisdictionZoning")
  patternBookDesigns PatternBookDesign[]        @relation("JurisdictionPatternBooks")
  housingPipeline    HousingPipelineEntry[]     @relation("JurisdictionHousingPipeline")
  dashboardSnapshots HousingDashboardSnapshot[] @relation("JurisdictionDashboardSnapshots")

  @@index([code])
  @@index([state, county])
  @@index([subscriptionStatus])
}

// ============================================================
// DUAL-SIDE EXTENSION MODELS
// ============================================================

model JurisdictionStaff {
  id             String  @id @default(uuid())
  jurisdictionId String
  userId         String? // Null if not a Kealee user

  // Staff Info
  firstName  String
  lastName   String
  email      String  @unique
  phone      String?
  employeeId String? // Jurisdiction employee ID

  // Role & Specialty
  role           String // PLAN_REVIEWER, INSPECTOR, PERMIT_TECH, ADMIN, SUPERVISOR
  disciplines    String[] // ["BUILDING", "ELECTRICAL", "FIRE"]
  certifications String[] // ["ICC_CERTIFIED", "PE_LICENSE"]

  // Workload Management
  currentWorkload Int     @default(0) // Active assignments
  maxWorkload     Int     @default(25)
  avgReviewTime   Int? // Minutes average
  isActive        Boolean @default(true)

  // Performance
  reviewsCompleted     Int    @default(0)
  inspectionsCompleted Int    @default(0)
  avgAccuracy          Float? // Based on supervisor reviews

  // Availability
  workingHours  Json // Weekly schedule
  timezone      String @default("America/New_York")
  vacationDates Json // Array of date ranges

  // Mobile
  mobileDeviceId String?
  lastLocation   Json? // {lat, lng, timestamp}
  lastActive     DateTime?

  // Metadata
  hiredDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  jurisdiction          Jurisdiction           @relation(fields: [jurisdictionId], references: [id])
  reviewAssignments     ReviewAssignment[]
  inspectionAssignments InspectionAssignment[]
  inspections           Inspection[]
  remoteInspections     RemoteInspection[]

  @@index([jurisdictionId])
  @@index([email])
  @@index([role])
  @@index([isActive])
}

// Usage metrics tracking (monthly snapshots)
model JurisdictionUsageMetrics {
  id             String @id @default(uuid())
  jurisdictionId String

  // Metrics period
  year  Int
  month Int // 1-12

  // Permit metrics
  permitsSubmitted Int @default(0)
  permitsApproved  Int @default(0)
  permitsIssued    Int @default(0)
  permitsCompleted Int @default(0)

  // Revenue metrics
  permitFeesCollected    Decimal @default(0) @db.Decimal(12, 2)
  expeditedFeesCollected Decimal @default(0) @db.Decimal(12, 2)
  totalRevenue           Decimal @default(0) @db.Decimal(12, 2)

  // Processing metrics
  averageProcessingTime Int? // Days
  averageReviewTime     Int? // Days
  averageInspectionTime Int? // Days

  // Staff metrics
  activeStaffCount     Int @default(0)
  reviewsCompleted     Int @default(0)
  inspectionsCompleted Int @default(0)

  recordedAt DateTime @default(now())

  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)

  @@unique([jurisdictionId, year, month])
  @@index([jurisdictionId])
  @@index([year, month])
}

// Permit template (jurisdiction-specific)
model PermitTemplate {
  id             String @id @default(uuid())
  jurisdictionId String

  templateName String
  permitType   String // BUILDING, ELECTRICAL, etc.
  templateData Json // Form fields, requirements, etc.

  isActive Boolean @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("PermitTemplateCreated", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([jurisdictionId])
  @@index([permitType])
}

// ============================================================
// FORM GENERATION & TEMPLATE MODELS
// ============================================================

model JurisdictionFormTemplate {
  id             String     @id @default(uuid())
  jurisdictionId String
  permitType     PermitType

  // Template Info
  formName    String // "Building Permit Application"
  formVersion String  @default("1.0")
  formCode    String? // Jurisdiction form code

  // Structure
  formSchema      Json // JSON Schema definition
  fieldMappings   Json // Kealee fields → Jurisdiction fields
  validationRules Json // Required fields, formats, conditions

  // Generation
  templateUrl      String? // PDF template URL
  generationMethod String // PDF_FILL, HTML_RENDER, API_CALL

  // Status
  isActive     Boolean   @default(true)
  lastUpdated  DateTime  @default(now())
  lastVerified DateTime?

  // Relationships
  jurisdiction Jurisdiction @relation(fields: [jurisdictionId], references: [id])

  @@unique([jurisdictionId, permitType, formVersion])
  @@index([jurisdictionId])
  @@index([permitType])
  @@index([isActive])
}

// Expedited permit service (premium processing)
model ExpeditedPermitService {
  id                  String @id @default(uuid())
  permitApplicationId String

  serviceType String // EXPEDITED_REVIEW, CONCIERGE

  jurisdictionFee Decimal @db.Decimal(10, 2) // What jurisdiction charges
  kealeeMarkup    Decimal @db.Decimal(10, 2) // Our markup (15-25%)
  totalCharge     Decimal @db.Decimal(10, 2)

  guaranteedDays Int // Guaranteed turnaround time in days
  actualDays     Int? // Actual processing days
  metGuarantee   Boolean? // Whether guarantee was met

  status       String    @default("PENDING") // PENDING, ACTIVE, COMPLETED, REFUNDED
  startedAt    DateTime?
  completedAt  DateTime?
  refundIssued Boolean   @default(false)
  refundAmount Decimal?  @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permitApplicationId])
  @@index([serviceType])
  @@index([status])
}

// Jurisdiction integration log (tracks API/scraping/email interactions)
model JurisdictionIntegrationLog {
  id                  String  @id @default(uuid())
  jurisdictionId      String
  permitApplicationId String?

  action String // SUBMIT, STATUS_CHECK, UPDATE, RETRIEVE
  method String // API, SCRAPING, EMAIL, PORTAL

  requestData  Json? // Request payload/data sent
  responseData Json? // Response received
  success      Boolean
  errorMessage String?

  executedAt DateTime @default(now())

  jurisdiction                   Jurisdiction         @relation("JurisdictionIntegrationLogJurisdiction", fields: [jurisdictionId], references: [id], onDelete: Cascade)
  permitApplicationNotifications PermitNotification[] @relation("PermitNotificationApplication")

  @@index([jurisdictionId])
  @@index([permitApplicationId])
  @@index([action])
  @@index([method])
  @@index([success])
  @@index([executedAt])
}

// ============================================================
// CORE PERMIT SCHEMA - Stage 7.5 Base + Dual-Side Extensions
// ============================================================

// ENUMS
enum PermitType {
  BUILDING
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE
  GRADING
  DEMOLITION
  SIGN
  FENCE
  ROOFING
  HVAC
  SOLAR
  POOL
}

enum PermitStatus {
  DRAFT
  AI_PRE_REVIEW
  READY_TO_SUBMIT
  SUBMITTED
  UNDER_REVIEW
  CORRECTIONS_REQUESTED
  RESUBMITTED
  APPROVED
  ISSUED
  ACTIVE
  INSPECTION_HOLD
  EXPIRED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ApplicantType {
  OWNER
  CONTRACTOR
  ARCHITECT
  ENGINEER
  DESIGN_BUILDER
  DEVELOPER
}

enum ReviewDiscipline {
  ZONING
  BUILDING
  STRUCTURAL
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE
  ENERGY
  ACCESSIBILITY
  ENVIRONMENTAL
  HEALTH
  TRANSPORTATION
}

enum InspectionType {
  SITE
  FOOTING
  FOUNDATION
  SLAB
  UNDER_SLAB_PLUMBING
  ROUGH_FRAMING
  ROUGH_ELECTRICAL
  ROUGH_PLUMBING
  ROUGH_MECHANICAL
  INSULATION
  GYPSUM_BOARD
  FINAL_ELECTRICAL
  FINAL_PLUMBING
  FINAL_MECHANICAL
  FINAL_BUILDING
  FINAL_FIRE
