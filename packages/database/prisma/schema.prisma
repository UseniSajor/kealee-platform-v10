model ModuleEntitlement {
  id         String    @id @default(uuid())
  orgId      String
  moduleKey  String
  enabled    Boolean   @default(false)
  enabledAt  DateTime?
  disabledAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleKey])
  @@index([orgId])
  @@index([moduleKey])
  @@index([enabled])
}

// ============================================================================
// PROPERTY MODEL
// ============================================================================

model Property {
  id        String   @id @default(uuid())
  orgId     String?
  address   String
  city      String
  state     String
  zip       String
  country   String   @default("US")
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  projects Project[]
  permits  Permit[]

  @@index([orgId])
  @@index([city, state])
}

// ============================================================================
// ORGANIZATIONS & MEMBERSHIPS
// ============================================================================

model Org {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logo        String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      OrgMember[]
  projects     Project[]
  properties   Property[]
  entitlements ModuleEntitlement[]

  // Command Center Infrastructure relations
  integrationCredentials IntegrationCredential[]

  @@index([slug])
  @@index([status])
}

model OrgMember {
  id       String   @id @default(uuid())
  userId   String
  orgId    String
  roleKey  String
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleKey], references: [key])

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
  @@index([roleKey])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
  @@index([expires])
}

// ============================================================================
// CONTRACTS, MILESTONES, ESCROW & DISPUTES
// ============================================================================

enum ContractStatus {
  DRAFT
  SENT
  SENT_FOR_SIGNATURE
  PARTIALLY_SIGNED
  FULLY_SIGNED
  SIGNED
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISPUTED
  PAID
}

enum EscrowStatus {
  PENDING_DEPOSIT
  ACTIVE
  FROZEN
  CLOSED
}

enum EscrowTransactionType {
  DEPOSIT
  RELEASE
  REFUND
  FEE
  INTEREST
}

enum EscrowTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

enum EscrowHoldReason {
  DISPUTE
  COMPLIANCE
  MANUAL
  LIEN
}

enum EscrowHoldStatus {
  ACTIVE
  RELEASED
}

enum DisputeStatus {
  OPEN // Initial status
  UNDER_REVIEW // Evidence review phase
  MEDIATION // Active mediation
  RESOLVED // Resolution decided
  CLOSED // Fully closed
  CANCELLED // Cancelled by initiator
}

enum DisputeType {
  PAYMENT // Payment dispute
  QUALITY // Quality of work
  SCOPE // Scope of work
  TIMELINE // Timeline/delays
  OTHER // Other issues
}

enum DisputeEvidenceType {
  DOCUMENT
  PHOTO
  VIDEO
  MESSAGE
  OTHER
}

enum DisputeResolutionType {
  FULL_RELEASE // Release full amount to contractor
  PARTIAL_RELEASE // Split between parties
  NO_RELEASE // No release, return to owner
  REFUND // Full refund to owner
}

enum DisputeAppealStatus {
  NONE // No appeal
  PENDING // Appeal filed, under review
  ACCEPTED // Appeal accepted, case reopened
  REJECTED // Appeal rejected
}

// ============================================================================
// LIEN WAIVER SYSTEM (Stage 5 - Finance & Trust - Compliance)
// ============================================================================

enum LienWaiverType {
  CONDITIONAL // Payment pending
  UNCONDITIONAL // Payment cleared
}

enum LienWaiverScope {
  PARTIAL // Progress payment
  FINAL // Final payment with holdback
}

enum LienWaiverStatus {
  GENERATED // Created, not sent
  SENT // Sent for signature
  SIGNED // Signed by contractor
  RECORDED // Officially recorded
  EXPIRED // Expired without signature
}

enum LienWaiverSignerRole {
  CONTRACTOR
  SUBCONTRACTOR
  SUPPLIER
  OWNER
}

enum LeadStatus {
  OPEN
  INTAKE
  DISTRIBUTED
  QUOTED
  AWARDED
  LOST
  CLOSED
}

model ContractAgreement {
  id                 String         @id @default(uuid())
  projectId          String
  ownerId            String
  contractorId       String
  amount             Decimal
  status             ContractStatus @default(DRAFT)
  signedAt           DateTime?
  expiresAt          DateTime?
  docusignEnvelopeId String?
  signedDocumentUrl  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner           User             @relation("ContractOwner", fields: [ownerId], references: [id])
  contractor      User             @relation("ContractContractor", fields: [contractorId], references: [id])
  milestones      Milestone[]
  escrowAgreement EscrowAgreement?
  disputes        Dispute[]
  lienWaivers     LienWaiver[]

  // Compliance relations
  complianceChecks ComplianceCheck[] @relation("ComplianceCheckContract")
  bonds            BondTracking[]    @relation("ContractBonds")
  complianceAlerts ComplianceAlert[] @relation("ComplianceAlertContract")

  @@index([projectId])
  @@index([ownerId])
  @@index([contractorId])
  @@index([status])
  @@index([status, createdAt])
}

model Milestone {
  id          String          @id @default(uuid())
  contractId  String
  name        String
  description String?
  amount      Decimal
  status      MilestoneStatus @default(PENDING)
  dependsOnId String?
  completedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?
  approvedBy  String?

  contract            ContractAgreement @relation(fields: [contractId], references: [id], onDelete: Cascade)
  dependsOn           Milestone?        @relation("MilestoneDependency", fields: [dependsOnId], references: [id])
  dependentMilestones Milestone[]       @relation("MilestoneDependency")
  evidence            Evidence[]
  payouts             Payout[] // Payouts from this milestone
  lienWaivers         LienWaiver[] // Lien waivers for this milestone
  fileUploads         FileUpload[] // File uploads associated with this milestone

  // Spatial & Financing relations (Backend Consolidation v10)
  spatialVerifications SpatialVerification[]
  approvals            MilestoneApproval[]

  @@index([contractId])
  @@index([status])
  @@index([dependsOnId])
  // ── Performance: Compound indexes for milestone dashboards ──
  @@index([contractId, status]) // Contract detail: milestones by status
}

model Evidence {
  id           String   @id @default(uuid())
  milestoneId  String
  type         String
  fileUrl      String
  caption      String?
  uploadedById String
  uploadedAt   DateTime @default(now())

  milestone  Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  uploadedBy User      @relation("EvidenceUploader", fields: [uploadedById], references: [id])

  @@index([milestoneId])
  @@index([uploadedById])
}

// ============================================================================
// ESCROW SYSTEM (Stage 5 - Finance & Trust)
// ============================================================================

model EscrowAgreement {
  id                  String @id @default(uuid())
  contractId          String @unique
  projectId           String
  escrowAccountNumber String @unique // Auto-generated: ESC-YYYYMMDD-XXXX

  // Financial Fields
  totalContractAmount  Decimal @db.Decimal(18, 2) // From contract
  initialDepositAmount Decimal @db.Decimal(18, 2) // Calculated percentage
  holdbackPercentage   Int     @default(10) // Default 10%
  currentBalance       Decimal @default(0) @db.Decimal(18, 2) // Current total in escrow
  availableBalance     Decimal @default(0) @db.Decimal(18, 2) // Current - holds
  heldBalance          Decimal @default(0) @db.Decimal(18, 2) // Sum of active holds
  currency             String  @default("USD") // Currency code

  // Interest Tracking (for interest-bearing escrows)
  interestRate    Decimal? @db.Decimal(5, 4) // e.g., 0.0250 for 2.5%
  interestAccrued Decimal  @default(0) @db.Decimal(18, 2)

  // Status & Lifecycle
  status      EscrowStatus @default(PENDING_DEPOSIT)
  createdAt   DateTime     @default(now())
  activatedAt DateTime? // When first deposit made
  closedAt    DateTime? // When escrow closed
  updatedAt   DateTime     @updatedAt

  // Relationships
  contract        ContractAgreement   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  transactions    EscrowTransaction[]
  holds           EscrowHold[]
  disputes        Dispute[]
  depositRequests DepositRequest[]    @relation("EscrowDepositRequests")

  @@index([contractId])
  @@index([projectId])
  @@index([status])
  @@index([escrowAccountNumber])
  @@index([status, createdAt])
}

model EscrowTransaction {
  id             String  @id @default(uuid())
  escrowId       String // CORRECT FIELD NAME
  journalEntryId String? @unique // Link to accounting entry

  // Transaction Details
  type        EscrowTransactionType
  amount      Decimal               @db.Decimal(18, 2)
  currency    String                @default("USD")
  description String?               @db.Text

  // Balance Tracking
  balanceBefore Decimal @db.Decimal(18, 2)
  balanceAfter  Decimal @db.Decimal(18, 2)

  // Status & Processing
  status        EscrowTransactionStatus @default(PENDING)
  scheduledDate DateTime? // When transaction is scheduled
  processedDate DateTime? // When transaction completed

  // Payment & Reference
  reference       String? // Payment ID, Milestone ID, etc.
  stripePaymentId String? // Stripe payment reference

  // Audit Trail
  initiatedBy String // User ID who initiated
  approvedBy  String? // User ID who approved (if required)

  // Flexible Metadata
  metadata Json? // For flexible data storage

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  escrow       EscrowAgreement @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  journalEntry JournalEntry?   @relation(fields: [journalEntryId], references: [id])
  initiator    User            @relation("EscrowTransactionInitiator", fields: [initiatedBy], references: [id])
  approver     User?           @relation("EscrowTransactionApprover", fields: [approvedBy], references: [id])
  payout       Payout? // Reverse relation for payout
  lienWaivers  LienWaiver[] // Lien waivers generated for this transaction

  @@index([escrowId])
  @@index([status])
  @@index([type])
  @@index([processedDate])
  @@index([initiatedBy])
  @@index([reference])
  @@index([status, createdAt])
}

model EscrowHold {
  id       String @id @default(uuid())
  escrowId String // CORRECT FIELD NAME

  // Hold Details
  amount Decimal          @db.Decimal(18, 2)
  reason EscrowHoldReason
  status EscrowHoldStatus @default(ACTIVE)
  notes  String?          @db.Text

  // Lifecycle
  placedBy   String // User ID who placed hold
  releasedBy String? // User ID who released hold
  placedAt   DateTime  @default(now())
  releasedAt DateTime?
  expiresAt  DateTime? // Optional expiration date

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  escrow   EscrowAgreement @relation(fields: [escrowId], references: [id], onDelete: Cascade)
  placer   User            @relation("EscrowHoldPlacer", fields: [placedBy], references: [id])
  releaser User?           @relation("EscrowHoldReleaser", fields: [releasedBy], references: [id])

  @@index([escrowId])
  @@index([status])
  @@index([placedBy])
  @@index([placedAt])
}

// ============================================================================
// DOUBLE-ENTRY LEDGER SYSTEM (Stage 5 - Finance & Trust)
// ============================================================================

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountSubType {
  // Assets (1000-1999)
  CASH
  ESCROW_HOLDINGS
  ACCOUNTS_RECEIVABLE
  PREPAID_EXPENSES
  // Liabilities (2000-2999)
  ACCOUNTS_PAYABLE
  ESCROW_LIABILITIES
  PLATFORM_FEES_PAYABLE
  DEFERRED_REVENUE
  // Equity (3000-3999)
  RETAINED_EARNINGS
  OWNER_EQUITY
  // Revenue (4000-4999)
  PLATFORM_FEES
  TRANSACTION_FEES
  SUBSCRIPTION_REVENUE
  // Expenses (5000-5999)
  PROCESSING_FEES
  OPERATING_EXPENSES
  CONTRACTOR_PAYOUTS
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

model Account {
  id          String          @id @default(uuid())
  code        String          @unique // Auto-assigned: 1000-1999 Assets, 2000-2999 Liabilities, etc.
  name        String
  type        AccountType
  subType     AccountSubType?
  description String?
  parentId    String? // Account hierarchy support
  isActive    Boolean         @default(true) // Soft delete pattern
  balance     Decimal         @default(0) @db.Decimal(18, 4) // Current balance (precision: 18, scale: 4)
  currency    String          @default("USD") // Multi-currency support

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relationships
  parent         Account?           @relation("AccountHierarchy", fields: [parentId], references: [id])
  children       Account[]          @relation("AccountHierarchy")
  lines          JournalEntryLine[]
  periodBalances AccountBalance[]

  @@index([type])
  @@index([subType])
  @@index([isActive])
  @@index([code])
  @@index([parentId])
}

model JournalEntry {
  id          String             @id @default(uuid())
  entryNumber String             @unique // Auto-increment format: JE-2025-000001
  description String
  reference   String? // Reference type (e.g., "ESCROW_DEPOSIT", "MILESTONE_PAYMENT")
  referenceId String? // ID of source transaction
  entryDate   DateTime           @default(now())
  status      JournalEntryStatus @default(DRAFT)

  // Approval workflow for large transactions
  requiresApproval Boolean   @default(false) // Auto-set for entries > $10,000
  approvedBy       String? // User ID who approved
  approvedAt       DateTime?

  // Posting (immutable once POSTED)
  postedAt   DateTime? // When entry was posted (null = draft, immutable once set)
  postedBy   String? // User who posted the entry
  voidedAt   DateTime? // When entry was voided
  voidedBy   String? // User who voided
  voidReason String?

  // Audit trail
  createdAt DateTime @default(now())
  createdBy String
  updatedAt DateTime @updatedAt

  // Relationships
  lines             JournalEntryLine[]
  escrowTransaction EscrowTransaction? // Reverse relation for 1:1

  @@index([entryDate])
  @@index([status])
  @@index([postedAt])
  @@index([reference, referenceId])
  @@index([requiresApproval])
  @@index([entryNumber])
}

model JournalEntryLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String
  lineOrder      Int     @default(0) // Line ordering within entry
  debit          Decimal @default(0) @db.Decimal(18, 4)
  credit         Decimal @default(0) @db.Decimal(18, 4)
  description    String?

  // Audit trail
  createdAt DateTime @default(now())

  // Relationships
  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@index([lineOrder])
}

// Period-based account balances for reconciliation
model AccountBalance {
  id           String @id @default(uuid())
  accountId    String
  fiscalYear   Int // e.g., 2025
  fiscalPeriod Int // 1-12 for months, or custom period

  // Balances
  openingBalance Decimal @default(0) @db.Decimal(18, 4)
  closingBalance Decimal @default(0) @db.Decimal(18, 4)
  debitTotal     Decimal @default(0) @db.Decimal(18, 4) // Sum of debits in period
  creditTotal    Decimal @default(0) @db.Decimal(18, 4) // Sum of credits in period

  // Reconciliation
  isReconciled        Boolean   @default(false)
  reconciledAt        DateTime?
  reconciledBy        String?
  reconciliationNotes String?

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, fiscalYear, fiscalPeriod])
  @@index([accountId])
  @@index([fiscalYear, fiscalPeriod])
  @@index([isReconciled])
}

// ============================================================================
// STRIPE CONNECT (Stage 5 - Finance & Trust - Contractor Payouts)
// ============================================================================

enum ConnectedAccountType {
  STANDARD
  EXPRESS
}

enum ConnectedAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DISABLED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum PayoutMethod {
  STANDARD // Next business day, no fee
  INSTANT // Within 30 minutes, 1% fee (max $10)
}

model ConnectedAccount {
  id     String @id @default(uuid())
  userId String @unique // Contractor user ID

  // Stripe Account Details
  stripeAccountId String                 @unique
  accountType     ConnectedAccountType
  status          ConnectedAccountStatus @default(PENDING)

  // Account Configuration
  country  String
  currency String @default("USD")
  email    String

  // Onboarding Status
  hasCompletedOnboarding Boolean   @default(false)
  onboardingLink         String? // Last generated onboarding link
  onboardingLinkExpires  DateTime?

  // Capabilities
  payoutsEnabled Boolean @default(false)
  chargesEnabled Boolean @default(false)

  // Requirements from Stripe
  requirements Json? // Store currently_due, eventually_due, past_due, disabled_reason

  // Platform Fee Configuration
  platformFeePercentage Decimal @default(0) @db.Decimal(5, 2) // e.g., 2.50 for 2.5%

  // Tax Information
  taxFormStatus     String? // W9_COLLECTED, W8BEN_COLLECTED, PENDING
  taxClassification String? // INDIVIDUAL, C_CORP, S_CORP, PARTNERSHIP, LLC, etc.
  taxId             String? // TIN/EIN (encrypted)

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user    User     @relation("ConnectedAccountUser", fields: [userId], references: [id], onDelete: Cascade)
  payouts Payout[]

  @@index([userId])
  @@index([stripeAccountId])
  @@index([status])
  @@index([hasCompletedOnboarding])
}

model Payout {
  id                  String  @id @default(uuid())
  connectedAccountId  String
  escrowTransactionId String? @unique // Link to escrow transaction if from escrow release (1:1)
  milestoneId         String? // Link to milestone if milestone payment

  // Payout Details
  amount           Decimal @db.Decimal(18, 2)
  currency         String  @default("USD")
  stripePayoutId   String? @unique
  stripeTransferId String? // Transfer ID if using Stripe Transfers

  // Status & Processing
  status      PayoutStatus @default(PENDING)
  method      PayoutMethod @default(STANDARD)
  arrivalDate DateTime? // Expected/actual arrival date
  processedAt DateTime? // When payout was processed
  failedAt    DateTime? // When payout failed

  // Failure Information
  failureCode    String?
  failureMessage String?

  // Fee Information
  platformFee      Decimal @default(0) @db.Decimal(18, 2)
  stripeFee        Decimal @default(0) @db.Decimal(18, 2)
  instantPayoutFee Decimal @default(0) @db.Decimal(18, 2) // 1% for instant payouts

  // Audit Trail
  initiatedBy String // User who initiated payout
  approvedBy  String? // User who approved (if manual approval required)

  // Metadata
  metadata Json? // For flexible data (milestone details, etc.)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  connectedAccount  ConnectedAccount   @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  escrowTransaction EscrowTransaction? @relation(fields: [escrowTransactionId], references: [id])
  milestone         Milestone?         @relation(fields: [milestoneId], references: [id])
  initiator         User               @relation("PayoutInitiator", fields: [initiatedBy], references: [id])
  approver          User?              @relation("PayoutApprover", fields: [approvedBy], references: [id])

  @@index([connectedAccountId])
  @@index([status])
  @@index([stripePayoutId])
  @@index([escrowTransactionId])
  @@index([milestoneId])
  @@index([initiatedBy])
  @@index([arrivalDate])
  @@index([status, createdAt])
}

// ============================================================================
// DISPUTE RESOLUTION SYSTEM (Stage 5 - Finance & Trust)
// ============================================================================

model Dispute {
  id            String @id @default(uuid())
  disputeNumber String @unique // Auto-generated: DISP-YYYYMMDD-XXXX

  // Linked Entities
  escrowAgreementId String
  contractId        String
  projectId         String

  // Parties
  initiatedBy  String // User ID who filed dispute
  respondentId String // User ID of other party
  mediatorId   String? // Assigned mediator user ID

  // Dispute Details
  type           DisputeType
  status         DisputeStatus @default(OPEN)
  disputedAmount Decimal       @db.Decimal(18, 2) // Amount in dispute
  frozenAmount   Decimal       @default(0) @db.Decimal(18, 2) // Amount actually frozen

  // Description & Resolution
  title       String // Brief title
  description String  @db.Text // Detailed description
  resolution  String? @db.Text // Final resolution text

  // Timestamps & Deadlines
  createdAt         DateTime  @default(now())
  evidenceDeadline  DateTime? // Deadline for evidence submission
  mediationDeadline DateTime? // Deadline for mediation
  resolvedAt        DateTime? // When resolution was decided
  closedAt          DateTime? // When dispute was fully closed
  updatedAt         DateTime  @updatedAt

  // Metadata
  metadata Json? // Flexible data storage

  // Relationships
  escrowAgreement EscrowAgreement     @relation(fields: [escrowAgreementId], references: [id], onDelete: Cascade)
  contract        ContractAgreement   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  initiator       User                @relation("DisputeInitiator", fields: [initiatedBy], references: [id])
  respondent      User                @relation("DisputeRespondent", fields: [respondentId], references: [id])
  mediator        User?               @relation("DisputeMediator", fields: [mediatorId], references: [id])
  evidence        DisputeEvidence[]
  messages        DisputeMessage[]
  resolutions     DisputeResolution[]

  @@index([escrowAgreementId])
  @@index([contractId])
  @@index([projectId])
  @@index([status])
  @@index([initiatedBy])
  @@index([respondentId])
  @@index([mediatorId])
  @@index([disputeNumber])
  @@index([createdAt])
}

model DisputeEvidence {
  id          String @id @default(uuid())
  disputeId   String
  submittedBy String // User ID

  // Evidence Details
  evidenceType DisputeEvidenceType
  fileUrl      String // S3 or storage URL
  fileName     String
  fileSize     Int // Size in bytes
  mimeType     String? // e.g., application/pdf, image/jpeg

  // Description & Review
  description String?   @db.Text
  uploadedAt  DateTime  @default(now())
  isReviewed  Boolean   @default(false)
  reviewedBy  String? // Mediator user ID who reviewed
  reviewedAt  DateTime?

  // Metadata
  metadata Json?

  // Relationships
  dispute   Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submitter User    @relation("DisputeEvidenceSubmitter", fields: [submittedBy], references: [id])
  reviewer  User?   @relation("DisputeEvidenceReviewer", fields: [reviewedBy], references: [id])

  @@index([disputeId])
  @@index([submittedBy])
  @@index([uploadedAt])
}

model DisputeMessage {
  id        String @id @default(uuid())
  disputeId String
  senderId  String // User ID

  // Message Content
  message    String  @db.Text
  isInternal Boolean @default(false) // Visible only to mediators/admins

  // Read Tracking
  readBy Json? // Array of user IDs who have read this message

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  dispute Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender  User    @relation("DisputeMessageSender", fields: [senderId], references: [id])

  @@index([disputeId])
  @@index([senderId])
  @@index([createdAt])
}

model DisputeResolution {
  id         String @id @default(uuid())
  disputeId  String
  mediatorId String // User ID of mediator

  // Resolution Details
  resolutionType   DisputeResolutionType
  ownerAmount      Decimal               @default(0) @db.Decimal(18, 2) // Amount awarded to owner
  contractorAmount Decimal               @default(0) @db.Decimal(18, 2) // Amount awarded to contractor
  refundAmount     Decimal               @default(0) @db.Decimal(18, 2) // Amount refunded

  // Reasoning & Decision
  reasoning String   @db.Text
  decidedAt DateTime @default(now())

  // Appeal Process
  appealDeadline DateTime // 7 days after decision
  appealStatus   DisputeAppealStatus @default(NONE)
  appealReason   String?             @db.Text
  appealedAt     DateTime?
  appealedBy     String? // User ID who filed appeal

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  dispute  Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  mediator User    @relation("DisputeResolutionMediator", fields: [mediatorId], references: [id])
  appealer User?   @relation("DisputeResolutionAppealer", fields: [appealedBy], references: [id])

  @@index([disputeId])
  @@index([mediatorId])
  @@index([decidedAt])
  @@index([appealStatus])
}

model LienWaiver {
  id                  String  @id @default(uuid())
  paymentReleaseId    String? // Link to payment release/escrow transaction
  escrowTransactionId String? // Direct link to escrow transaction
  contractId          String
  projectId           String
  milestoneId         String? // Link to milestone if applicable

  // Waiver Classification
  waiverType  LienWaiverType
  waiverScope LienWaiverScope
  status      LienWaiverStatus @default(GENERATED)

  // Project Information
  projectName    String
  projectAddress String @db.Text
  state          String // US State code for form selection

  // Claimant Information (Contractor/Sub/Supplier)
  claimantName    String
  claimantAddress String  @db.Text
  claimantEmail   String?
  claimantPhone   String?

  // Owner Information
  ownerName    String
  ownerAddress String? @db.Text

  // Payment Details
  throughDate      DateTime // Payment period end date
  waiverAmount     Decimal  @db.Decimal(18, 2) // Amount covered by this waiver
  cumulativeAmount Decimal  @db.Decimal(18, 2) // Total amount to date

  // Documents
  documentUrl       String? // Generated waiver PDF URL
  signedDocumentUrl String? // Signed waiver PDF URL
  templateUsed      String? // Template identifier used

  // Timestamps
  generatedAt DateTime  @default(now())
  sentAt      DateTime? // When sent for signature
  signedAt    DateTime? // When signed
  expiresAt   DateTime? // For conditional waivers
  recordedAt  DateTime? // When officially recorded

  // Metadata
  metadata Json? // Additional clauses, notary info, etc.

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String // User ID who generated

  // Relationships
  contract          ContractAgreement     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  project           Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  escrowTransaction EscrowTransaction?    @relation(fields: [escrowTransactionId], references: [id])
  milestone         Milestone?            @relation(fields: [milestoneId], references: [id])
  creator           User                  @relation("LienWaiverCreator", fields: [createdBy], references: [id])
  signatures        LienWaiverSignature[]

  @@index([contractId])
  @@index([projectId])
  @@index([status])
  @@index([escrowTransactionId])
  @@index([milestoneId])
  @@index([generatedAt])
  @@index([state])
}

model LienWaiverSignature {
  id           String @id @default(uuid())
  lienWaiverId String
  signerId     String // User ID

  // Signer Information
  signerRole    LienWaiverSignerRole
  signerName    String
  signerTitle   String?
  signerCompany String?
  signerEmail   String

  // Digital Signature
  signatureImageUrl String? // URL to signature image
  ipAddress         String? // IP address when signed
  userAgent         String? // Browser/device info

  // Electronic Consent
  electronicConsentGiven Boolean   @default(false)
  consentTimestamp       DateTime?

  // Notarization (for states requiring it)
  isNotarized      Boolean   @default(false)
  notaryName       String?
  notaryCommission String?
  notaryExpiration DateTime?
  notarySeal       String? // URL to notary seal image

  // Third-party E-Signature Integration
  docusignEnvelopeId String? // DocuSign envelope ID
  docusignStatus     String? // DocuSign status
  hellosignRequestId String? // HelloSign request ID

  // Timestamps
  signedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  lienWaiver LienWaiver @relation(fields: [lienWaiverId], references: [id], onDelete: Cascade)
  signer     User       @relation("LienWaiverSigner", fields: [signerId], references: [id])

  @@index([lienWaiverId])
  @@index([signerId])
  @@index([signedAt])
}

// ============================================================================
// STATEMENT GENERATION & COMPLIANCE (Stage 5 - Finance & Trust - Reporting)
// ============================================================================

enum StatementType {
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

enum StatementStatus {
  GENERATED // Created but not sent
  SENT // Sent to recipient
  VIEWED // Opened by recipient
  ARCHIVED // Archived after retention period
}

enum RecipientRole {
  OWNER
  CONTRACTOR
  ADMIN
  FINANCE
}

enum DeliveryMethod {
  EMAIL
  DOWNLOAD
  BOTH
}

enum ComplianceReportType {
  SAR // Suspicious Activity Report
  CTR // Currency Transaction Report
  FORM_1099_NEC
  FORM_1099_K
  FORM_1099_MISC
}

enum ComplianceReportStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  FILED
  REJECTED
}

model Statement {
  id            String        @id @default(uuid())
  statementType StatementType
  recipientId   String // User ID
  recipientRole RecipientRole

  // Period Coverage
  periodStart DateTime
  periodEnd   DateTime

  // Content
  documentUrl String? // URL to generated PDF
  status      StatementStatus @default(GENERATED)

  // Financial Summary (stored in metadata)
  openingBalance   Decimal @db.Decimal(18, 2)
  closingBalance   Decimal @db.Decimal(18, 2)
  totalDeposits    Decimal @db.Decimal(18, 2)
  totalReleases    Decimal @db.Decimal(18, 2)
  totalFees        Decimal @db.Decimal(18, 2)
  transactionCount Int     @default(0)

  // Metadata
  metadata Json? // Transaction details, charts data, etc.

  // Timestamps
  generatedAt DateTime  @default(now())
  sentAt      DateTime?
  viewedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relationships
  recipient User @relation("StatementRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([statementType])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([generatedAt])
}

model StatementSchedule {
  id            String        @id @default(uuid())
  recipientId   String // User ID
  statementType StatementType
  frequency     String        @default("MONTHLY") // MONTHLY, QUARTERLY, ANNUAL

  // Schedule Configuration
  dayOfMonth     Int            @default(1) // Day of month to generate (1-31)
  isActive       Boolean        @default(true)
  deliveryMethod DeliveryMethod @default(EMAIL)

  // Tracking
  lastGenerated DateTime?
  nextScheduled DateTime?

  // Metadata
  metadata Json? // Additional configuration

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  recipient User @relation("StatementScheduleRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId])
  @@index([isActive])
  @@index([nextScheduled])
}

model ComplianceReport {
  id         String                 @id @default(uuid())
  reportType ComplianceReportType
  status     ComplianceReportStatus @default(DRAFT)

  // Report Details
  title       String
  description String? @db.Text

  // Period Coverage
  periodStart DateTime?
  periodEnd   DateTime?

  // Filing Information
  filedWith    String? // FinCEN, IRS, etc.
  filingNumber String? // Reference number from filing
  filedAt      DateTime?

  // Related Entities
  relatedUserId        String? // User involved
  relatedTransactionId String? // Transaction involved
  relatedEscrowId      String? // Escrow account involved

  // Document
  documentUrl String? // URL to generated report

  // Review & Approval
  reviewedBy String? // User ID of reviewer
  reviewedAt DateTime?
  approvedBy String? // User ID of approver
  approvedAt DateTime?

  // Metadata
  metadata Json? // Report-specific data (SAR details, 1099 data, etc.)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  relatedUser User? @relation("ComplianceReportUser", fields: [relatedUserId], references: [id])
  reviewer    User? @relation("ComplianceReportReviewer", fields: [reviewedBy], references: [id])
  approver    User? @relation("ComplianceReportApprover", fields: [approvedBy], references: [id])

  @@index([reportType])
  @@index([status])
  @@index([relatedUserId])
  @@index([periodStart, periodEnd])
  @@index([filedAt])
}

// ============================================================================
// ADVANCED ANALYTICS & PREDICTIVE MODELS (Stage 5 - Finance & Trust)
// ============================================================================

enum SnapshotType {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum KPIType {
  FINANCIAL // Revenue, profit, cash flow
  OPERATIONAL // Transaction success rate, processing time
  CUSTOMER // Churn rate, NPS, LTV
  COMPLIANCE // Dispute rate, fraud rate
}

enum TrendDirection {
  UP
  DOWN
  FLAT
}

enum CalculationFrequency {
  REALTIME // Calculate on every request
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum RiskLevel {
  VERY_LOW // 0-20
  LOW // 21-40
  MEDIUM // 41-60
  HIGH // 61-80
  VERY_HIGH // 81-100
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  EMERGENCY
}

model AnalyticsSnapshot {
  id           String       @id @default(uuid())
  snapshotDate DateTime     @default(now())
  snapshotType SnapshotType

  // Calculated Metrics (stored as JSON for flexibility)
  metrics Json // All calculated metrics for this period

  // Trend Indicators
  trends Json? // Trend analysis results

  // Forecasts & Predictions
  forecasts Json? // Predictive analytics results

  // Metadata
  calculationTime Int? // Time taken to calculate (ms)
  dataPoints      Int? // Number of records analyzed

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([snapshotDate])
  @@index([snapshotType])
  @@index([createdAt])
}

model KPI {
  id   String  @id @default(uuid())
  name String  @unique // Unique identifier (e.g., "monthly_revenue")
  type KPIType

  // Display Information
  displayName String // Human-readable name
  description String? @db.Text
  unit        String? // e.g., "USD", "count", "percent"
  category    String? // Grouping category

  // Current State
  currentValue Decimal  @db.Decimal(18, 2)
  targetValue  Decimal? @db.Decimal(18, 2)
  threshold    Decimal? @db.Decimal(18, 2) // Alert threshold

  // Trend Analysis
  trendDirection TrendDirection
  changePercent  Decimal?       @db.Decimal(8, 2) // % change vs. previous period
  previousValue  Decimal?       @db.Decimal(18, 2)
  isHealthy      Boolean        @default(true) // Is KPI within acceptable range?

  // Calculation Settings
  calculationFrequency CalculationFrequency @default(DAILY)
  lastCalculated       DateTime             @default(now())
  nextCalculation      DateTime?

  // Alert Configuration
  alertEnabled   Boolean   @default(false)
  alertThreshold Decimal?  @db.Decimal(18, 2)
  lastAlertSent  DateTime?

  // Metadata
  metadata Json? // Additional configuration

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([type])
  @@index([lastCalculated])
  @@index([isHealthy])
}

model FraudScore {
  id            String  @id @default(uuid())
  transactionId String? // EscrowTransaction ID
  userId        String? // User being scored
  entityType    String // "transaction", "user", "payout"
  entityId      String // ID of the entity

  // Fraud Scoring
  score      Int       @default(0) // 0-100 (100 = highest fraud risk)
  riskLevel  RiskLevel @default(VERY_LOW)
  confidence Decimal   @db.Decimal(5, 2) // Confidence level 0-100%

  // Features Used (for ML model)
  features Json // Input features used for scoring

  // Detection Details
  flaggedReasons       String[] // Array of reasons
  manualReviewRequired Boolean   @default(false)
  reviewedBy           String? // User ID of reviewer
  reviewedAt           DateTime?
  isFraud              Boolean? // Final determination

  // Actions Taken
  actionsTaken String[] // e.g., ["transaction_held", "user_notified"]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user     User? @relation("FraudScoreUser", fields: [userId], references: [id])
  reviewer User? @relation("FraudScoreReviewer", fields: [reviewedBy], references: [id])

  @@index([score])
  @@index([riskLevel])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([manualReviewRequired])
  @@index([createdAt])
}

model ChurnPrediction {
  id     String @id @default(uuid())
  userId String @unique // Contractor being scored

  // Churn Prediction
  churnScore       Int       @default(0) // 0-100 (100 = highest churn risk)
  riskLevel        RiskLevel @default(VERY_LOW)
  confidence       Decimal   @db.Decimal(5, 2)
  churnProbability Decimal   @db.Decimal(5, 2) // 0-100%

  // Risk Factors
  riskFactors Json // Array of contributing factors

  // Features Used
  features Json // Input features: transaction frequency, disputes, etc.

  // Recommendations
  retentionActions String[] // Recommended actions
  priorityLevel    String   @default("low") // low, medium, high, critical

  // Tracking
  lastEngagement    DateTime? // Last transaction or activity
  daysSinceActivity Int? // Days since last activity

  // Review & Action
  reviewedBy   String? // User ID
  reviewedAt   DateTime?
  actionsToken String[] // Actions taken

  // Prediction Outcome (to track model accuracy)
  actuallyChurned Boolean? // Did they actually churn?
  churnedAt       DateTime?

  // Timestamps
  calculatedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  user     User  @relation("ChurnPredictionUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ChurnPredictionReviewer", fields: [reviewedBy], references: [id])

  @@index([churnScore])
  @@index([riskLevel])
  @@index([calculatedAt])
}

model AnalyticsAlert {
  id          String        @id @default(uuid())
  alertType   String // "kpi_threshold", "fraud_detected", "churn_risk", etc.
  severity    AlertSeverity @default(INFO)
  title       String
  description String        @db.Text

  // Related Entities
  relatedKPIId      String? // KPI that triggered alert
  relatedUserId     String? // User involved
  relatedEntityType String? // "transaction", "escrow", "user"
  relatedEntityId   String? // ID of entity

  // Alert Data
  data Json? // Additional alert data

  // Status
  isResolved Boolean   @default(false)
  resolvedBy String? // User ID
  resolvedAt DateTime?
  resolution String?   @db.Text

  // Notification
  notificationSent Boolean   @default(false)
  sentAt           DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  relatedUser User? @relation("AnalyticsAlertUser", fields: [relatedUserId], references: [id])
  resolver    User? @relation("AnalyticsAlertResolver", fields: [resolvedBy], references: [id])

  @@index([alertType])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
}

model CustomReport {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  createdBy   String // User ID

  // Report Configuration
  metrics       String[] // List of metrics to include
  filters       Json // Filter configuration
  groupBy       String[] // Grouping dimensions
  visualization String   @default("table") // table, line, bar, pie

  // Schedule
  isScheduled        Boolean   @default(false)
  scheduleFrequency  String? // "daily", "weekly", "monthly"
  scheduleDayOfWeek  Int? // 0-6 for weekly
  scheduleDayOfMonth Int? // 1-31 for monthly
  lastGenerated      DateTime?
  nextScheduled      DateTime?

  // Sharing
  isPublic   Boolean  @default(false)
  sharedWith String[] // Array of user IDs

  // Metadata
  metadata Json? // Additional configuration

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  creator User @relation("CustomReportCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([isScheduled])
  @@index([nextScheduled])
}

// ============================================================================
// REGULATORY COMPLIANCE MONITORING (Stage 5 - Finance & Trust)
// ============================================================================

enum RuleType {
  STATE_ESCROW // State-specific escrow requirements
  AML // Anti-Money Laundering
  KYC // Know Your Customer
  LICENSING // Contractor licensing
  INSURANCE // Insurance requirements
  BOND // Surety bond requirements
  LIEN_LAW // State lien law compliance
  TAX // Tax compliance
}

enum ComplianceSeverity {
  LOW // Minor issue, informational
  MEDIUM // Should be addressed
  HIGH // Must be addressed soon
  CRITICAL // Blocking issue, immediate action required
}

enum CheckStatus {
  PASS // Compliance check passed
  FAIL // Compliance check failed
  PENDING // Check in progress
  WAIVED // Check waived by admin
  EXPIRED // Check result expired
}

enum LicenseStatus {
  ACTIVE // License is current and valid
  EXPIRED // License has expired
  SUSPENDED // License temporarily suspended
  REVOKED // License permanently revoked
  PENDING // Application pending
}

enum InsuranceStatus {
  ACTIVE // Insurance is current
  EXPIRED // Insurance has expired
  CANCELLED // Insurance cancelled
  PENDING // Certificate pending verification
}

enum RemediationStatus {
  OPEN // Issue identified, not addressed
  IN_PROGRESS // Working on remediation
  RESOLVED // Issue resolved
  ESCALATED // Escalated to management
}

model ComplianceRule {
  id   String   @id @default(uuid())
  name String // Unique rule name
  type RuleType

  // Jurisdiction
  jurisdiction String  @default("US") // Country
  state        String? // State code (for US)
  county       String? // County (if applicable)

  // Rule Details
  description  String  @db.Text
  requirements Json // Detailed requirements (JSONB)
  citations    String? @db.Text // Legal citations

  // Validity
  effectiveDate  DateTime
  expirationDate DateTime?
  isActive       Boolean            @default(true)
  severity       ComplianceSeverity @default(MEDIUM)

  // Thresholds (if applicable)
  thresholdAmount     Decimal? @db.Decimal(18, 2) // Dollar amount threshold
  thresholdDays       Int? // Days threshold
  thresholdPercentage Decimal? @db.Decimal(5, 2) // Percentage threshold

  // Metadata
  metadata Json? // Additional rule configuration

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  checks ComplianceCheck[] @relation("ComplianceRuleChecks")

  @@index([type])
  @@index([jurisdiction, state])
  @@index([isActive])
  @@index([effectiveDate, expirationDate])
}

model ComplianceCheck {
  id        String @id @default(uuid())
  ruleId    String
  checkType String // "pre_contract", "pre_payment", "daily_monitoring", "manual"

  // Entity Being Checked
  userId     String? // User being checked
  contractId String? // Contract being checked
  escrowId   String? // Escrow account being checked
  entityType String? // Generic entity type
  entityId   String? // Generic entity ID

  // Check Result
  status        CheckStatus @default(PENDING)
  checkDate     DateTime    @default(now())
  expiresAt     DateTime? // When check result expires
  passedChecks  String[] // List of checks that passed
  failedChecks  String[] // List of checks that failed
  failureReason String?     @db.Text

  // Remediation
  remediation        Json? // Remediation steps and tracking
  remediationStatus  RemediationStatus?
  remediationDueDate DateTime?

  // Performed By
  performedBy String? // "system" or user ID
  isAutomated Boolean @default(true)

  // Metadata
  metadata Json? // Additional check data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  rule      ComplianceRule     @relation("ComplianceRuleChecks", fields: [ruleId], references: [id])
  user      User?              @relation("ComplianceCheckUser", fields: [userId], references: [id])
  contract  ContractAgreement? @relation("ComplianceCheckContract", fields: [contractId], references: [id])
  performer User?              @relation("ComplianceCheckPerformer", fields: [performedBy], references: [id])

  @@index([ruleId])
  @@index([userId])
  @@index([contractId])
  @@index([status])
  @@index([checkDate])
  @@index([expiresAt])
}

model LicenseTracking {
  id     String @id @default(uuid())
  userId String // Contractor ID

  // License Details
  licenseType      String // "general_contractor", "electrical", "plumbing", etc.
  licenseNumber    String
  issuingAuthority String // "California CSLB", "Texas TDLR", etc.
  state            String // State code
  county           String? // County (if applicable)

  // License Information
  issueDate       DateTime
  expirationDate  DateTime
  status          LicenseStatus @default(ACTIVE)
  classifications String[] // License classifications/specialties

  // Document
  documentUrl String? // URL to license document
  verifiedAt  DateTime? // When license was verified
  verifiedBy  String? // User ID who verified

  // Validation
  lastChecked        DateTime? // Last time we checked with state board
  nextCheck          DateTime? // Next scheduled check
  autoVerified       Boolean   @default(false) // Verified via API
  verificationSource String? // "manual", "state_api", "third_party"

  // Alerts
  expirationAlertSent Boolean   @default(false)
  alertSentAt         DateTime?

  // Metadata
  metadata Json? // Additional license data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  contractor User @relation("ContractorLicenses", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([licenseNumber])
  @@index([state])
  @@index([status])
  @@index([expirationDate])
  @@index([nextCheck])
}

model InsuranceCertificate {
  id     String @id @default(uuid())
  userId String // Contractor ID

  // Insurance Details
  insuranceType String // "general_liability", "workers_comp", "professional_liability"
  carrier       String // Insurance company name
  policyNumber  String

  // Coverage
  coverageAmount Decimal  @db.Decimal(18, 2)
  deductible     Decimal? @db.Decimal(18, 2)
  perOccurrence  Decimal? @db.Decimal(18, 2) // Per occurrence limit
  aggregate      Decimal? @db.Decimal(18, 2) // Aggregate limit

  // Validity
  effectiveDate  DateTime
  expirationDate DateTime
  status         InsuranceStatus @default(ACTIVE)

  // Additional Insured
  additionalInsureds String[] // List of additional insureds

  // Document
  documentUrl String? // URL to certificate
  verifiedAt  DateTime? // When certificate was verified
  verifiedBy  String? // User ID who verified

  // Alerts
  expirationAlertSent Boolean   @default(false)
  alertSentAt         DateTime?

  // Metadata
  metadata Json? // Additional insurance data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  contractor User @relation("ContractorInsurance", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([policyNumber])
  @@index([status])
  @@index([expirationDate])
  @@index([insuranceType])
}

model BondTracking {
  id         String  @id @default(uuid())
  userId     String // Contractor ID
  contractId String? // Specific contract (if project-specific bond)

  // Bond Details
  bondType      String // "license_bond", "contract_bond", "payment_bond", "performance_bond"
  bondNumber    String
  suretyCompany String
  bondAmount    Decimal @db.Decimal(18, 2)

  // Validity
  effectiveDate  DateTime
  expirationDate DateTime?
  status         String    @default("ACTIVE") // ACTIVE, EXPIRED, CLAIMED, RELEASED

  // Obligee
  obligee String? // Who is protected by the bond

  // Document
  documentUrl String? // URL to bond document
  verifiedAt  DateTime?
  verifiedBy  String?

  // Claims
  hasClaims   Boolean  @default(false)
  claimAmount Decimal? @db.Decimal(18, 2)
  claimNotes  String?  @db.Text

  // Alerts
  expirationAlertSent Boolean   @default(false)
  alertSentAt         DateTime?

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  contractor User               @relation("ContractorBonds", fields: [userId], references: [id], onDelete: Cascade)
  contract   ContractAgreement? @relation("ContractBonds", fields: [contractId], references: [id])

  @@index([userId])
  @@index([contractId])
  @@index([bondNumber])
  @@index([status])
  @@index([expirationDate])
}

model ComplianceAlert {
  id        String @id @default(uuid())
  alertType String // "license_expiring", "insurance_lapsing", "bond_insufficient", etc.

  // Related Entities
  userId     String? // User involved
  contractId String? // Contract involved
  entityType String? // "license", "insurance", "bond", "check"
  entityId   String? // ID of entity

  // Alert Details
  title       String
  description String             @db.Text
  severity    ComplianceSeverity @default(MEDIUM)
  dueDate     DateTime? // When action must be taken

  // Status
  status           RemediationStatus @default(OPEN)
  resolvedBy       String? // User ID
  resolvedAt       DateTime?
  resolution       String?           @db.Text
  remediationSteps String[] // Steps taken

  // Notification
  notificationSent Boolean   @default(false)
  sentAt           DateTime?
  recipients       String[] // User IDs notified
  escalated        Boolean   @default(false)
  escalatedAt      DateTime?

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user     User?              @relation("ComplianceAlertUser", fields: [userId], references: [id])
  contract ContractAgreement? @relation("ComplianceAlertContract", fields: [contractId], references: [id])
  resolver User?              @relation("ComplianceAlertResolver", fields: [resolvedBy], references: [id])

  @@index([alertType])
  @@index([userId])
  @@index([contractId])
  @@index([severity])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

// ============================================================================
// AUDIT LOGGING & REPORTING (Stage 5 - Finance & Trust)
// ============================================================================

enum AuditEntityType {
  USER
  CONTRACT
  ESCROW
  TRANSACTION
  PAYMENT
  MILESTONE
  PROJECT
  PAYOUT
  DISPUTE
  LICENSE
  INSURANCE
  BOND
  COMPLIANCE_CHECK
  JOURNAL_ENTRY
  ACCOUNT
  STATEMENT
  REPORT
  BID
  CHANGE_ORDER
  SCHEDULE_ITEM
  QA_ISSUE
  SUBSCRIPTION
  ROLE
  INVITATION
  SESSION
  DATA_EXPORT
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  APPROVE
  REJECT
  VOID
  REVERSE
  EXPORT
  DOWNLOAD
  PRINT
  SEND
  SIGN
  LOGIN
  LOGOUT
  ACCESS
  ESCALATE
}

enum AuditCategory {
  FINANCIAL // Monetary transactions, journal entries
  OPERATIONAL // Day-to-day operations
  SECURITY // Authentication, authorization, access
  COMPLIANCE // Regulatory compliance actions
  ADMINISTRATIVE // System administration
}

enum AuditSeverity {
  INFO // Informational, routine operations
  WARNING // Unusual but not problematic
  CRITICAL // Requires attention, security concern
}

enum AuditFindingType {
  PASS // Audit check passed
  DISCREPANCY // Minor discrepancy found
  IRREGULARITY // Significant issue found
  FRAUD // Potential fraud detected
}

enum AccessAction {
  VIEW
  DOWNLOAD
  EXPORT
  PRINT
  SHARE
  DELETE
}

enum SensitivityLevel {
  PUBLIC // Public information
  INTERNAL // Internal use only
  CONFIDENTIAL // Confidential data
  RESTRICTED // Highly restricted (financial, PII)
}

model AuditLog {
  id         String          @id @default(uuid())
  entityType AuditEntityType
  entityId   String // ID of the entity
  action     AuditAction

  // User Context
  performedBy String // User ID
  performedAt DateTime @default(now())
  userEmail   String? // Denormalized for fast search
  userRole    String? // Role at time of action

  // Session Context
  ipAddress String?
  userAgent String? @db.Text
  sessionId String?
  location  String? // Geolocated location

  // Change Tracking
  beforeData   Json? // State before change
  afterData    Json? // State after change
  fieldChanges Json? // Specific field changes with reasons

  // Description
  changeDescription String? @db.Text
  description       String? @db.Text // Human-readable description
  businessReason    String? @db.Text // Why the change was made

  // Scope
  projectId      String? // Project scope
  organizationId String? // Organization scope

  // Tracing
  traceId String? // Links to OpenTelemetry distributed trace
  source  String? // Origin: 'api', 'command-center', 'webhook', 'cron', 'system'

  // Classification
  category AuditCategory
  severity AuditSeverity @default(INFO)

  // Metadata
  metadata Json? // Additional context

  // Immutability
  isImmutable Boolean @default(true) // Cannot be modified once created

  // Timestamps
  createdAt DateTime @default(now())

  // Relationships
  performer User @relation("AuditLogPerformer", fields: [performedBy], references: [id])

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([performedAt])
  @@index([action])
  @@index([category])
  @@index([severity])
  @@index([createdAt])
  @@index([projectId])
  @@index([organizationId])
  @@index([userEmail])
  @@index([traceId])
  @@index([source])
}

model FinancialAuditEntry {
  id             String  @id @default(uuid())
  journalEntryId String? // Journal entry being audited
  transactionId  String? // Transaction being audited
  escrowId       String? // Escrow account being audited

  // Audit Details
  auditType   String           @default("REVIEW") // CREATION, MODIFICATION, REVERSAL, RECONCILIATION, REVIEW
  auditorId   String // User ID performing audit
  auditDate   DateTime         @default(now())
  findingType AuditFindingType @default(PASS)

  // Findings
  notes         String? @db.Text
  discrepancies Json? // Detailed discrepancies found
  resolution    String? @db.Text
  actionTaken   String? // What action was taken

  // Verification (Dual Control)
  verifiedBy String? // Secondary auditor
  verifiedAt DateTime?
  isVerified Boolean   @default(false)

  // Amount Verification
  expectedAmount Decimal? @db.Decimal(18, 2)
  actualAmount   Decimal? @db.Decimal(18, 2)
  variance       Decimal? @db.Decimal(18, 2)

  // Compliance
  isCompliant Boolean  @default(true)
  violations  String[] // List of violations found

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  auditor  User  @relation("FinancialAuditAuditor", fields: [auditorId], references: [id])
  verifier User? @relation("FinancialAuditVerifier", fields: [verifiedBy], references: [id])

  @@index([journalEntryId])
  @@index([transactionId])
  @@index([escrowId])
  @@index([auditorId])
  @@index([auditDate])
  @@index([findingType])
  @@index([isVerified])
}

model AccessLog {
  id           String @id @default(uuid())
  userId       String
  resourceType String // "contract", "escrow", "transaction", "report", etc.
  resourceId   String // ID of resource

  // Action Details
  action     AccessAction
  accessedAt DateTime     @default(now())

  // Context
  ipAddress String?
  userAgent String? @db.Text
  location  String? // Geolocated location
  sessionId String?

  // Result
  success       Boolean @default(true)
  failureReason String? @db.Text

  // Security Classification
  sensitivityLevel SensitivityLevel @default(INTERNAL)

  // Data Scope (for exports/downloads)
  recordCount  Int? // Number of records accessed/exported
  dataSize     Int? // Size in bytes
  exportFormat String? // CSV, PDF, JSON, etc.

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())

  // Relationships
  user User @relation("AccessLogUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([accessedAt])
  @@index([action])
  @@index([sensitivityLevel])
  @@index([success])
}

model AuditReport {
  id          String  @id @default(uuid())
  reportType  String // SOC2, FINANCIAL, REGULATORY, SECURITY, CUSTOM
  title       String
  description String? @db.Text

  // Report Period
  periodStart DateTime
  periodEnd   DateTime

  // Generated By
  generatedBy String // User ID
  generatedAt DateTime @default(now())

  // Report Content
  summary         String   @db.Text
  findings        Json // Detailed findings
  metrics         Json // Key metrics
  recommendations String[] // Recommendations

  // Document
  documentUrl String? // URL to generated report PDF

  // Distribution
  sharedWith String[] // User IDs who can access
  isPublic   Boolean  @default(false)

  // Status
  status String @default("DRAFT") // DRAFT, FINAL, ARCHIVED

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  generator User @relation("AuditReportGenerator", fields: [generatedBy], references: [id])

  @@index([reportType])
  @@index([generatedBy])
  @@index([periodStart, periodEnd])
  @@index([generatedAt])
  @@index([status])
}

model DataRetentionPolicy {
  id            String @id @default(uuid())
  dataType      String @unique // "audit_log", "access_log", "financial_audit", etc.
  retentionDays Int // Days to retain in active storage

  // Archive Settings
  archiveEnabled   Boolean @default(true)
  archiveAfterDays Int // Days after which to archive
  archiveStorage   String  @default("s3_glacier") // Storage location

  // Deletion Settings
  deleteAfterDays Int // Days after which to permanently delete
  requireApproval Boolean @default(true)

  // Compliance
  regulatoryRequirement String? @db.Text
  legalHold             Boolean @default(false)

  // Status
  isActive Boolean @default(true)

  // Metadata
  metadata Json?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataType])
  @@index([isActive])
}

model Lead {
  id                 String     @id @default(uuid())
  projectId          String?
  category           String
  description        String
  estimatedValue     Decimal?
  budget             Decimal?
  location           String
  city               String?
  state              String?
  stage              LeadStatus @default(OPEN)
  status             String? // Alternative status field
  distributedTo      String[] // Array of profile IDs
  assignedSalesRepId String?
  lostAt             DateTime?
  lostReason         String?
  stageChangedAt     DateTime?
  srp                Decimal?

  // Marketplace pricing (set by estimating engine)
  suggestedPrice Decimal? @db.Decimal(12, 2)
  priceRange     Json? // { "low": number, "mid": number, "high": number }
  projectType    String? // "kitchen_renovation", "bathroom_remodel", etc.
  sqft           Decimal? @db.Decimal(10, 2)
  qualityTier    String? // "low", "mid", "high"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project?        @relation(fields: [projectId], references: [id])
  quotes         Quote[]
  quickEstimates QuickEstimate[]

  @@index([projectId])
  @@index([stage])
  @@index([status])
  // ── Performance: Compound indexes for marketplace queries ──
  @@index([stage, createdAt]) // Lead pipeline: filter by stage + sort by time
  @@index([status, createdAt]) // Lead listing with time-based pagination
}

model MarketplaceProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  businessName         String
  description          String?
  serviceArea          Json?
  specialties          String[]
  rating               Float?    @default(0)
  reviewCount          Int       @default(0)
  projectsCompleted    Int       @default(0)
  performanceScore     Int?
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  subscriptionTier     String?
  leadCredits          Int       @default(0)
  acceptingLeads       Boolean   @default(true)
  maxPipelineValue     Decimal?
  currentPipelineValue Decimal?  @default(0)
  lastWonAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user      User        @relation("MarketplaceProfileUser", fields: [userId], references: [id])
  portfolio Portfolio[]
  quotes    Quote[]

  @@index([verified])
  @@index([subscriptionTier])
  @@index([acceptingLeads])
}

model Portfolio {
  id          String    @id @default(uuid())
  profileId   String
  projectName String
  description String?
  category    String
  imageUrls   String[]
  completedAt DateTime?

  profile MarketplaceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Quote {
  id          String   @id @default(uuid())
  leadId      String
  profileId   String
  amount      Decimal
  timeline    String?
  details     String?
  status      String // SUBMITTED, ACCEPTED, REJECTED
  submittedAt DateTime @default(now())

  lead    Lead               @relation(fields: [leadId], references: [id])
  profile MarketplaceProfile @relation(fields: [profileId], references: [id])

  @@index([leadId])
  @@index([profileId])
  @@index([status])
}

// ============================================================================
// UNIFIED API PLATFORM (Prompt 3.1)
// ============================================================================

// API Key Management
model ApiKey {
  id             String  @id @default(uuid())
  keyHash        String  @unique // SHA-256 hash of the actual API key
  keyPrefix      String? // First 8 chars for identification
  name           String
  jurisdictionId String?
  userId         String?
  organizationId String?

  // Permissions
  scopes    String[] // e.g., ["read", "write", "admin"]
  rateLimit Int      @default(100) // requests per minute

  // Status
  active     Boolean   @default(true)
  isRevoked  Boolean   @default(false)
  expiresAt  DateTime?
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  usage     ApiKeyUsage[]
  auditLogs SecurityAuditLog[]

  @@index([keyHash])
  @@index([userId])
  @@index([organizationId])
  @@index([jurisdictionId])
  @@index([active])
}

// API Key Usage Tracking
model ApiKeyUsage {
  id           String   @id @default(uuid())
  apiKeyId     String
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds
  timestamp    DateTime @default(now())

  // Context
  ipAddress      String?
  userAgent      String?
  jurisdictionId String?
  organizationId String?

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([timestamp])
  @@index([endpoint])
}

// Webhook Management
model Webhook {
  id     String   @id @default(uuid())
  url    String
  secret String // HMAC secret for signing
  events String[] // Event types to subscribe to

  // Ownership
  jurisdictionId String?
  organizationId String?
  userId         String?

  // Status
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  deliveries WebhookDelivery[]

  @@index([jurisdictionId])
  @@index([organizationId])
  @@index([active])
}

// Webhook Delivery Tracking
model WebhookDelivery {
  id        String @id @default(uuid())
  webhookId String
  event     String
  payload   Json

  // Delivery status
  status        WebhookDeliveryStatus @default(PENDING)
  attempts      Int                   @default(0)
  lastAttemptAt DateTime?
  nextRetryAt   DateTime?

  // Response
  responseCode Int?
  responseBody String? // Truncated response body

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([nextRetryAt])
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// API Usage Analytics (consolidated usage tracking)
model ApiUsage {
  id             String  @id @default(uuid())
  apiKeyId       String?
  userId         String?
  organizationId String?
  jurisdictionId String?

  // Request details
  endpoint     String
  method       String
  statusCode   Int
  responseTime Int // milliseconds

  // Context
  ipAddress String?
  userAgent String?

  timestamp DateTime @default(now())

  @@index([apiKeyId])
  @@index([userId])
  @@index([organizationId])
  @@index([jurisdictionId])
  @@index([timestamp])
  @@index([endpoint])
}

// Security Audit Logging
model SecurityAuditLog {
  id        String            @id @default(uuid())
  eventType SecurityEventType
  severity  SecuritySeverity

  // Actor
  userId    String?
  apiKeyId  String?
  ipAddress String
  userAgent String

  // Action
  endpoint   String
  method     String
  statusCode Int

  // Data
  requestBody  Json?
  responseBody Json?

  // Context
  jurisdictionId String?
  organizationId String?
  metadata       Json?

  timestamp DateTime @default(now())

  apiKey ApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([severity])
  @@index([userId])
  @@index([apiKeyId])
  @@index([jurisdictionId])
  @@index([organizationId])
  @@index([timestamp])
}

enum SecurityEventType {
  API_ACCESS
  AUTHENTICATION
  AUTHORIZATION
  DATA_ACCESS
  CONFIG_CHANGE
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================================
// SECURITY & AUTHENTICATION MODELS
// ============================================================================

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  sessionToken String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  lastActivity DateTime @default(now()) // CORRECT FIELD NAME (not lastActivityAt!)
  isActive     Boolean  @default(true)
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([sessionToken])
  @@index([expiresAt])
}

model TwoFactorSecret {
  id         String    @id @default(uuid())
  userId     String    @unique
  secret     String
  isEnabled  Boolean   @default(false)
  isVerified Boolean   @default(false)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}

model BackupCode {
  id        String    @id @default(uuid())
  userId    String
  code      String    @unique
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([code])
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model SecurityEvent {
  id          String   @id @default(uuid())
  userId      String?
  eventType   String
  type        String? // Alias for eventType
  action      String? // Action performed
  description String
  resource    String? // Resource affected by the event
  result      String? // Result of the action (success/failure)
  severity    String   @default("INFO")
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  timestamp   DateTime @default(now()) // Alias for createdAt
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}

// ============================================================================
// PAYMENT & DEPOSIT MODELS
// ============================================================================

model PaymentMethod {
  id                    String   @id @default(uuid())
  userId                String
  type                  String // CARD, ACH, WIRE
  stripePaymentMethodId String   @unique
  last4                 String
  brand                 String?
  bankName              String?
  isDefault             Boolean  @default(false)
  isVerified            Boolean  @default(false)
  status                String   @default("ACTIVE") // ACTIVE, VERIFICATION_PENDING, FAILED, REMOVED
  expiryMonth           Int?
  expiryYear            Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user            User             @relation("UserPaymentMethods", fields: [userId], references: [id], onDelete: Cascade)
  depositRequests DepositRequest[] @relation("PaymentMethodDepositRequests")

  @@index([userId])
  @@index([stripePaymentMethodId])
  @@index([status])
  @@index([type])
  @@index([isDefault])
}

model DepositRequest {
  id                    String    @id @default(uuid())
  escrowId              String // CORRECT FIELD NAME (not escrowAgreementId!)
  paymentMethodId       String
  userId                String
  amount                Decimal   @db.Decimal(18, 2)
  currency              String    @default("USD")
  status                String    @default("PENDING") // PENDING, PROCESSING, CLEARING, COMPLETED, FAILED, CANCELLED, REFUNDED
  requiresVerification  Boolean   @default(false)
  expectedClearanceDate DateTime?
  stripePaymentIntentId String?   @unique
  stripeChargeId        String?
  failureReason         String?
  failureCode           String?
  retryCount            Int       @default(0)
  createdAt             DateTime  @default(now())
  clearedAt             DateTime?
  updatedAt             DateTime  @updatedAt

  // Relations
  escrow        EscrowAgreement @relation("EscrowDepositRequests", fields: [escrowId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod   @relation("PaymentMethodDepositRequests", fields: [paymentMethodId], references: [id], onDelete: Restrict)
  user          User            @relation("UserDepositRequests", fields: [userId], references: [id], onDelete: Cascade)

  @@index([escrowId])
  @@index([paymentMethodId])
  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([escrowId, status])
  @@index([createdAt])
}

model TaxForm {
  id          String    @id @default(uuid())
  userId      String // CORRECT FIELD NAME (not recipientId!)
  taxYear     Int
  formType    String // 1099_NEC, 1099_K, W9
  totalAmount Decimal   @db.Decimal(18, 2)
  status      String    @default("NOT_FILED") // NOT_FILED, FILED, 1099_READY, NOT_REQUIRED
  filedAt     DateTime?
  sentAt      DateTime?
  documentUrl String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user User @relation("UserTaxForms", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([taxYear])
  @@index([formType])
  @@index([status])
  @@index([userId, taxYear])
  @@index([userId, formType, taxYear])
}

// ============================================================================
// STRIPE BILLING MODELS
// ============================================================================

model Payment {
  id                    String    @id @default(uuid())
  orgId                 String?
  projectId             String?
  subscriptionId        String?
  stripeInvoiceId       String?
  stripePaymentIntentId String?   @unique
  amount                Decimal   @db.Decimal(10, 2)
  currency              String    @default("usd")
  status                String // completed, failed, pending, refunded
  paidAt                DateTime?
  failedAt              DateTime?
  refundedAt            DateTime?
  refundAmount          Decimal?  @db.Decimal(10, 2)
  metadata              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  financingApplicationId String?

  project              Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  financingApplication FinancingApplication? @relation("FinancingPayments", fields: [financingApplicationId], references: [id], onDelete: SetNull)
  // org          Org?              @relation(fields: [orgId], references: [id], onDelete: SetNull)
  // subscription ServiceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([projectId])
  @@index([subscriptionId])
  @@index([stripePaymentIntentId])
  @@index([financingApplicationId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Invoice {
  id               String    @id @default(uuid())
  orgId            String?
  subscriptionId   String?
  stripeInvoiceId  String    @unique
  invoiceNumber    String?
  amount           Decimal   @db.Decimal(10, 2)
  currency         String    @default("usd")
  status           String // draft, open, paid, uncollectible, void
  periodStart      DateTime?
  periodEnd        DateTime?
  paidAt           DateTime?
  hostedInvoiceUrl String?
  invoicePdf       String?
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // org          Org?              @relation(fields: [orgId], references: [id], onDelete: SetNull)
  // subscription ServiceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([subscriptionId])
  @@index([stripeInvoiceId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

// ============================================================================
// APPROVAL WORKFLOW
// ============================================================================

enum ApprovalRequestType {
  EXPENSE
  TIME_OFF
  PURCHASE
  DOCUMENT
  CUSTOM
}

enum ApprovalRequestStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  type        ApprovalRequestType
  subtype     String?
  status      ApprovalRequestStatus @default(DRAFT)
  priority    ApprovalPriority      @default(MEDIUM)
  title       String
  description String?
  requesterId String
  amount      Decimal?              @db.Decimal(12, 2)
  currency    String?               @default("usd")
  startDate   DateTime?
  endDate     DateTime?
  metadata    Json? // Additional metadata
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  requester     User                 @relation("ApprovalRequestRequester", fields: [requesterId], references: [id])
  approvalSteps ApprovalStep[]
  attachments   ApprovalAttachment[]
  comments      ApprovalComment[]

  @@index([requesterId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([submittedAt])
}

model ApprovalStep {
  id                String             @id @default(uuid())
  approvalRequestId String
  approverId        String
  approverRole      String?
  status            ApprovalStepStatus @default(PENDING)
  comments          String?
  order             Int // Order in approval chain
  required          Boolean            @default(true)
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver        User            @relation("ApprovalStepApprover", fields: [approverId], references: [id])

  @@index([approvalRequestId])
  @@index([approverId])
  @@index([status])
  @@index([order])
}

model ApprovalRule {
  id            String            @id @default(uuid())
  name          String
  type          String
  subtype       String?
  conditions    Json // Array of condition objects
  approvalChain Json // Array of approval chain steps
  priority      ApprovalPriority?
  sla           Int? // SLA in hours
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([type])
  @@index([active])
  @@index([createdAt])
}

model ApprovalAttachment {
  id                String   @id @default(uuid())
  approvalRequestId String
  fileId            String? // Reference to File model
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int // Bytes
  uploadedAt        DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
}

model ApprovalComment {
  id                String   @id @default(uuid())
  approvalRequestId String
  userId            String
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  user            User            @relation("ApprovalCommentUser", fields: [userId], references: [id])

  @@index([approvalRequestId])
  @@index([userId])
  @@index([createdAt])
}

// ============================================================================
// MISSING MODELS - Added for API compatibility
// ============================================================================

model Client {
  id               String   @id @default(uuid())
  name             String
  email            String?
  phone            String?
  assignedPM       String? // PM user ID
  status           String   @default("ACTIVE")
  subscriptionTier String?  @default("BASIC") // BASIC, STANDARD, PREMIUM, ENTERPRISE
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  projects           Project[]
  tasks              Task[]
  assignmentRequests AssignmentRequest[]

  // SOP v2 Service Subscriptions
  pmSubscriptions     PMServiceSubscription[]     @relation("PMServiceSubscriptionClient")
  permitSubscriptions PermitServiceSubscription[] @relation("PermitServiceSubscriptionClient")
  alaCarteServices    ALaCarteService[]           @relation("ALaCarteServiceClient")

  @@index([assignedPM])
  @@index([status])
}

model Task {
  id          String    @id @default(uuid())
  projectId   String?
  clientId    String?
  title       String
  description String?
  status      String    @default("PENDING")
  priority    String    @default("NORMAL")
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  client   Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  comments TaskComment[]

  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([assignedTo])
  // ── Performance: Compound indexes for task boards ──
  @@index([projectId, status]) // Project detail: tasks by status
  @@index([projectId, status, dueDate]) // Task board: filtered + sorted by due date
  @@index([assignedTo, status]) // "My tasks" filtered by status
  @@index([status, createdAt])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model Report {
  id          String    @id @default(uuid())
  projectId   String?
  type        String
  title       String
  description String?
  data        Json?
  status      String    @default("DRAFT")
  generatedBy String?
  periodStart DateTime?
  periodEnd   DateTime?
  generatedAt DateTime?
  content     Json?
  narrative   String?   @db.Text
  templateId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  template ReportTemplate? @relation(fields: [templateId], references: [id])

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

model AssignmentRequest {
  id        String   @id @default(uuid())
  clientId  String
  pmUserId  String
  status    String   @default("PENDING")
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([pmUserId])
  @@index([status])
}

// ============================================================================
// NOTIFICATION SYSTEM MODELS
// ============================================================================

model Notification {
  id      String @id @default(uuid())
  userId  String
  type    String // Notification type
  title   String
  message String
  data    Json? // Additional notification data

  // Delivery channels
  channels String[] // email, push, sms

  // Status tracking
  status String    @default("PENDING") // PENDING, SENT, FAILED
  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  // ── Performance: Compound indexes for notification bell ──
  @@index([userId, status, createdAt]) // Notification bell: unread + recent
}

// ============================================================================
// WEBHOOK IDEMPOTENCY MODELS
// ============================================================================

model WebhookLog {
  id         String  @id @default(uuid())
  webhookId  String  @unique // Stripe webhook ID or other source ID
  status     String  @default("PENDING") // PENDING, PROCESSED, FAILED
  result     Json?
  error      String?
  retryCount Int     @default(0)

  processedAt   DateTime?
  lastAttemptAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  retries WebhookRetry[]

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
}

model WebhookRetry {
  id           String    @id @default(uuid())
  webhookId    String
  retryCount   Int
  scheduledFor DateTime
  payload      Json
  status       String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  error        String?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  webhookLog WebhookLog @relation(fields: [webhookId], references: [webhookId])

  @@index([webhookId])
  @@index([status])
  @@index([scheduledFor])
}

// ============================================================================
// OFAC SCREENING & SECURITY MODELS
// ============================================================================

model OFACScreening {
  id             String   @id @default(uuid())
  screeningId    String   @unique
  entityName     String
  entityType     String
  matchFound     Boolean
  matchScore     Float
  matchDetails   Json?
  requestData    Json?
  sdnListVersion String?
  error          String?
  screenedAt     DateTime @default(now())
