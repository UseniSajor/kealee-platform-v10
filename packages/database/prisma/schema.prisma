  estimatedDuration Int // Minutes
  travelTime        Int? // Minutes from previous

  // Status
  assignedAt DateTime @default(now())
  status     String   @default("SCHEDULED") // SCHEDULED, EN_ROUTE, ON_SITE, COMPLETED, CANCELLED

  // Location
