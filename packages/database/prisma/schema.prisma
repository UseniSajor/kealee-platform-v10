model APIIntegration {
  id             String @id @default(uuid())
  jurisdictionId String

  // Provider Info
  provider        String // ACCELA, TYLER, GOVOS, CUSTOM, KEALEE_API
  integrationType String // REST_API, SOAP, GRAPHQL, WEBHOOK

  // Credentials (Encrypted)
  apiUrl         String
  apiKey         String
  clientId       String?
  clientSecret   String?
  authToken      String?
  tokenExpiresAt DateTime?

  // Configuration
  endpoints     Json // Endpoint mappings
  fieldMappings Json // Data transformation rules
  webhookUrl    String? // Our webhook endpoint for them
  webhookSecret String?

  // Status
  isActive   Boolean   @default(true)
  lastSyncAt DateTime?
  lastError  String?
  errorCount Int       @default(0)

  // Performance
  totalRequests      Int  @default(0)
  successfulRequests Int  @default(0)
  failedRequests     Int  @default(0)
  avgResponseTime    Int? // Milliseconds

  // Rate Limiting
  rateLimitRemaining Int?
  rateLimitReset     DateTime?

  jurisdiction  Jurisdiction   @relation(fields: [jurisdictionId], references: [id])
  apiCalls      APICall[]
  webhookEvents WebhookEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jurisdictionId])
  @@index([provider])
  @@index([isActive])
}

model APICall {
  id            String @id @default(uuid())
  integrationId String

  // Request
  endpoint       String
  method         String // GET, POST, PUT, DELETE, PATCH
  requestPayload Json?
  requestHeaders Json?

  // Response
  statusCode      Int?
  responsePayload Json?
  responseHeaders Json?
  responseTime    Int? // Milliseconds

  // Context
  action       String // SUBMIT_PERMIT, CHECK_STATUS, GET_DOCUMENTS
  permitId     String?
  inspectionId String?

  // Outcome
  success      Boolean
  errorMessage String?
  retryCount   Int     @default(0)

  executedAt DateTime @default(now())

  integration APIIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([executedAt])
  @@index([action])
  @@index([permitId])
}

model WebhookEvent {
  id            String  @id @default(uuid())
  integrationId String?

  // Event Details
  eventType   String // permit.submitted, permit.approved, inspection.scheduled
  eventSource String // ACCELA, TYLER, CLIENT, JURISDICTION
  eventId     String? // Source event ID

  // Payload
  payload   Json
  signature String? // For verification
  rawBody   String? // Original raw body

  // Processing
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
  status       String    @default("PENDING") // PENDING, PROCESSED, FAILED, RETRYING
  errorMessage String?
  retryCount   Int       @default(0)

  // Related Records
  permitId     String?
  inspectionId String?

  integration APIIntegration? @relation(fields: [integrationId], references: [id])

  @@index([integrationId])
  @@index([eventType])
  @@index([receivedAt])
  @@index([status])
  @@index([permitId])
}

