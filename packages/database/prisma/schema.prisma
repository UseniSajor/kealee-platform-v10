  AUTH_STRATEGY // Authentication and authorization
  API_DESIGN // API endpoint design
  PRICING_STRUCTURE // Pricing and billing decisions
  FEATURE_SPEC // Feature specifications
  UI_UX_DECISION // UI/UX design decisions
  INTEGRATION // Third-party integration decisions
  SECURITY // Security architecture
  DEPLOYMENT // Deployment and infrastructure
  BUSINESS_RULE // Business logic rules
  DATA_FLOW // How data moves between apps
  COST_BOOK_ARCHITECTURE // Cost database tier structure
