  aiTradeCategory String? // AI-detected trade category
  aiProjectType   String? // AI-detected project type
  aiMethodology   String? // AI-detected construction methodology
  aiConfidence    Decimal? @db.Decimal(5, 4) // AI classification confidence 0-1

