// ============================================================================
// PROJECT PHASES
// ============================================================================

enum ProjectPhaseType {
  PRE_CONSTRUCTION // Planning, permits, design
  SITE_PREPARATION // Demolition, grading, utilities
  FOUNDATION // Excavation, footings, foundation walls
  FRAMING // Structural framing, roof structure
  ROUGH_IN // Electrical, plumbing, HVAC rough
  EXTERIOR // Siding, roofing, windows, doors
  INSULATION // Insulation, vapor barriers
  DRYWALL // Drywall, taping, texturing
  INTERIOR_FINISHES // Cabinets, flooring, trim, paint
  MEP_FINISH // Electrical/plumbing/HVAC finish
  FINAL_INSPECTION // Inspections, punch list
  CLOSEOUT // Final walkthrough, handover
  WARRANTY // Post-completion warranty period
  CUSTOM // Custom phase for unique projects
}

enum ProjectPhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  DELAYED
  COMPLETED
  SKIPPED
}

model ProjectPhase {
  id        String @id @default(uuid())
  projectId String

  // Phase identification
  type        ProjectPhaseType
  name        String // Display name (can override type name)
  description String?
  sortOrder   Int              @default(0) // For ordering phases

  // Status tracking
  status          ProjectPhaseStatus @default(NOT_STARTED)
  percentComplete Int                @default(0) // 0-100

  // Schedule
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  // Budget allocation
  budgetAllocated Decimal? @db.Decimal(14, 2) // Allocated budget for this phase
  budgetSpent     Decimal? @db.Decimal(14, 2) // Actual spent

  // Responsible party
  assignedContractorId String?
  assignedPmId         String?

  // Dependencies (phases that must complete before this one)
  dependsOnPhaseIds String[] // Array of ProjectPhase IDs

  // Notes and metadata
  notes    String?
  metadata Json?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  completedBy String? // User ID who marked as complete

  // Relations
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedContractor Contractor?           @relation(fields: [assignedContractorId], references: [id], onDelete: SetNull)
  milestones         PhaseMilestone[]
  phaseHistory       ProjectPhaseHistory[]

  @@unique([projectId, type]) // One phase of each type per project (unless CUSTOM)
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([assignedContractorId])
}

model PhaseMilestone {
  id      String @id @default(uuid())
  phaseId String

  name        String
  description String?
  dueDate     DateTime?

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?

  // Verification
  requiresInspection Boolean @default(false)
  inspectionId       String? // Link to Inspection if required

  // Payment trigger
  triggersPayment  Boolean  @default(false)
  paymentAmount    Decimal? @db.Decimal(14, 2)
  paymentTriggered Boolean  @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phase      ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  inspection Inspection?  @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  @@index([phaseId])
  @@index([isCompleted])
}

model ProjectPhaseHistory {
  id      String @id @default(uuid())
  phaseId String

  // What changed
  fromStatus ProjectPhaseStatus?
  toStatus   ProjectPhaseStatus

  // Who and when
  changedBy String?
  changedAt DateTime @default(now())

  // Context
  reason String?
  notes  String?

  phase ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
  @@index([changedAt])
}

model User {
  id        String  @id @default(uuid())
  email     String? @unique
  name      String?
  firstName String?
  lastName  String?
  password  String?
  phone     String?

  // User metadata
