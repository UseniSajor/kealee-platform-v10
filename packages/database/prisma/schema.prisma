  includesExpediting      Boolean @default(false)
  includesInspectionCoord Boolean @default(false)
  resubmittalsIncluded    Int     @default(0) // 0, 1, unlimited
  turnaroundDays          Int     @default(3) // 2-3, 1-2, same-day

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation("PermitServiceSubscriptionClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectId])
  @@index([status])
  @@index([packageTier])
  @@map("permit_service_subscriptions")
}

