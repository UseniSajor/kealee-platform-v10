  city    String?
  state   String?
  zipCode String?
  ssn     String? // Encrypted
  ein     String? // Tax ID

  // Location
  homeLatitude  Float?
  homeLongitude Float?

  // Notification preferences
  notificationPreferences Json?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Organization relations
  orgMemberships OrgMember[]
  sessions       Session[]
  notifications  Notification[]

  // Relationships (example - adjust based on your existing schema)
  // submittedPermits  Permit[]  @relation("PermitApplicant")
  // reviewedPermits   Permit[]  @relation("PermitReviewer")
  // pmPermits         Permit[]  @relation("PermitPM")

  // PermitRouting relations
