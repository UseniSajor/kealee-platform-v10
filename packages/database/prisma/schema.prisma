  @@index([pmId])
  @@index([scheduledAt])
  @@index([status])
  // ── Performance: Compound indexes for visit calendar ──
  @@index([projectId, scheduledAt]) // Project detail: upcoming visits
  @@index([pmId, scheduledAt]) // PM calendar: my schedule
  @@map("site_visits")
}

// APP-03: Change Order Models

model ChangeOrder {
  id                String  @id @default(uuid())
  projectId         String
  contractId        String?
  changeOrderNumber String
  number            Int?    @default(autoincrement()) // Auto-incrementing number for display
  title             String
  description       String? @db.Text
  reason            String? // OWNER_REQUEST, DESIGN_CHANGE, UNFORESEEN_CONDITIONS, CODE_COMPLIANCE
  requestedBy       String? // User ID who requested the change

  // Amounts
  originalAmount Decimal  @db.Decimal(12, 2)
  adjustedAmount Decimal? @db.Decimal(12, 2)
  estimatedCost  Decimal? @db.Decimal(12, 2)
  approvedCost   Decimal? @db.Decimal(12, 2)
  laborCost      Decimal? @db.Decimal(12, 2)
  materialCost   Decimal? @db.Decimal(12, 2)
  markupPercent  Decimal? @db.Decimal(5, 2)
  totalCost      Decimal  @db.Decimal(12, 2)

