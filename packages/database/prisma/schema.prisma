  verified       Boolean @default(false) // true if GPS within 200m of project
  distanceMeters Float? // distance from project site
  manualOverride Boolean @default(false) // user overrode GPS warning
  overrideNote   String? @db.Text

  // Time on site (calculated at check-out)
  minutesOnSite Int?

  // Context
  role       String? // CONTRACTOR, PM, INSPECTOR, etc.
  orgId      String?
  deviceInfo String? // mobile/desktop/tablet

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user    User    @relation("UserCheckIns", fields: [userId], references: [id])
  project Project @relation("ProjectCheckIns", fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, checkInAt])
  @@index([userId, checkInAt])
  @@index([projectId, checkOutAt])
  @@index([verified])
  @@map("site_check_ins")
}

// ============================================================================
// IoT SENSOR DATA
// ============================================================================

model SensorDevice {
  id              String    @id @default(uuid())
  projectId       String
  type            String // "temperature", "humidity", "vibration", "noise", "water_leak", "air_quality", "motion"
  name            String // "Kitchen Humidity Sensor", "Basement Temp #1"
  location        String // "Kitchen wall A", "Basement NE corner"
  deviceId        String    @unique // hardware device identifier
  status          String    @default("active") // active, offline, low_battery, error
  batteryLevel    Int? // percentage, if applicable
  lastReading     DateTime?
  config          Json? // threshold settings: { alertAbove: 80, alertBelow: 32, unit: "°F" }
  metadata        Json? // additional device metadata
  installedAt     DateTime?
  installedBy     String?
  firmwareVersion String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relationships
  project  Project         @relation("ProjectSensors", fields: [projectId], references: [id], onDelete: Cascade)
  readings SensorReading[]

  @@index([projectId])
  @@index([status])
  @@index([type])
  @@map("sensor_devices")
}

model SensorReading {
  id        String   @id @default(uuid())
  deviceId  String
  value     Float
  unit      String // "°F", "%RH", "dB", "g", "ppm", "boolean"
  timestamp DateTime @default(now())
  alert     Boolean  @default(false) // true if this reading triggered an alert
  alertType String? // "above_threshold", "below_threshold", "rate_of_change", "offline"
  metadata  Json? // additional reading context

  // Relationships
  device SensorDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, timestamp])
  @@index([alert])
  @@index([timestamp])
  @@map("sensor_readings")
}

