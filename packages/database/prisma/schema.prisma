// ============================================================================
// 21st CENTURY ROAD TO HOUSING ACT — ZONING & COMPLIANCE
// Sec 203 (Housing Supply Frameworks), Sec 209 ($200M Innovation Fund),
// NEPA Streamlining
// ============================================================================

model ZoningProfile {
  id             String  @id @default(uuid())
  jurisdictionId String
  parcelNumber   String?
  address        String
  city           String
  state          String
  zipCode        String
  latitude       Float?
  longitude      Float?

  // Zoning Classification
  zoningDistrict   ZoningDistrictType @default(UNKNOWN)
  zoningCode       String             @default("")
  overlayDistricts String[]           @default([])

  // Permitted Uses
  allowedHousingTypes HousingType[] @default([])
  conditionalUses     HousingType[] @default([])
  prohibitedUses      HousingType[] @default([])

  // Dimensional Standards
  maxDensity     Float?
  maxHeight      Float?
  maxStories     Int?
  minLotSize     Float?
  minLotWidth    Float?
  frontSetback   Float?
  sideSetback    Float?
  rearSetback    Float?
  maxLotCoverage Float?
  maxFAR         Float?
  minOpenSpace   Float?

  // Parking
  parkingMinPerUnit Float?
  parkingReductions Json?
  bikeParking       Float?

  // Special Provisions
  densityBonuses  Json?
  inclusionaryReq Json?

  // NEPA
  nepaExemption       NEPAExemptionType @default(NONE)
  nepaExemptionReason String?

  // Transit-Oriented Development (Build More Housing Near Transit Act)
  transitProximity Float?
  transitType      String?

  // AI Analysis
  aiAnalyzedAt       DateTime?
  aiConfidence       Float?
  aiRawResponse      Json?
  sourceDocumentUrls String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jurisdiction        Jurisdiction             @relation("JurisdictionZoning", fields: [jurisdictionId], references: [id])
  complianceReports   ZoningComplianceReport[]
  developmentPackages DevelopmentPackage[]

  @@unique([parcelNumber, jurisdictionId])
  @@index([jurisdictionId])
  @@index([zoningDistrict])
  @@index([city, state])
  @@index([address])
  @@map("zoning_profiles")
}

model ZoningComplianceReport {
  id              String @id @default(uuid())
  zoningProfileId String
  requestedById   String

  // Proposed Development
  proposedHousingType HousingType
  proposedUnits       Int
  proposedStories     Int         @default(1)
  proposedSqFt        Int?
  proposedHeight      Float?
  proposedLotCoverage Float?
  proposedFAR         Float?
  proposedParking     Int?

  // Compliance Results
  isCompliant         Boolean @default(false)
  complianceScore     Int?
  violations          Json?
  variances           Json?
  conditionalApproval Json?

  // NEPA Assessment
  nepaExemptionEligible Boolean           @default(false)
  nepaCategory          NEPAExemptionType @default(NONE)
  nepaJustification     String?

  // Required Permits
  requiredPermits   Json?
  estimatedTimeline Int?
  estimatedFees     Decimal? @db.Decimal(10, 2)

  // Density Bonus Analysis (Sec 209)
  densityBonusEligible Boolean @default(false)
  densityBonusDetails  Json?

  // AI Analysis
  aiModelUsed      String?
  aiConfidence     Float?
  aiAnalysisDetail Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zoningProfile ZoningProfile @relation(fields: [zoningProfileId], references: [id], onDelete: Cascade)
  requestedBy   User          @relation("ZoningComplianceRequester", fields: [requestedById], references: [id])

  @@index([zoningProfileId])
  @@index([requestedById])
  @@index([proposedHousingType])
  @@map("zoning_compliance_reports")
}

// ============================================================================
// 21st CENTURY ROAD TO HOUSING ACT — PATTERN BOOK HOUSING
// Sec 210 (Accelerating Home Building Act)
// ============================================================================

model PatternBookDesign {
  id             String  @id @default(uuid())
  jurisdictionId String?

  // Design Identity
  name               String
  slug               String          @unique
  housingType        HousingType
  architecturalStyle AutoDesignStyle @default(MODERN)
  description        String          @db.Text
  tags               String[]        @default([])

  // Design Specifications
  totalSqFt     Int
  units         Int     @default(1)
  stories       Int     @default(1)
  bedrooms      Int
  bathrooms     Decimal @db.Decimal(3, 1)
  garageSpaces  Int     @default(0)
  parkingSpaces Int     @default(0)

  // Dimensional Data
  buildingWidth  Float?
  buildingDepth  Float?
  buildingHeight Float?
  footprintSqFt  Int?
  lotWidthMin    Float?
  lotDepthMin    Float?

  // Floor Plan Data
  floorPlanUrls String[] @default([])
  elevationUrls String[] @default([])
  siteLayoutUrl String?
  renderingUrls String[] @default([])
  floorPlanData Json?
  roomSchedule  Json?

  // Cost Data
  estimatedCostLow  Decimal? @db.Decimal(12, 2)
  estimatedCostMid  Decimal? @db.Decimal(12, 2)
  estimatedCostHigh Decimal? @db.Decimal(12, 2)
  costPerSqFt       Decimal? @db.Decimal(8, 2)
  costBreakdown     Json?

  // Construction Data
  estimatedDuration   Int?
  constructionType    String?
  foundationType      String?
  energyEfficiency    String?
  sustainabilityScore Int?

  // Compliance Data
  applicableCodes          String[] @default([])
  preApprovedJurisdictions String[] @default([])
  complianceNotes          Json?

  // Status & Publication
  status              PatternBookStatus @default(DRAFT)
  publishedAt         DateTime?
  featuredOrder       Int?
  isPubliclyAvailable Boolean           @default(true)

  // Usage Stats
  viewCount         Int @default(0)
  downloadCount     Int @default(0)
  permitSubmissions Int @default(0)

  // Creator
  createdById String
  designFirm  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jurisdiction Jurisdiction?          @relation("JurisdictionPatternBooks", fields: [jurisdictionId], references: [id])
  createdBy    User                   @relation("PatternBookCreator", fields: [createdById], references: [id])
  selections   PatternBookSelection[]

  @@index([housingType])
  @@index([status])
  @@index([jurisdictionId])
  @@index([architecturalStyle])
  @@index([totalSqFt])
  @@map("pattern_book_designs")
}

model PatternBookSelection {
  id                  String  @id @default(uuid())
  patternBookDesignId String
  userId              String
  projectId           String?

  // Customization
  customizations Json?
  notes          String?

  // Delivery
  downloadedAt      DateTime?
  permitSubmittedAt DateTime?

  createdAt DateTime @default(now())

  design PatternBookDesign @relation(fields: [patternBookDesignId], references: [id], onDelete: Cascade)
  user   User              @relation("PatternBookSelector", fields: [userId], references: [id])

  @@index([patternBookDesignId])
  @@index([userId])
  @@map("pattern_book_selections")
}

// ============================================================================
// 21st CENTURY ROAD TO HOUSING ACT — AI DEVELOPMENT PACKAGE GENERATOR
