enum ContractStatus {
  DRAFT
  SENT
  SENT_FOR_SIGNATURE
  PARTIALLY_SIGNED
  FULLY_SIGNED
  SIGNED
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISPUTED
  PAID
}

enum EscrowStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum DisputeStatus {
  FILED
  FREEZE_APPLIED
  UNDER_INVESTIGATION
  PENDING_MEDIATION
  PENDING_RESOLUTION
  RESOLVED
  CANCELLED
}

enum LeadStatus {
  OPEN
  INTAKE
  DISTRIBUTED
  QUOTED
  AWARDED
  LOST
  CLOSED
}

model ContractAgreement {
  id                 String         @id @default(uuid())
  projectId          String
  ownerId            String
  contractorId       String
  amount             Decimal
  status             ContractStatus @default(DRAFT)
  signedAt           DateTime?
  expiresAt          DateTime?
  docusignEnvelopeId String?
  signedDocumentUrl  String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner           User             @relation("ContractOwner", fields: [ownerId], references: [id])
  contractor      User             @relation("ContractContractor", fields: [contractorId], references: [id])
  milestones      Milestone[]
  escrowAgreement EscrowAgreement?
  disputes        Dispute[]

  @@index([projectId])
  @@index([ownerId])
  @@index([contractorId])
  @@index([status])
}

model Milestone {
  id          String          @id @default(uuid())
  contractId  String
  name        String
  description String?
  amount      Decimal
  status      MilestoneStatus @default(PENDING)
  dependsOnId String?
  completedAt DateTime?
  approvedAt  DateTime?
  paidAt      DateTime?
  approvedBy  String?

  contract            ContractAgreement @relation(fields: [contractId], references: [id], onDelete: Cascade)
  dependsOn           Milestone?        @relation("MilestoneDependency", fields: [dependsOnId], references: [id])
  dependentMilestones Milestone[]       @relation("MilestoneDependency")
