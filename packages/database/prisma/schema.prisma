  metadata   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploadedBy])
  @@index([status])
  @@map("files")
}

// ── Marketing & Lead Capture ──────────────────────────────────
model MarketingCampaign {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  headline    String?
  subheadline String?
  benefits    Json?    @default("[]")
