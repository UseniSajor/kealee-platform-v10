// APP-01: Bid Engine Models

model Contractor {
  id          String  @id @default(uuid())
  companyName String
  contactName String
  email       String  @unique
  phone       String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  latitude    Float?
  longitude   Float?

  // Business info
  trades          String[]
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount     Int      @default(0)
  yearsInBusiness Int?
  employeeCount   Int?
  bondedAmount    Decimal? @db.Decimal(12, 2)
  insuredAmount   Decimal? @db.Decimal(12, 2)

  // Status
  status      String    @default("ACTIVE")
  isVerified  Boolean   @default(false)
  verifiedAt  DateTime?
  isPreferred Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  credentials        ContractorCredential[]
  reviews            ContractorReview[]
  contractorProjects ContractorProject[]
  bidInvitations     BidInvitation[]
  bidSubmissions     BidSubmission[]
  awardedBidRequests BidRequest[]           @relation("AwardedContractor")
  assignedPhases     ProjectPhase[]
  score              ContractorScore?

  @@index([email])
  @@index([status])
  @@index([isVerified])
  @@map("contractors")
}

model ContractorCredential {
  id           String    @id @default(uuid())
  contractorId String
  type         String // LICENSE, INSURANCE, BOND, CERTIFICATION
  name         String
  number       String?
  issuedBy     String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  documentUrl  String?
  verified     Boolean   @default(false)
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([contractorId])
  @@index([type])
  @@index([expiresAt])
  @@map("contractor_credentials")
}

model ContractorReview {
  id              String  @id @default(uuid())
  contractorId    String
  projectId       String?
  reviewerId      String?
  rating          Int // 1-5
  comment         String? @db.Text
  workQuality     Int? // 1-5
  communication   Int? // 1-5
  timeliness      Int? // 1-5
  professionalism Int? // 1-5
  wouldRecommend  Boolean @default(true)

  createdAt DateTime @default(now())

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([contractorId])
  @@index([projectId])
  @@map("contractor_reviews")
}

model ContractorProject {
  id               String    @id @default(uuid())
  contractorId     String
  projectId        String? // Reference to actual project if exists
  projectName      String
  projectType      String?
  description      String?   @db.Text
  status           String    @default("COMPLETED") // IN_PROGRESS, COMPLETED, TERMINATED
  startDate        DateTime?
  endDate          DateTime?
  scheduledEndDate DateTime?
  actualEndDate    DateTime?
  completedAt      DateTime?
  contractValue    Decimal?  @db.Decimal(12, 2)
  role             String? // GENERAL, SUBCONTRACTOR
  outcome          String? // COMPLETED, TERMINATED, IN_PROGRESS

  createdAt DateTime @default(now())

  contractor Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([contractorId])
  @@index([projectId])
  @@index([status])
  @@index([completedAt])
  @@map("contractor_projects")
}

model BidRequest {
  id              String   @id @default(uuid())
  projectId       String
  title           String?
  trades          String[]
  scope           Json?
  requirements    Json?
  estimatedBudget Decimal? @db.Decimal(12, 2)
  deadline        DateTime
  status          String   @default("OPEN") // OPEN, EVALUATING, AWARDED, CLOSED, CANCELLED

  // Matching results
  matchResults Json? // Results from contractor matching

  // Awarded info
  awardedContractorId String?
  awardedSubmissionId String?
  awardedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  awardedContractor Contractor?     @relation("AwardedContractor", fields: [awardedContractorId], references: [id])
  bidInvitations    BidInvitation[]
  bidSubmissions    BidSubmission[]

  @@index([projectId])
  @@index([status])
  @@index([deadline])
  @@map("bid_requests")
}

model BidInvitation {
  id            String    @id @default(uuid())
  bidRequestId  String
  contractorId  String
  status        String    @default("PENDING") // PENDING, VIEWED, SUBMITTED, DECLINED, EXPIRED
  sentAt        DateTime  @default(now())
  viewedAt      DateTime?
  respondedAt   DateTime?
  declineReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest BidRequest @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id])

  @@unique([bidRequestId, contractorId])
  @@index([bidRequestId])
  @@index([contractorId])
  @@index([status])
  @@map("bid_invitations")
}

model BidSubmission {
  id           String    @id @default(uuid())
  bidRequestId String
  invitationId String?
  contractorId String
  amount       Decimal   @db.Decimal(12, 2)
  timeline     Json? // Proposed timeline/schedule
  scope        Json? // Detailed scope breakdown
  alternates   Json? // Alternative pricing options
  exclusions   String[]
  assumptions  String[]
  validUntil   DateTime?

  // Analysis
  score          Int? // 0-100 AI score
  recommendation String? // AI recommendation
  analysisData   Json? // Detailed analysis

  // Status
  status         String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SHORTLISTED, AWARDED, REJECTED, WITHDRAWN
  submittedAt    DateTime  @default(now())
  withdrawnAt    DateTime?
  withdrawReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest BidRequest @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id])

  @@index([bidRequestId])
  @@index([contractorId])
  @@index([status])
  @@index([score])
  @@index([status, createdAt])
  @@map("bid_submissions")
}

// APP-02: Visit Scheduler Models

model SiteVisit {
  id        String  @id @default(uuid())
  projectId String
  pmId      String
  type      String // INITIAL, PROGRESS, INSPECTION, FINAL, EMERGENCY
  visitType String? // Alias for type for backward compat
  status    String  @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED, RESCHEDULED
  priority  String  @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  scheduledAt              DateTime
  startedAt                DateTime?
  completedAt              DateTime?
  duration                 Int? // Minutes
  estimatedDurationMinutes Int?

  // Location
  address   String?
  latitude  Float?
  longitude Float?

  // Visit details
  purpose       String?  @db.Text
  notes         String?  @db.Text
  findings      Json?
  photos        String[]
  checklistData Json?

  // Client info
  clientName  String?
  clientEmail String?
  clientPhone String?

  // Cancellation
  cancellationReason String?

  // Calendar
  calendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  pm      User?   @relation("SiteVisitPM", fields: [pmId], references: [id])

  // Before/After photo comparison pairs
  beforePairs BeforeAfterPair[] @relation("BeforePairs")
  afterPairs  BeforeAfterPair[] @relation("AfterPairs")

