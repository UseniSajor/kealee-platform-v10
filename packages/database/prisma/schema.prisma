  approvedComplianceReports ComplianceReport[]  @relation("ComplianceReportApprover")

  // Analytics & Predictive Model relations
  fraudScores              FraudScore[]      @relation("FraudScoreUser")
  reviewedFraudScores      FraudScore[]      @relation("FraudScoreReviewer")
  churnPrediction          ChurnPrediction?  @relation("ChurnPredictionUser")
  reviewedChurnPredictions ChurnPrediction[] @relation("ChurnPredictionReviewer")
  analyticsAlerts          AnalyticsAlert[]  @relation("AnalyticsAlertUser")
  resolvedAnalyticsAlerts  AnalyticsAlert[]  @relation("AnalyticsAlertResolver")
  customReports            CustomReport[]    @relation("CustomReportCreator")

  // Compliance & Regulatory relations
  complianceChecks          ComplianceCheck[]      @relation("ComplianceCheckUser")
  performedComplianceChecks ComplianceCheck[]      @relation("ComplianceCheckPerformer")
  licenses                  LicenseTracking[]      @relation("ContractorLicenses")
  insuranceCertificates     InsuranceCertificate[] @relation("ContractorInsurance")
  bonds                     BondTracking[]         @relation("ContractorBonds")
  complianceAlerts          ComplianceAlert[]      @relation("ComplianceAlertUser")
  resolvedComplianceAlerts  ComplianceAlert[]      @relation("ComplianceAlertResolver")

  // Audit & Logging relations
  auditLogsPerformed       AuditLog[]            @relation("AuditLogPerformer")
  financialAuditsPerformed FinancialAuditEntry[] @relation("FinancialAuditAuditor")
  financialAuditsVerified  FinancialAuditEntry[] @relation("FinancialAuditVerifier")
  accessLogs               AccessLog[]           @relation("AccessLogUser")
  auditReportsGenerated    AuditReport[]         @relation("AuditReportGenerator")

  // Payment & Deposit relations
  paymentMethods  PaymentMethod[]  @relation("UserPaymentMethods")
  depositRequests DepositRequest[] @relation("UserDepositRequests")
  taxForms        TaxForm[]        @relation("UserTaxForms")

  // PreCon Project relations
  preConProjects PreConProject[] @relation("PreConProjectOwner")

  // Command Center relations
  siteVisits           SiteVisit[]              @relation("SiteVisitPM")
  changeOrderApprovals ChangeOrderApproval[]    @relation("ChangeOrderApprover")
  notificationPrefs    NotificationPreference[] @relation("UserNotificationPrefs")
  managedProjects      ProjectManager[]

  // Command Center Infrastructure relations
  dashboardWidgets DashboardWidget[]
  aiConversations  AIConversation[]

  // V10 Spec relations
  projectMemberships ProjectMembership[]
  reviews            Review[]            @relation("ReviewAuthor")
}

// ============================================================================
// ============================================================================
// MODULE ENTITLEMENTS
// ============================================================================

model ModuleEntitlement {
