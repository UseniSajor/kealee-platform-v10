// ═══════════════════════════════════════════════════════════════
// BidOpportunity pipeline (Windows) — scoring, MBE/DBE, automation
// ═══════════════════════════════════════════════════════════════

model BidOpportunity {
  id             String  @id @default(uuid())
  organizationId String?

  // Source tracking
  source    BidSource @default(MANUAL)
  sourceId  String?
  sourceUrl String?

  // Project details
  projectName   String
  projectNumber String?
  description   String? @db.Text
  scope         String?
  location      String?
  county        String?
  state         String? @default("MD")

  // Owner / GC info
  ownerName    String?
  gcName       String?
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Financials
  estimatedValue Decimal? @db.Decimal(14, 2)
  bidBond        Decimal? @db.Decimal(14, 2)
  bidBondPercent Decimal? @db.Decimal(5, 2)

  // Key dates
  dueDate         DateTime?
  prebidDate      DateTime?
  prebidLocation  String?
  prebidMandatory Boolean   @default(false)
  awardDate       DateTime?
  startDate       DateTime?

  // Status tracking
  status     BidPipelineStatus @default(NEW)
  priority   BidPriority       @default(MEDIUM)
  assignedTo String?
  confidence Int?

  // Classification flags
  isGovernment   Boolean  @default(false)
  isFederal      Boolean  @default(false)
  isStateLocal   Boolean  @default(false)
  requiresMBE    Boolean  @default(false)
  requiresDBE    Boolean  @default(false)
  mbeGoalPercent Decimal? @db.Decimal(5, 2)
  dbeGoalPercent Decimal? @db.Decimal(5, 2)
  prevailingWage Boolean  @default(false)
  bondRequired   Boolean  @default(false)

  // Evaluation scores (0-100)
  scopeScore    Int?
  locationScore Int?
  valueScore    Int?
  mbeScore      Int?
  overallScore  Int?

  // AI Analysis
  aiAnalysis   Json?
  aiStrategy   Json?
  aiAnalyzedAt DateTime?

  // Notes
  notes         String? @db.Text
  internalNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  checklist   BidChecklistItem[]
  documents   BidDocument[]
  activities  BidActivity[]
  subRequests BidSubRequest[]

  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([dueDate])
  @@index([organizationId])
  @@index([status, priority])
  @@index([source, status])
  @@index([assignedTo])
  @@map("bid_opportunities")
}

enum BidChecklistStatus {
