  OTHER
}

// ============================================================
// CORE MODELS (Stage 7.5)
// ============================================================

model Permit {
  id             String  @id @default(uuid())
  permitNumber   String? @unique // Auto-generated after submission
  projectId      String
  clientId       String
  jurisdictionId String
  pmUserId       String // Kealee PM assigned

  // Basic Info
  permitType    PermitType
  subtype       String? // "Kitchen Remodel", "New Deck", etc.
  scope         String
  valuation     Decimal    @db.Decimal(12, 2) // For fee calculation
  squareFootage Int?
  units         Int? // For multi-family
  stories       Int?

  // Property Info
  propertyId   String?
  address      String
  parcelNumber String?
  zoning       String?

  // Applicant Info
  applicantId    String
  applicantType  ApplicantType
  applicantName  String
  applicantEmail String
  applicantPhone String

  // Professionals
  architectId       String?
  architectName     String?
  architectLicense  String?
  engineerId        String?
  engineerName      String?
  engineerLicense   String?
  contractorId      String?
  contractorName    String?
  contractorLicense String?

  // Status Tracking (Client-Side)
  status          PermitStatus @default(DRAFT) // Alias for kealeeStatus, used by Command Center
  kealeeStatus    PermitStatus @default(DRAFT)
  aiReviewScore   Int? // 0-100 score from AI pre-review
  aiIssuesFound   Json? // JSON array of issues detected
  autoCorrections Json? // Corrections made before submission
  readyToSubmit   Boolean      @default(false)

  // Jurisdiction Tracking (Dual-Side)
  jurisdictionRefNumber String? // Jurisdiction's permit number
  jurisdictionStatus    String? // Status in jurisdiction's system
  submittedVia          String? // API, PORTAL, EMAIL, MANUAL
  submittedAt           DateTime?
  reviewStartedAt       DateTime?
  approvedAt            DateTime?
  issuedAt              DateTime?
  expiresAt             DateTime?
  completedAt           DateTime?

  // Fees
  calculatedFee Decimal?  @db.Decimal(10, 2)
  paidAmount    Decimal?  @default(0) @db.Decimal(10, 2)
  feePaid       Boolean   @default(false)
  feePaidAt     DateTime?

  // Expedited Processing
  expedited              Boolean  @default(false)
  expeditedFee           Decimal? @db.Decimal(10, 2)
  expeditedGuaranteeDays Int? // 2, 5, 10 day guarantee

  // Documents
  plans          String[] // Array of S3 URLs
  calculations   String[]
  reports        String[]
  otherDocuments String[]

  // Relationships
  jurisdiction        Jurisdiction         @relation(fields: [jurisdictionId], references: [id])
  project             Project              @relation(fields: [projectId], references: [id])
  property            Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  aiReviews           AIReviewResult[]
  submissions         PermitSubmission[]
  corrections         PermitCorrection[]
  reviewAssignments   ReviewAssignment[]
  inspections         Inspection[]
  events              PermitEvent[]
  permitRoutings      PermitRouting[]      @relation("PermitRoutingPermit")
  permitNotifications PermitNotification[] @relation("PermitNotificationPermit")
  activities          PermitActivity[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([clientId])
  @@index([jurisdictionId])
  @@index([kealeeStatus])
  @@index([jurisdictionStatus])
  @@index([submittedAt])
  @@index([permitNumber])
  @@index([status, createdAt])
}

model AIReviewResult {
  id            String         @id @default(uuid())
  permitId      String
  reviewSource  AIReviewSource
  overallScore  Int // 0-100
  readyToSubmit Boolean

  // Findings
  planIssues       Json // Array of plan-related issues
  codeViolations   Json // Array of code violations
  missingDocuments Json // Array of missing required docs
  suggestedFixes   Json // Array of suggested fixes

  // Metadata
  modelVersion     String
  processingTimeMs Int
  confidenceScores Json // Per-issue confidence scores

  reviewedAt DateTime @default(now())
  reviewedBy String? // NULL for AI, user ID for human

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([reviewSource])
  @@index([reviewedAt])
}

model PermitSubmission {
  id       String @id @default(uuid())
  permitId String

  submissionType String // INITIAL, RESUBMITTAL, SUPPLEMENTAL
  submittedVia   String // API, PORTAL, EMAIL, MANUAL, FAX
  submittedBy    String // User ID
  submittedAt    DateTime @default(now())

  // Submission Data
  documents Json // Array of document metadata
  formData  Json // Form field values
  notes     String?

  // Jurisdiction Response
  confirmationNumber   String?
  jurisdictionResponse Json? // Raw response from jurisdiction
  submissionStatus     String? // RECEIVED, PROCESSING, REJECTED

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([submittedAt])
  @@index([confirmationNumber])
}

model PermitCorrection {
  id       String @id @default(uuid())
  permitId String

  source     String // JURISDICTION_EMAIL, PORTAL_COMMENT, PHONE_CALL, AI_DETECTION
  receivedAt DateTime @default(now())
  rawText    String // Original correction text

  // Parsed Data
  parsedIssues   Json // Array of structured issues
  affectedSheets String[] // Drawing sheet references
  severity       String // MINOR, MAJOR, CRITICAL
  discipline     ReviewDiscipline?

  // Assignment & Tracking
  assignedTo      String // ARCHITECT, ENGINEER, CONTRACTOR, OWNER
  assignedUserId  String? // Kealee user assigned to fix
  dueDate         DateTime
  status          String    @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, OVERDUE
  resolvedAt      DateTime?
  resolutionNotes String?

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedTo])
}

// ============================================================
// EVENT & AUDIT MODELS
// ============================================================

model PermitEvent {
  id       String  @id @default(uuid())
  permitId String
  userId   String? // NULL for system events

  eventType   String // STATUS_CHANGE, DOCUMENT_UPLOAD, FEE_PAID, etc.
  description String
  metadata    Json? // Additional event data

  // Source
  source    String  @default("SYSTEM") // SYSTEM, USER, API, WEBHOOK
  ipAddress String?
  userAgent String?

  occurredAt DateTime @default(now())

  permit Permit @relation(fields: [permitId], references: [id], onDelete: Cascade)

  @@index([permitId])
  @@index([eventType])
  @@index([occurredAt])
  @@index([userId])
}

model Inspection {
  id               String  @id @default(uuid())
  inspectionNumber String? @unique
  permitId         String
  projectId        String
  jurisdictionId   String

  inspectionType InspectionType
  description    String?
  phaseRequired  String? // Construction phase

  // Preparation (Client-Side)
  checklistId     String?
  sitePhotos      String[] // Pre-inspection photos
  pmPreInspection DateTime? // PM verification date
  readyToSchedule Boolean   @default(false)
  notes           String? // Contractor notes about readiness

  // Scheduling (Jurisdiction-Side)
  requestedDate         DateTime
  requestedBy           String // User ID
  scheduledDate         DateTime?
  scheduledWindow       String? // "8:00-12:00", "1:00-5:00"
  inspectorId           String? // Jurisdiction inspector
  jurisdictionRefNumber String?

  // Remote Inspection (Dual-Side Extension)
  isRemote          Boolean @default(false)
  videoSessionId    String?
  videoRecordingUrl String?
  liveStreamUrl     String?
  aiVideoAnalysis   Json?

  // Results
  result         InspectionResult?
  inspectorNotes String?
  deficiencies   Json? // Array of deficiencies found
  passedItems    Int?
  failedItems    Int?
  totalItems     Int?
  completedAt    DateTime?

  // Reinspection Tracking
  parentInspectionId String?
  isReinspection     Boolean @default(false)

  // Relationships
  permit               Permit                @relation(fields: [permitId], references: [id])
  project              Project               @relation(fields: [projectId], references: [id])
  jurisdiction         Jurisdiction          @relation(fields: [jurisdictionId], references: [id])
  inspector            JurisdictionStaff?    @relation(fields: [inspectorId], references: [id])
  remoteSession        RemoteInspection?
  inspectionAssignment InspectionAssignment?

  // Command Center relations
  preparationItems InspectionPreparationItem[]
  findings         InspectionFinding[]

  // Phase milestone relations
  phaseMilestones PhaseMilestone[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permitId])
  @@index([projectId])
  @@index([jurisdictionId])
  @@index([scheduledDate])
  @@index([inspectorId])
  @@index([result])
}

