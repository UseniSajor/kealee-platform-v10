// APP-15: Estimation Tool Models (from user's schema provided)

model CostDatabase {
  id             String           @id @default(uuid())
  organizationId String?
  name           String
  description    String?
  region         String
  type           CostDatabaseType @default(CUSTOM)
  version        String           @default("1.0")
  effectiveDate  DateTime         @default(now())
  expirationDate DateTime?
  source         String?
  isActive       Boolean          @default(true)
  isDefault      Boolean          @default(false)
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // ── 3-Tier Cost Book Architecture ─────────────────────────────────
  tier         CostDatabaseTier     @default(ORGANIZATION)
  visibility   CostDataVisibility   @default(ORG_ONLY)
  reviewStatus CostDataReviewStatus @default(DRAFT)

  // Submission & Review tracking
  submittedById String? // User who uploaded / created
  reviewedById  String? // Kealee admin who approved/rejected
  reviewedAt    DateTime?
  reviewNotes   String?   @db.Text

  // Classification for organization
  tradeCategory String? // e.g. "concrete", "steel", "electrical"
  projectType   String? // e.g. "residential", "commercial", "industrial"
  methodology   String? // e.g. "tilt-up", "stick-frame", "CMU"

  // Standard book flags (Tier 1)
  isStandard Boolean @default(false) // true = Kealee base/standard cost book

  materials      MaterialCost[]
  laborRates     LaborRate[]
  equipmentRates EquipmentRate[]
  assemblies     Assembly[]
  estimates      Estimate[]
  importJobs     CostCodeImportJob[]
  reviews        CostDataReview[]

  submittedBy User? @relation("CostDatabaseSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User? @relation("CostDatabaseReviewer", fields: [reviewedById], references: [id])

  @@index([organizationId])
  @@index([region])
  @@index([isActive])
  @@index([tier])
  @@index([visibility])
  @@index([reviewStatus])
  @@index([tradeCategory])
  @@index([submittedById])
  @@map("cost_databases")
}

enum CostDatabaseType {
  NATIONAL
  REGIONAL
  LOCAL
  CUSTOM
  IMPORTED
}

// ── 3-Tier Cost Book Enums ────────────────────────────────────────

enum CostDatabaseTier {
  STANDARD // Tier 1: Kealee base cost book — admin upload/remove only
  COMMUNITY // Tier 2: User-uploaded, curated — feeds AI & platform intelligence
  ORGANIZATION // Tier 3: Private org-scoped — customizable per user/org
}

enum CostDataVisibility {
  PUBLIC // Visible to all authenticated users (standard books)
  AI_STAFF_ONLY // Visible to platform AI and Kealee staff only (community data)
  ORG_ONLY // Visible only to the uploading organization (private)
  ADMIN_ONLY // Visible only to Kealee admin (internal reference)
}

enum CostDataReviewStatus {
  DRAFT // Just uploaded, not yet submitted for review
  PENDING_REVIEW // Submitted for Kealee admin review
  APPROVED // Approved by admin — available per visibility rules
  REJECTED // Rejected by admin — not available
  ARCHIVED // Previously approved, now archived
}

