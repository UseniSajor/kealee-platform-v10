// ── AI Takeoff Job ──────────────────────────────────────────────────
// Tracks AI-powered plan takeoff jobs that process architectural drawings
// into CTC task breakdowns and estimate line items.
enum TakeoffJobStatus {
  TAKEOFF_PENDING
  TAKEOFF_UPLOADING
  TAKEOFF_ANALYZING
  TAKEOFF_EXTRACTING
  TAKEOFF_MAPPING
  TAKEOFF_REVIEW
  TAKEOFF_CONFIRMED
  TAKEOFF_FAILED
}

model TakeoffJob {
  id             String  @id @default(uuid())
  organizationId String?
  userId         String
  estimateId     String?

  // Input files
  fileName  String
  fileUrl   String?
  fileSize  Int?
  mimeType  String  @default("application/pdf")
  pageCount Int?

  // Processing state
  status   TakeoffJobStatus @default(TAKEOFF_PENDING)
  progress Int              @default(0) // 0-100

  // AI extraction results
  extractedScopes Json? // Array of detected scope items from plans
  extractedTasks  Json? // Mapped CTC tasks with quantities
  confidence      Decimal? @db.Decimal(5, 4)

  // Mapping results
  ctcTasksMatched    Int @default(0)
  ctcTasksUnmatched  Int @default(0)
  lineItemsGenerated Int @default(0)

  // Review
  reviewedBy  String?
  reviewNotes String?
  adjustments Json? // User modifications before confirmation

  // Errors
  errors Json?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation("TakeoffJobs", fields: [userId], references: [id])
  estimate Estimate? @relation(fields: [estimateId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([estimateId])
  @@index([status])
  @@map("takeoff_jobs")
}

