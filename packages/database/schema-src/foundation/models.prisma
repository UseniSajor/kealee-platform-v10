model PlatformKnowledge {
  id       String                    @id @default(uuid())
  category PlatformKnowledgeCategory
  topic    String // Short topic label e.g. "Cost Book Architecture"
  question String                    @db.Text // The prompt/question asked
  answer   String                    @db.Text // The recommendation/answer given
  decision String?                   @db.Text // Final decision made (if different from answer)

  // Classification
  domain   String? // e.g. "estimation", "auth", "billing", "permits"
  appScope String[] @default([]) // Which apps this applies to: ["os-pm", "m-estimation"]
  tags     String[] @default([])

  // Status & Priority
  status        KnowledgeStatus   @default(ACTIVE)
  priority      KnowledgePriority @default(NORMAL)
  isImplemented Boolean           @default(false)
  implementedAt DateTime?

  // Context
  authorId     String? // Who authored/prompted this
  sessionRef   String? // Reference to Claude session or commit hash
