// FOUNDATION — BOT/AGENT EXECUTION TRACKING
// Domain: foundation | Owner: worker service + all agents
// Tracks bot/agent runs, inputs, outputs, and errors for audit and traceability

enum BotRunStatus {
  STARTED
  PROCESSING
  COMPLETED
  FAILED
  TIMEOUT
}

// Bot/agent execution record
model BotRun {
  id String @id @default(uuid())

  // Bot Identity
  botName     String // "concept-engine", "estimation-bot", "permit-bot", "vision-analyzer", etc.
  botVersion  String @default("1.0")
  agentType   String? // "design", "estimation", "vision", "nlp", etc.

  // Execution Context
  status      BotRunStatus @default(STARTED)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationMs  Int? // Duration in milliseconds

  // Input/Output Context
  inputId     String? // Links to BotRunInput
  outputId    String? // Links to BotRunOutput
  errorId     String? // Links to BotRunError (if failed)

  // Source & Traceability
  sourceType  String? // "intake", "project", "job_queue", "webhook", "manual", etc.
  sourceId    String? // ID of source entity (intakeId, projectId, jobId, etc.)
  triggeredBy String? // User ID or service name that triggered this

  // Relationships (for traceability)
  projectId           String?
  projectConceptId    String?
  estimateId          String?
  permitApplicationId String?

  // Metadata
  metadata Json? // Custom bot-specific metadata
  tags     String[] // "high-priority", "retry-attempt-2", etc.

  // Cost Tracking
  tokensCost Int? // Estimated tokens used
  apiCallsCost Decimal? @db.Decimal(10, 4) // Estimated API cost

  // Input
  input BotRunInput?

  // Output
  output BotRunOutput?

  // Error (if failed)
  error BotRunError?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([botName])
  @@index([status])
  @@index([sourceType])
  @@index([sourceId])
  @@index([createdAt])
  @@map("bot_runs")
}

// Snapshot of bot input (full context passed to bot)
model BotRunInput {
  id String @id @default(uuid())

  botRunId String @unique

  // Input Data (stored as JSON)
  // Examples:
  // - Design intake: { projectType, description, photos, budget, etc. }
  // - Cost estimate: { scopeDetail, designDrawings, location, etc. }
  // - Vision analysis: { imageUrl, analysisType, confidence, etc. }
  rawInput Json

  // Parsed Input (normalized/structured)
  parsedInput Json?

  // Input Validation
  isValidated Boolean @default(false)
  validationErrors String[] @default([]) // List of validation issue descriptions

  createdAt DateTime @default(now())

  botRun BotRun @relation(fields: [botRunId], references: [id], onDelete: Cascade)

  @@map("bot_run_inputs")
}

// Snapshot of bot output (complete results generated by bot)
model BotRunOutput {
  id String @id @default(uuid())

  botRunId String @unique

  // Output Data (stored as JSON)
  // Examples:
  // - Concept engine: { concepts: [...], styleProfile, budget, feasibility, etc. }
  // - Estimation: { lineItems: [...], total, RSMeans_references, etc. }
  // - Vision: { findings: [...], defects: [...], confidence, etc. }
  rawOutput Json

  // Post-processing (if further refined)
  processedOutput Json? // After human review, adjustments, etc.

  // Output Status
  isComplete       Boolean @default(false)
  quality          String? // "high", "medium", "low", "review_required"
  confidenceScore  Float? // 0.0-1.0
  requiresReview   Boolean @default(false)
  reviewNotes      String? @db.Text

  // File References (if output includes generated files)
  outputFileUrls String[] // S3/Supabase URLs for PDFs, images, etc.
  outputFileCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  botRun BotRun @relation(fields: [botRunId], references: [id], onDelete: Cascade)

  @@map("bot_run_outputs")
}

// Error tracking for failed bot runs
model BotRunError {
  id String @id @default(uuid())

  botRunId String @unique

  // Error Details
  errorType   String // "validation_error", "api_error", "timeout", "parse_error", etc.
  errorCode   String?
  errorMessage String @db.Text
  errorStack   String? @db.Text // Stack trace if available

  // Error Context
  failedAt    DateTime @default(now())
  retryCount  Int @default(0)
  isRetryable Boolean @default(true)
  nextRetryAt DateTime?

  // Recovery
  recoveryAttempt String? // Description of attempted recovery
  wasRecovered    Boolean @default(false)

  createdAt DateTime @default(now())

  botRun BotRun @relation(fields: [botRunId], references: [id], onDelete: Cascade)

  @@index([errorType])
  @@index([isRetryable])
  @@map("bot_run_errors")
}

// ─────────────────────────────────────────────────────────────────────
// IMPORTANT NOTE: Seed/Reference Data
// ─────────────────────────────────────────────────────────────────────
// The seed data stored in Postgres (jurisdictions, rules, prompts, etc.)
// is NOT training data for LLMs. It is runtime reference context passed
// to agents at execution time via retrievals and registries.
//
// Seeds are used to provide:
// - Jurisdiction rules and requirements
// - Policy enforcement rules
// - Service catalog information
// - Workflow definitions
// - Role-based permissions
//
// Seeds do NOT:
// - Fine-tune LLM models
// - Influence model weights or behavior
// - Train models on proprietary data
// - Create learning artifacts
//
// Agents access seeds via:
// - @kealee/seeds package registries
// - RAG retrieval at runtime
// - Direct database queries for lookups
// ─────────────────────────────────────────────────────────────────────
