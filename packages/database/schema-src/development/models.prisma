// DEVELOPMENT — Models
// Auto-generated from schema splitter

// Development Lead (from website intake or manual entry)
model DevelopmentLead {
  id String @id @default(uuid())

  // Contact Information
  fullName String
  company  String
  email    String
  phone    String?
  role     String // Owner, Developer, Investor, Asset Manager, Non-profit, Other

  // Project Details
  location     String
  assetType    DevelopmentAssetType
  units        String // Can be number or "N/A" for non-unit-based
  notUnitBased Boolean                 @default(false)
  projectStage DevelopmentProjectStage
  budgetRange  String // "< $1M", "$1–5M", etc.
  timeline     String // "0–3 mo", "3–6 mo", etc.

  // Needs Assessment
  needsHelp String[] // Array of selected needs
  message   String   @db.Text // Project summary

  // Lead Management
  status     DevelopmentLeadStatus   @default(NEW)
  priority   DevelopmentLeadPriority @default(MEDIUM)
  source     DevelopmentLeadSource   @default(WEBSITE)
  assignedTo String? // User ID of assigned team member

  // Deal Information
  estimatedValue Decimal?  @db.Decimal(12, 2)
  proposalSentAt DateTime?
  proposalAmount Decimal?  @db.Decimal(12, 2)
  closedAt       DateTime?
  closedAmount   Decimal?  @db.Decimal(12, 2)
  lostReason     String?

  // Communication
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?

  // Metadata
  consent     Boolean  @default(false)
  ipAddress   String?
  userAgent   String?
  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  notes      DevelopmentLeadNote[]
  activities DevelopmentLeadActivity[]

  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([email])
  @@index([createdAt])
  @@index([nextFollowUpAt])
  @@map("development_leads")
}

// Notes on development leads
model DevelopmentLeadNote {
  id     String @id @default(uuid())
  leadId String

  content   String  @db.Text
  createdBy String // User ID
  isPrivate Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead DevelopmentLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdBy])
  @@index([createdAt])
  @@map("development_lead_notes")
}

// Activity log for development leads
model DevelopmentLeadActivity {
  id     String @id @default(uuid())
  leadId String

  activityType String // STATUS_CHANGED, EMAIL_SENT, CALL_MADE, MEETING_SCHEDULED, PROPOSAL_SENT, NOTE_ADDED, etc.
  description  String @db.Text
  metadata     Json? // Additional activity data

  createdBy String // User ID
  createdAt DateTime @default(now())

  lead DevelopmentLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([activityType])
  @@index([createdAt])
  @@map("development_lead_activities")
}

model FinancingApplication {
  id              String          @id @default(uuid())
  projectId       String
  applicantId     String
  requestedAmount Decimal         @db.Decimal(18, 2)
  approvedAmount  Decimal?        @db.Decimal(18, 2)
  interestRate    Float?
  termMonths      Int?
  lenderName      String?
  loanOfficer     String?
  loanNumber      String?
  status          FinancingStatus @default(PENDING)
  applicationUrl  String?
  approvalUrl     String?
  appliedAt       DateTime        @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  fundedAt        DateTime?

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  applicant     User      @relation(fields: [applicantId], references: [id])
  disbursements Payment[] @relation("FinancingPayments")

  @@index([projectId])
  @@index([applicantId])
  @@index([status])
}

model PatternBookDesign {
  id               String  @id @default(uuid())
  jurisdictionId   String?

  // Design Identity
  name              String
  slug              String  @unique
  housingType       HousingType
  architecturalStyle AutoDesignStyle @default(MODERN)
  description        String          @db.Text
  tags               String[]        @default([])

  // Design Specifications
  totalSqFt     Int
  units         Int     @default(1)
  stories       Int     @default(1)
  bedrooms      Int
  bathrooms     Decimal @db.Decimal(3, 1)
  garageSpaces  Int     @default(0)
  parkingSpaces Int     @default(0)

  // Dimensional Data
  buildingWidth  Float?
  buildingDepth  Float?
  buildingHeight Float?
  footprintSqFt  Int?
  lotWidthMin    Float?
  lotDepthMin    Float?

  // Floor Plan Data
  floorPlanUrls   String[] @default([])
  elevationUrls   String[] @default([])
  siteLayoutUrl   String?
  renderingUrls   String[] @default([])
  floorPlanData   Json?
  roomSchedule    Json?

  // Cost Data
  estimatedCostLow  Decimal? @db.Decimal(12, 2)
  estimatedCostMid  Decimal? @db.Decimal(12, 2)
  estimatedCostHigh Decimal? @db.Decimal(12, 2)
  costPerSqFt       Decimal? @db.Decimal(8, 2)
  costBreakdown     Json?

  // Construction Data
  estimatedDuration   Int?
  constructionType    String?
  foundationType      String?
  energyEfficiency    String?
  sustainabilityScore Int?

  // Compliance Data
  applicableCodes             String[]         @default([])
  preApprovedJurisdictions    String[]         @default([])
  complianceNotes             Json?

  // Status & Publication
  status              PatternBookStatus @default(DRAFT)
  publishedAt         DateTime?
  featuredOrder       Int?
  isPubliclyAvailable Boolean           @default(true)

  // Usage Stats
  viewCount         Int @default(0)
  downloadCount     Int @default(0)
  permitSubmissions Int @default(0)

  // Creator
  createdById String
  designFirm  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jurisdiction Jurisdiction?        @relation("JurisdictionPatternBooks", fields: [jurisdictionId], references: [id])
  createdBy    User                 @relation("PatternBookCreator", fields: [createdById], references: [id])
  selections   PatternBookSelection[]

  @@index([housingType])
  @@index([status])
  @@index([jurisdictionId])
  @@index([architecturalStyle])
  @@index([totalSqFt])
  @@map("pattern_book_designs")
}

model PatternBookSelection {
  id                  String  @id @default(uuid())
  patternBookDesignId String
  userId              String
  projectId           String?

  // Customization
  customizations Json?
  notes          String?

  // Delivery
  downloadedAt     DateTime?
  permitSubmittedAt DateTime?

  createdAt DateTime @default(now())

  design PatternBookDesign @relation(fields: [patternBookDesignId], references: [id], onDelete: Cascade)
  user   User              @relation("PatternBookSelector", fields: [userId], references: [id])

  @@index([patternBookDesignId])
  @@index([userId])
  @@map("pattern_book_selections")
}

model DevelopmentPackage {
  id              String                  @id @default(uuid())
  userId          String
  projectId       String?
  zoningProfileId String?

  // Property Input
  address     String
  parcelNumber String?
  city        String
  state       String
  zipCode     String
  latitude    Float?
  longitude   Float?

  // Proposed Development
  housingType HousingType
  targetUnits Int
  targetSqFt  Int?
  targetStories Int @default(1)

  // Status
  status DevelopmentPackageStatus @default(INTAKE)

  // Generated Components
  zoningReport    Json?
  conceptPlans    Json?
  costEstimate    Json?
  proForma        Json?
  permitChecklist Json?
  financingOptions Json?
  nepaAssessment  Json?

  // Linked Records
  estimateId          String?
  zoningComplianceId  String?
  patternBookDesignId String?

  // Package Output
  packagePdfUrl String?
  packageData   Json?

  // AI Metadata
  aiModelUsed       String?
  aiTotalTokens     Int?
  aiProcessingTimeMs Int?
  aiConfidence      Float?

  // Timing
  generationStartedAt   DateTime?
  generationCompletedAt DateTime?
  expiresAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation("DevelopmentPackageUser", fields: [userId], references: [id])
  zoningProfile ZoningProfile? @relation(fields: [zoningProfileId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([housingType])
  @@index([city, state])
  @@map("development_packages")
}

model HousingPipelineEntry {
  id             String @id @default(uuid())
  jurisdictionId String

  // Project Identity
  projectName  String
  address      String
  parcelNumber String?
  permitId     String?

  // Housing Details
  housingType     HousingType
  totalUnits      Int
  affordableUnits Int @default(0)
  workforceUnits  Int @default(0)
  marketRateUnits Int @default(0)

  // Status
  pipelineStage       String
  estimatedCompletion  DateTime?

  // Pattern Book Tracking (Sec 210)
  usesPatternBook     Boolean @default(false)
  patternBookDesignId String?

  // Financial
  totalProjectCost Decimal? @db.Decimal(14, 2)
  publicSubsidy    Decimal? @db.Decimal(14, 2)
  grantFunding     Json?

  // Timestamps
  proposedAt            DateTime?
  entitledAt            DateTime?
  permittedAt           DateTime?
  constructionStartedAt DateTime?
  completedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jurisdiction Jurisdiction @relation("JurisdictionHousingPipeline", fields: [jurisdictionId], references: [id])

  @@index([jurisdictionId])
  @@index([pipelineStage])
  @@index([housingType])
  @@index([jurisdictionId, pipelineStage])
  @@map("housing_pipeline_entries")
}

model HousingDashboardSnapshot {
  id             String   @id @default(uuid())
  jurisdictionId String
  snapshotDate   DateTime @default(now())

  // Pipeline Metrics
  totalProjects        Int @default(0)
  totalUnitsInPipeline Int @default(0)
  unitsPermittedYTD    Int @default(0)
  unitsCompletedYTD    Int @default(0)
  affordableUnitsYTD   Int @default(0)

  // Pattern Book Metrics (Sec 210)
  patternBookAdoptions Int @default(0)
  patternBookProjects  Int @default(0)

  // Permit Metrics
  avgPermitReviewDays Float?
  permitApprovalRate  Float?

  // Detailed Data
  housingTypeBreakdown Json?
  monthlyTrend         Json?
  grantUtilization     Json?

  createdAt DateTime @default(now())

  jurisdiction Jurisdiction @relation("JurisdictionDashboardSnapshots", fields: [jurisdictionId], references: [id])

  @@index([jurisdictionId, snapshotDate])
  @@map("housing_dashboard_snapshots")
}

// Total capital with senior/mezz/equity breakdown
model CapitalStack {
  id        String @id @default(uuid())
  projectId String @unique
  orgId     String

  // Summary
  totalCapital       Decimal  @db.Decimal(14, 2)
  seniorDebt         Decimal  @db.Decimal(14, 2) @default(0)
  mezzanineDebt      Decimal  @db.Decimal(14, 2) @default(0)
  preferredEquity    Decimal  @db.Decimal(14, 2) @default(0)
  commonEquity       Decimal  @db.Decimal(14, 2) @default(0)
  grants             Decimal  @db.Decimal(14, 2) @default(0)
  otherSources       Decimal  @db.Decimal(14, 2) @default(0)

  // Leverage metrics
  loanToValue        Float?
  loanToCost         Float?
  debtServiceCoverage Float?

  // Status
  isFinalized        Boolean  @default(false)
  finalizedAt        DateTime?
  finalizedBy        String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources      CapitalSource[]
  drawSchedules DrawSchedule[]

  @@index([orgId])
  @@index([projectId])
  @@map("capital_stacks")
}

// Individual funding sources with terms
model CapitalSource {
  id            String @id @default(uuid())
  capitalStackId String

  // Source info
  sourceType    CapitalSourceType
  lenderName    String
  contactInfo   Json?     // { name, email, phone }

  // Amount
  commitmentAmount Decimal  @db.Decimal(14, 2)
  fundedAmount     Decimal  @db.Decimal(14, 2) @default(0)
  remainingAmount  Decimal  @db.Decimal(14, 2) @default(0)

  // Terms
  interestRate    Float?
  term            Int?      // Months
  amortization    Int?      // Months
  ioPeriod        Int?      // Interest-only period in months
  origFee         Float?    // Origination fee percentage
  exitFee         Float?
  prepayPenalty   String?

  // Covenants
  covenants       Json?     // Array of covenant conditions

  // Status
  status          String    @default("PENDING") // PENDING, COMMITTED, ACTIVE, REPAID, DEFAULTED
  closedAt        DateTime?
  maturityDate    DateTime?

  notes           String?
  documentUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capitalStack CapitalStack @relation(fields: [capitalStackId], references: [id], onDelete: Cascade)

  @@index([capitalStackId])
  @@index([sourceType])
  @@map("capital_sources")
}

// Draw requests with inspection and lien waiver tracking
model DrawSchedule {
  id            String @id @default(uuid())
  capitalStackId String

  // Draw info
  drawNumber    Int
  requestDate   DateTime  @default(now())
  periodStart   DateTime?
  periodEnd     DateTime?

  // Amounts
  requestedAmount  Decimal  @db.Decimal(14, 2)
  approvedAmount   Decimal? @db.Decimal(14, 2)
  retainage        Decimal? @db.Decimal(14, 2)
  netDisbursement  Decimal? @db.Decimal(14, 2)

  // Breakdown
  lineItems        Json?    // Array of { costCode, description, thisRequest, toDate, remaining }

  // Approval workflow
  status           DrawStatus @default(DRAFT)
  submittedAt      DateTime?
  reviewedAt       DateTime?
  reviewedBy       String?
  approvedAt       DateTime?
  approvedBy       String?
  fundedAt         DateTime?
  rejectionReason  String?

  // Inspection
  inspectionRequired Boolean  @default(true)
  inspectionDate     DateTime?
  inspectionResult   String?  // PASS, FAIL, CONDITIONAL
  inspectorName      String?
  inspectionReport   String?  // URL
  completionPercent  Float?   // Verified % complete

  // Lien waivers
  lienWaiversRequired Boolean @default(true)
  lienWaiversReceived Boolean @default(false)
  lienWaiverDocs      Json?   // Array of { contractor, type, url, receivedAt }

  // Supporting docs
  supportingDocs   Json?    // Array of { name, url, type }
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capitalStack CapitalStack @relation(fields: [capitalStackId], references: [id], onDelete: Cascade)

  @@index([capitalStackId])
  @@index([status])
  @@index([drawNumber])
  @@map("draw_schedules")
}

// Monthly/quarterly investor reports
model InvestorReport {
  id        String @id @default(uuid())
  projectId String
  orgId     String

  // Report info
  reportType    String    // "monthly", "quarterly", "annual", "special"
  periodStart   DateTime
  periodEnd     DateTime
  title         String?

  // Financial summary
  totalInvested     Decimal?  @db.Decimal(14, 2)
  totalSpent        Decimal?  @db.Decimal(14, 2)
  budgetRemaining   Decimal?  @db.Decimal(14, 2)
  budgetVariance    Float?    // Percentage

  // Construction progress
  overallCompletion Float?    // Percentage
  scheduleVariance  Float?    // Days ahead/behind

  // Distribution
  distributionAmount Decimal? @db.Decimal(14, 2)
  distributionDate   DateTime?
  distributionType   String?  // "return_of_capital", "preferred_return", "profit_share"

  // Content
  narrative         String?   // Written summary
  highlights        Json?     // Array of key highlights
  risks             Json?     // Array of risk items
  nextSteps         Json?     // Array of upcoming milestones

  // Attachments
  reportPdfUrl      String?
  attachments       Json?     // Array of { name, url }

  // AI generated
  aiGenerated       Boolean   @default(false)
  aiModelUsed       String?

  // Status
  status            String    @default("DRAFT") // DRAFT, REVIEW, PUBLISHED, ARCHIVED
  publishedAt       DateTime?
  publishedBy       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([orgId])
  @@index([reportType])
  @@index([periodEnd])
  @@map("investor_reports")
}

// Entitlement tracking — rezoning, variance, conditional use
model Entitlement {
  id        String @id @default(uuid())
  projectId String
  orgId     String

  // Entitlement info
  entitlementType EntitlementType
  status          EntitlementStatus @default(NOT_STARTED)
  title           String
  description     String?

  // Jurisdiction
  jurisdiction    String?   // City/county name
  department      String?   // Planning dept, zoning board, etc.
  caseNumber      String?   // Application/case number

  // Timeline
  applicationDate DateTime?
  hearingDate     DateTime?
  decisionDate    DateTime?
  expirationDate  DateTime?

  // Conditions
  conditions      Json?     // Array of approval conditions
  conditionsMet   Boolean   @default(false)

  // Costs
  applicationFee  Decimal?  @db.Decimal(10, 2)
  legalCosts      Decimal?  @db.Decimal(10, 2)
  consultantCosts Decimal?  @db.Decimal(10, 2)
  impactFees      Decimal?  @db.Decimal(14, 2)
  totalCosts      Decimal?  @db.Decimal(14, 2)

  // Documents
  applicationUrl  String?
  approvalUrl     String?
  attachments     Json?

  notes           String?
  assignedTo      String?   // User ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([orgId])
  @@index([entitlementType])
  @@index([status])
  @@map("entitlements")
}
