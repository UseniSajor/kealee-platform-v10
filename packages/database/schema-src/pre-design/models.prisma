// AI Pre-Design Domain — Models
// Domain: pre-design | Owner: concept-engine + web-main

model ProjectConceptPreDesign {
  id        String  @id @default(cuid())
  projectId String?
  intakeId  String? // links to PublicIntakeLead

  projectType PreDesignProjectType
  tier        PreDesignTier
  status      PreDesignStatus      @default(DRAFT)

  captureMode         PreDesignCaptureMode?
  captureQualityScore Int?
  confidenceScore     Float?
  complexityScore     Float?

  requiresArchitect Boolean        @default(false)
  architectRouted   Boolean        @default(false)
  executionRoute    ExecutionRoute?

  // AI outputs
  conceptSummary      Json?
  styleProfile        Json?
  budgetRange         Json?
  feasibilitySummary  Json?
  zoningSummary       Json?
  buildabilitySummary Json?
  scopeOfWork         Json?
  systemsImpact       Json?
  estimateFramework   Json?

  // Output assets
  outputImages      Json?
  outputVideoUrl    String?
  outputPdfUrl      String?
  outputJsonUrl     String?
  outputDxfUrl      String?
  outputSketchupUrl String?

  // Payment
  stripeSessionId String?
  stripePaymentId String?
  pricePaidCents  Int?

  exportPackageVersion Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  architectEngagement ArchitectEngagement?
  conceptServiceLead  ConceptServiceLead? @relation("ConceptLeadToPreDesign")

  @@index([projectId])
  @@index([intakeId])
  @@index([status])
  @@index([tier])
}

model ArchitectEngagement {
  id          String  @id @default(cuid())
  projectId   String?
  preDesignId String  @unique

  status ArchitectEngagementStatus @default(NEW)

  intakePackageUrl    String?
  intakeSummary       Json?
  targetSoftware      Json? // ["AUTOCAD","REVIT","SKETCHUP"]
  estimatedPriceRange Json?

  assignedArchitectId String?
  assignedAt          DateTime?

  notes    String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preDesign ProjectConceptPreDesign @relation(fields: [preDesignId], references: [id])

  @@index([projectId])
  @@index([status])
}
