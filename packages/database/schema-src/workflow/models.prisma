  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([performedAt])
  @@index([action])
  @@index([category])
  @@index([severity])
  @@index([createdAt])
  @@index([projectId])
  @@index([organizationId])
  @@index([userEmail])
  @@index([traceId])
  @@index([source])
}

