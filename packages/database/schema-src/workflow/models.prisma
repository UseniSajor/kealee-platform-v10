  updatedAt DateTime @updatedAt

  // Relationships
  user     User?              @relation("ComplianceAlertUser", fields: [userId], references: [id])
  contract ContractAgreement? @relation("ComplianceAlertContract", fields: [contractId], references: [id])
  resolver User?              @relation("ComplianceAlertResolver", fields: [resolvedBy], references: [id])

  @@index([alertType])
  @@index([userId])
  @@index([contractId])
  @@index([severity])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
}

model AuditLog {
  id         String          @id @default(uuid())
  entityType AuditEntityType
  entityId   String // ID of the entity
