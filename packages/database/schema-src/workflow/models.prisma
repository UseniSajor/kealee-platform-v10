model ApprovalRequest {
  id          String                @id @default(uuid())
  type        ApprovalRequestType
  subtype     String?
  status      ApprovalRequestStatus @default(DRAFT)
  priority    ApprovalPriority      @default(MEDIUM)
  title       String
  description String?
  requesterId String
  amount      Decimal?              @db.Decimal(12, 2)
  currency    String?               @default("usd")
  startDate   DateTime?
  endDate     DateTime?
  metadata    Json? // Additional metadata
  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  requester     User                 @relation("ApprovalRequestRequester", fields: [requesterId], references: [id])
  approvalSteps ApprovalStep[]
  attachments   ApprovalAttachment[]
  comments      ApprovalComment[]

  @@index([requesterId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([createdAt])
  @@index([submittedAt])
}

model ApprovalStep {
  id                String             @id @default(uuid())
  approvalRequestId String
  approverId        String
  approverRole      String?
  status            ApprovalStepStatus @default(PENDING)
  comments          String?
  order             Int // Order in approval chain
  required          Boolean            @default(true)
  approvedAt        DateTime?
  rejectedAt        DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver        User            @relation("ApprovalStepApprover", fields: [approverId], references: [id])

  @@index([approvalRequestId])
  @@index([approverId])
  @@index([status])
  @@index([order])
}

model ApprovalRule {
  id            String            @id @default(uuid())
  name          String
  type          String
  subtype       String?
  conditions    Json // Array of condition objects
  approvalChain Json // Array of approval chain steps
  priority      ApprovalPriority?
  sla           Int? // SLA in hours
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([type])
  @@index([active])
  @@index([createdAt])
}

model ApprovalAttachment {
  id                String   @id @default(uuid())
  approvalRequestId String
  fileId            String? // Reference to File model
  fileName          String
  fileUrl           String
  fileType          String
  fileSize          Int // Bytes
  uploadedAt        DateTime @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)

  @@index([approvalRequestId])
}

model ApprovalComment {
  id                String   @id @default(uuid())
  approvalRequestId String
  userId            String
  content           String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  user            User            @relation("ApprovalCommentUser", fields: [userId], references: [id])

  @@index([approvalRequestId])
  @@index([userId])
  @@index([createdAt])
}

model AutomationTask {
  id           String    @id @default(uuid())
  type         String // Task type
  status       String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  priority     String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  projectId    String?
  clientId     String?
  assignedPmId String?
  sourceApp    String? // "APP-01" through "APP-15"
  payload      Json?
  result       Json?
  error        String?   @db.Text
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  dueAt        DateTime?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
  @@index([projectId])
  @@index([sourceApp])
  @@index([assignedPmId])
  @@index([scheduledAt])
  @@map("automation_tasks")
}

model DecisionLog {
  id             String    @id @default(uuid())
  projectId      String
  type           String // BUDGET, SCHEDULE, QUALITY, SCOPE, VENDOR
  question       String    @db.Text
  context        Json?
  recommendation String    @db.Text
  confidence     Decimal   @db.Decimal(5, 4)
  reasoning      String?   @db.Text
  alternatives   Json?
  risks          Json?
  dataPoints     Json?
  accepted       Boolean?
  acceptedAt     DateTime?
  feedback       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([createdAt])
  @@map("decision_logs")
}

// APP-15: Automation Event Bus
model AutomationEvent {
  id          String   @id @default(uuid())
  eventType   String
  sourceApp   String // "APP-01" through "APP-15"
  projectId   String?
  payload     Json
  processedBy String[]
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([sourceApp])
  @@index([projectId])
  @@index([createdAt])
  @@map("automation_events")
}

// APP-14: Decision Queue for PM Actions
model DecisionQueue {
  id        String @id @default(uuid())
  projectId String
  pmId      String

  type  String // bid_award, change_order, payment_release, schedule_change
  title String

  context          Json
  aiRecommendation String?  @db.Text
  aiConfidence     Decimal? @db.Decimal(5, 4)
  options          Json

  decision  String? // approved, rejected, deferred
  decidedAt DateTime?
  decidedBy String?
  reasoning String?   @db.Text

  createdAt DateTime @default(now())

  @@index([pmId])
  @@index([projectId])
  @@index([type])
  @@index([decision])
  @@map("decision_queue")
}

model AutonomousActionLog {
  id            String             @id @default(uuid())
  projectId     String
  appSource     String // e.g. "APP-03", "APP-01", "APP-07"
  actionType    String // e.g. "change_order_approve", "bid_reject", "budget_acknowledge"
  description   String
  decision      AutonomousDecision
  reasoning     String             @db.Text
  data          Json? // Action-specific data (amounts, IDs, etc.)
  confidence    Int                @default(0) // 0-100
  autonomyLevel Int // The autonomy level that was active when this action was taken

  // Review tracking
  reviewedByPM Boolean   @default(false)
  reviewedAt   DateTime?
  revertedAt   DateTime?
  revertedBy   String?

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([appSource])
  @@index([decision])
  @@index([reviewedByPM])
  @@map("autonomous_action_logs")
}
