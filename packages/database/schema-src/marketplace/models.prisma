// Marketplace Fee Configuration (per SOP v2)
model MarketplaceFeeConfig {
  id String @id @default(uuid())

  // Fee Rates
  standardPlatformFee Decimal @default(0.03) @db.Decimal(5, 4) // 3%
  packageCDFee        Decimal @default(0) @db.Decimal(5, 4) // 0% for C/D
  escrowFeeStandard   Decimal @default(0.01) @db.Decimal(5, 4) // 1% (max $500)
  escrowFeeReduced    Decimal @default(0.005) @db.Decimal(5, 4) // 0.5% for C/D
  escrowMaxFee        Decimal @default(500) @db.Decimal(10, 2)

  // Bid Rules
  maxBidOverSRP Decimal @default(0.03) @db.Decimal(5, 4) // 3% max over SRP

  // Effective Dates
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([effectiveFrom])
  @@map("marketplace_fee_config")
}

