// PM Service Subscription (m-ops-services -> executed by os-pm)
model PMServiceSubscription {
  id          String        @id @default(uuid())
  clientId    String
  orgId       String?
  packageTier PMPackageTier

  // Pricing
  monthlyPrice          Decimal @db.Decimal(10, 2)
  hoursPerWeek          Int // 5-10, 15-20, 30-40, 40+
  maxConcurrentProjects Int // 1, 3, unlimited, portfolio

  // Status
  status       SubscriptionStatus @default(PENDING_PAYMENT)
  startDate    DateTime?
  endDate      DateTime?
  trialEndsAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  // Stripe
  stripeSubscriptionId String?
  stripePriceId        String?

  // Support Level
  supportLevel String @default("EMAIL") // EMAIL, PRIORITY, 24_7
  responseTime Int    @default(48) // hours

  // Features based on tier
  includesPermitMgmt   Boolean @default(false) // Package C/D only
  includesSiteVisits   Boolean @default(false) // Package C/D only
  siteVisitsPerMonth   Int     @default(0) // 0, 2-4, 4-8
  marketplaceFeeWaiver Boolean @default(false) // Package C/D = 0% fees
  escrowFeeReduction   Boolean @default(false) // Package C/D = 0.5%

  // PM Module v4 tier configuration
  maxProjectValue   BigInt @default(50000000) // Max single project value in cents
  maxPortfolioValue BigInt @default(100000000) // Max total portfolio value in cents
  hoursPerWeekMin   Int    @default(5)
  hoursPerWeekMax   Int    @default(10)
  tierLevel         String @default("A") // A, B, C, D

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation("PMServiceSubscriptionClient", fields: [clientId], references: [id], onDelete: Cascade)

  // Assigned PM for execution (os-pm)
  assignedPMs ProjectManager[] @relation("PMServiceAssignments")

  @@index([clientId])
  @@index([status])
  @@index([packageTier])
  @@map("pm_service_subscriptions")
}

