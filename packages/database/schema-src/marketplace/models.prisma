  setAsideType    String?
  solicitationNum String?
  awardDeadline   DateTime?
  isActive        Boolean                  @default(true)
  isFeatured      Boolean                  @default(false)
  postedById      String
  postedBy        User                     @relation("OpportunityListingPostedBy", fields: [postedById], references: [id])
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  applications    OpportunityApplication[]

  @@index([categoryId])
  @@index([postedById])
  @@index([isActive])
  @@index([tradeType])
  @@map("opportunity_listings")
}

model OpportunityApplication {
  id          String             @id @default(cuid())
  listingId   String
  listing     OpportunityListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  applicantId String
  applicant   User               @relation("OpportunityApplicationApplicant", fields: [applicantId], references: [id])
  status      String             @default("pending")
  resumeUrl   String?
  coverNote   String?            @db.Text
  appliedAt   DateTime           @default(now())

  @@index([listingId])
  @@index([applicantId])
  @@index([status])
  @@map("opportunity_applications")
}

model InterestListSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String
  tradeType String?
  location  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([role])
  @@map("interest_list_signups")
}

model ContractorLicenseRegistry {
  id           String    @id @default(cuid())
  state        String
  licenseNum   String    @unique
  companyName  String
  licenseType  String
  licenseClass String?
  status       String
  expiresAt    DateTime?
  issuedAt     DateTime?
  city         String?
  county       String?
  zip          String?
  phone        String?
  lastSynced   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([licenseNum])
  @@index([state, status])
  @@index([companyName])
  @@map("contractor_license_registry")
}

// Tracks which licenses have been claimed by a Kealee user account
model ContractorVerification {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation("ContractorVerificationUser", fields: [userId], references: [id])
  state          String
  licenseNum     String
  licenseType    String
  licenseClass   String?
  companyName    String
  status         String
  expiresAt      DateTime?
  verifiedAt     DateTime  @default(now())
  lastChecked    DateTime  @default(now())
  rawApiResponse Json?

  @@index([licenseNum])
  @@map("contractor_verifications")
}
