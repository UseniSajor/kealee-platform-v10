// MARKETPLACE — Models
// Auto-generated from schema splitter

model Lead {
  id                 String     @id @default(uuid())
  projectId          String?
  category           String
  description        String
  estimatedValue     Decimal?
  budget             Decimal?
  location           String
  city               String?
  state              String?
  stage              LeadStatus @default(OPEN)
  status             String? // Alternative status field
  distributedTo      String[] // Array of profile IDs
  assignedSalesRepId String?
  lostAt             DateTime?
  lostReason         String?
  stageChangedAt     DateTime?
  srp                Decimal?

  // Marketplace pricing (set by estimating engine)
  suggestedPrice Decimal? @db.Decimal(12, 2)
  priceRange     Json? // { "low": number, "mid": number, "high": number }
  projectType    String? // "kitchen_renovation", "bathroom_remodel", etc.
  sqft           Decimal? @db.Decimal(10, 2)
  qualityTier    String? // "low", "mid", "high"

  // ── Rotating assignment fields (lead-assignment.prisma) ──────────────────
  /// How this lead was sourced — determines routing path (SPONSORED_AD bypasses
  /// the queue; PLATFORM_SERVICE uses fair rotation; OWNER_INVITED gates on
  /// registration).
  sourceType         LeadSourceType    @default(PLATFORM_SERVICE)
  /// Which professional discipline this lead is for.  Drives queue selection.
  professionalType   ProfessionalType?
  /// Set only when sourceType = OWNER_INVITED.  The specific MarketplaceProfile
  /// the owner wants to work with.  Must be a registered Kealee professional.
  invitedProfileId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project?               @relation(fields: [projectId], references: [id])
  quotes         Quote[]
  quickEstimates QuickEstimate[]
  /// All assignment offers ever made for this lead (one per rotation attempt)
  assignments    ProfessionalAssignment[] @relation("LeadAssignments")

  @@index([projectId])
  @@index([stage])
  @@index([status])
  // ── Performance: Compound indexes for marketplace queries ──
  @@index([stage, createdAt]) // Lead pipeline: filter by stage + sort by time
  @@index([status, createdAt]) // Lead listing with time-based pagination
  @@index([sourceType])
  @@index([professionalType, stage]) // Queue routing: find active leads by discipline
}

model MarketplaceProfile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  businessName         String
  description          String?
  serviceArea          Json?
  specialties          String[]
  rating               Float?    @default(0)
  reviewCount          Int       @default(0)
  projectsCompleted    Int       @default(0)
  performanceScore     Int?
  verified             Boolean   @default(false)
  verifiedAt           DateTime?
  subscriptionTier     String?
  leadCredits          Int       @default(0)
  acceptingLeads       Boolean   @default(true)
  maxPipelineValue     Decimal?
  currentPipelineValue Decimal?  @default(0)
  lastWonAt            DateTime?

  // ── Rotating assignment fields (lead-assignment.prisma) ──────────────────
  /// Primary professional discipline for this profile.  A professional who
  /// works in multiple disciplines has multiple RotationQueueEntry rows.
  professionalType     ProfessionalType?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user      User        @relation("MarketplaceProfileUser", fields: [userId], references: [id])
  portfolio Portfolio[]
  quotes    Quote[]
  /// All assignment offers sent to this professional
  assignments  ProfessionalAssignment[] @relation("ProfessionalAssignments")
  /// Queue entries — one per professional discipline
  queueEntries RotationQueueEntry[]     @relation("RotationQueueEntries")

  @@index([verified])
  @@index([subscriptionTier])
  @@index([acceptingLeads])
  @@index([professionalType])
}

model Portfolio {
  id          String    @id @default(uuid())
  profileId   String
  projectName String
  description String?
  category    String
  imageUrls   String[]
  completedAt DateTime?

  profile MarketplaceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Quote {
  id          String   @id @default(uuid())
  leadId      String
  profileId   String
  amount      Decimal
  timeline    String?
  details     String?
  status      String // SUBMITTED, ACCEPTED, REJECTED
  submittedAt DateTime @default(now())

  lead    Lead               @relation(fields: [leadId], references: [id])
  profile MarketplaceProfile @relation(fields: [profileId], references: [id])

  @@index([leadId])
  @@index([profileId])
  @@index([status])
}

model AssignmentRequest {
  id        String   @id @default(uuid())
  clientId  String
  pmUserId  String
  status    String   @default("PENDING")
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([pmUserId])
  @@index([status])
}

// Contractor Profile - Contractors in the marketplace system
model ContractorProfile {
  id     String @id @default(uuid())
  userId String @unique

  // Business Info
  businessName    String
  licenseNumber   String?
  insuranceInfo   Json?
  yearsInBusiness Int?

  // Contact
  email   String
  phone   String?
  address String?
  city    String?
  state   String?
  zipCode String?

  // Profile
  description String?  @db.Text
  specialties String[]
  serviceArea Json? // GeoJSON or list of zip codes

  // Ratings & Performance
  rating            Decimal? @default(0) @db.Decimal(3, 2)
  reviewCount       Int      @default(0)
  projectsCompleted Int      @default(0)

  // Verification
  isVerified      Boolean   @default(false)
  verifiedAt      DateTime?
  backgroundCheck Boolean   @default(false)

  // Status
  isActive      Boolean @default(true)
  acceptingBids Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  user User            @relation("ContractorProfileUser", fields: [userId], references: [id])
  bids ContractorBid[]

  @@index([userId])
  @@index([isVerified])
  @@index([isActive])
  @@index([acceptingBids])
}

// Contractor Bid - Bids from marketplace
model ContractorBid {
  id                  String @id @default(uuid())
  preConProjectId     String
  contractorProfileId String

  // Bid Details
  bidAmount         Decimal   @db.Decimal(12, 2)
  proposedTimeline  Int // days
  proposedStartDate DateTime?

  // Breakdown
  laborCost    Decimal? @db.Decimal(12, 2)
  materialCost Decimal? @db.Decimal(12, 2)
  overheadCost Decimal? @db.Decimal(12, 2)
  profitMargin Decimal? @db.Decimal(5, 2) // percentage

  // Proposal
  coverLetter    String?  @db.Text
  proposalDocUrl String?
  portfolioUrls  String[]
  references     Json? // Array of references

  // Status
  status    String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SHORTLISTED, AWARDED, REJECTED, WITHDRAWN
  isAwarded Boolean   @default(false)
  awardedAt DateTime?

  // Contractor Info (denormalized for display)
  contractorName    String?
  contractorRating  Decimal? @db.Decimal(3, 2)
  contractorReviews Int?

  // Timestamps
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?

  // Relationships
  preConProject     PreConProject     @relation(fields: [preConProjectId], references: [id], onDelete: Cascade)
  contractorProfile ContractorProfile @relation(fields: [contractorProfileId], references: [id])

  @@index([preConProjectId])
  @@index([contractorProfileId])
  @@index([status])
  @@index([isAwarded])
}

model Contractor {
