// PM — PROCUREMENT
// Domain: pm | Owner: OS-PM service

model PurchaseOrder {
  id          String              @id @default(uuid())
  projectId   String
  vendorId    String?
  status      PurchaseOrderStatus @default(DRAFT)
  amountCents Int
  description String?
  costCodeId  String?
  poNumber    String?

  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?
  approvedBy String?
  executedAt DateTime?

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  costCode CostCode? @relation(fields: [costCodeId], references: [id])
  bills    Bill[]

  @@index([projectId])
  @@index([status])
  @@index([vendorId])
  @@map("purchase_orders")
}

model Bill {
  id              String     @id @default(uuid())
  projectId       String
  purchaseOrderId String?
  vendorId        String?
  amountCents     Int
  status          BillStatus @default(DRAFT)
  billNumber      String?
  dueDate         DateTime?
  description     String?
  lineItems       Json?

  createdBy  String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  approvedAt DateTime?
  approvedBy String?
  paidAt     DateTime?

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([projectId])
  @@index([purchaseOrderId])
  @@index([status])
  @@map("bills")
}

model RFQ {
  id           String    @id @default(uuid())
  projectId    String
  name         String
  description  String?
  status       RFQStatus @default(DRAFT)
  dueDate      DateTime?
  requirements Json?

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([createdBy])
  @@map("rfqs")
}

model Delivery {
  id              String         @id @default(uuid())
  projectId       String
  supplierId      String
  purchaseOrderId String?
  status          DeliveryStatus @default(SCHEDULED)
  trackingNumber  String?
  scheduledDate   DateTime?
  deliveredDate   DateTime?
  receivedDate    DateTime?
  confirmedDate   DateTime?
  podDocumentId   String?
  notes           String?
  metadata        Json?

  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([supplierId])
  @@index([status])
  @@index([scheduledDate])
  @@map("deliveries")
}
