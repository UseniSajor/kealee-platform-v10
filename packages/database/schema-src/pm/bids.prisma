// PM — BIDS
// Domain: pm | Owner: OS-PM service

model BidRequest {
  id              String   @id @default(uuid())
  projectId       String
  title           String?
  trades          String[]
  scope           Json?
  requirements    Json?
  estimatedBudget Decimal? @db.Decimal(12, 2)
  deadline        DateTime
  status          String   @default("OPEN") // OPEN, EVALUATING, AWARDED, CLOSED, CANCELLED

  // Matching results
  matchResults Json? // Results from contractor matching

  // Awarded info
  awardedContractorId String?
  awardedSubmissionId String?
  awardedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  awardedContractor Contractor?     @relation("AwardedContractor", fields: [awardedContractorId], references: [id])
  bidInvitations    BidInvitation[]
  bidSubmissions    BidSubmission[]

  @@index([projectId])
  @@index([status])
  @@index([deadline])
  @@map("bid_requests")
}

model BidInvitation {
  id            String    @id @default(uuid())
  bidRequestId  String
  contractorId  String
  status        String    @default("PENDING") // PENDING, VIEWED, SUBMITTED, DECLINED, EXPIRED
  sentAt        DateTime  @default(now())
  viewedAt      DateTime?
  respondedAt   DateTime?
  declineReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest BidRequest @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  contractor Contractor @relation(fields: [contractorId], references: [id])

  @@unique([bidRequestId, contractorId])
  @@index([bidRequestId])
  @@index([contractorId])
  @@index([status])
  @@map("bid_invitations")
}

model BidSubmission {
  id           String    @id @default(uuid())
  bidRequestId String
  invitationId String?
  contractorId String
  amount       Decimal   @db.Decimal(12, 2)
  timeline     Json? // Proposed timeline/schedule
  scope        Json? // Detailed scope breakdown
  alternates   Json? // Alternative pricing options
  exclusions   String[]
  assumptions  String[]
  validUntil   DateTime?

  // Analysis
  score          Int? // 0-100 AI score
  recommendation String? // AI recommendation
  analysisData   Json? // Detailed analysis

  // Status
  status         String    @default("SUBMITTED") // SUBMITTED, UNDER_REVIEW, SHORTLISTED, AWARDED, REJECTED, WITHDRAWN
  submittedAt    DateTime  @default(now())
  withdrawnAt    DateTime?
  withdrawReason String?

  // ── Canonical Engagement FK (additive, nullable) ──────────────────────────
  engagementId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bidRequest BidRequest  @relation(fields: [bidRequestId], references: [id], onDelete: Cascade)
  contractor Contractor  @relation(fields: [contractorId], references: [id])
  engagement Engagement? @relation("EngagementBidSubmissions", fields: [engagementId], references: [id], onDelete: SetNull)

  @@index([bidRequestId])
  @@index([contractorId])
  @@index([status])
  @@index([score])
  @@index([status, createdAt])
  @@index([engagementId])
  @@map("bid_submissions")
}

// APP-01: Bid Evaluation
model BidEvaluation {
  id        String @id @default(uuid())
  projectId String
  trade     String
  status    String @default("collecting")

  // Scoring weights
  weightPrice        Decimal @default(0.30) @db.Decimal(3, 2)
  weightTimeline     Decimal @default(0.25) @db.Decimal(3, 2)
  weightQuality      Decimal @default(0.25) @db.Decimal(3, 2)
  weightProximity    Decimal @default(0.10) @db.Decimal(3, 2)
  weightAvailability Decimal @default(0.10) @db.Decimal(3, 2)

  dueDate          DateTime?
  selectedBidId    String?
  aiRecommendation String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bids    Bid[]

  @@index([projectId])
  @@index([status])
  @@map("bid_evaluations")
}

// APP-01: Individual Bid within an Evaluation
model Bid {
  id           String @id @default(uuid())
  evaluationId String
  contractorId String

  amount   Decimal @db.Decimal(12, 2)
  timeline Int // days

  qualityScore      Decimal? @db.Decimal(5, 2)
  proximityScore    Decimal? @db.Decimal(5, 2)
  availabilityScore Decimal? @db.Decimal(5, 2)
  totalScore        Decimal? @db.Decimal(5, 2)

  rank   Int?
  notes  String? @db.Text
  scope  String? @db.Text
  status String  @default("submitted")

  createdAt DateTime @default(now())

  evaluation BidEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@index([evaluationId])
  @@index([contractorId])
  @@index([totalScore])
  @@map("bids")
}

model OpportunityBid {
  id              String        @id @default(cuid())

  // Source & identification
  source          BidSource
  externalId      String?
  sourceUrl       String?

  // Project details
  projectName     String
  description     String?       @db.Text
  scope           String?
  location        String?
  city            String?
  state           String?       @default("MD")
  county          String?

  // Owner / GC info
  ownerName       String?
  gcName          String?
  gcContactName   String?
  gcContactEmail  String?
  gcContactPhone  String?

  // Financials
  estimatedValue  Decimal?      @db.Decimal(12, 2)
  bidAmount       Decimal?      @db.Decimal(12, 2)
  bondRequired    Boolean?      @default(false)
  bondAmount      Decimal?      @db.Decimal(12, 2)

  // Deadlines & dates
  prebidDate      DateTime?
  prebidLocation  String?
  questionsDeadline DateTime?
  bidDeadline     DateTime
  projectStart    DateTime?
  projectEnd      DateTime?

  // Status & tracking
  status          BidStatus     @default(DISCOVERED)
  priority        String?       @default("MEDIUM")
  winProbability  Int?

  // AI Analysis
  aiScore         Int?
  aiNotes         String?       @db.Text
  matchReasons    String[]
  keyRequirements String[]
  risks           String[]

  // Internal tracking
  assignedTo      String?
  internalNotes   String?       @db.Text
  decisionNotes   String?       @db.Text

  // Email tracking
  emailThreadId   String?
  lastEmailDate   DateTime?

  // Timestamps
  discoveredAt    DateTime      @default(now())
  submittedAt     DateTime?
  decisionDate    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  documents       OpportunityBidDocument[]
  checklist       OpportunityBidChecklist[]
  subQuotes       SubcontractorQuote[]
  activities      OpportunityBidActivity[]

  @@index([status])
  @@index([bidDeadline])
  @@index([source])
  @@index([state])
  @@index([assignedTo])
  @@index([discoveredAt])
  @@map("opportunity_bids")
}

model OpportunityBidDocument {
  id          String   @id @default(cuid())
  bidId       String
  name        String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  category    String?
  version     Int      @default(1)
  uploadedAt  DateTime @default(now())

  bid OpportunityBid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([category])
  @@map("opportunity_bid_documents")
}

model OpportunityBidChecklist {
  id          String   @id @default(cuid())
  bidId       String
  item        String
  category    String?
  completed   Boolean  @default(false)
  completedAt DateTime?
  completedBy String?
  notes       String?  @db.Text
  order       Int      @default(0)

  bid OpportunityBid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([completed])
  @@map("opportunity_bid_checklists")
}

// Renamed from BidActivity to avoid collision with Windows BidActivity
model OpportunityBidActivity {
  id          String   @id @default(cuid())
  bidId       String
  type        String
  description String
  metadata    Json?
  createdBy   String?
  createdAt   DateTime @default(now())

  bid OpportunityBid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([createdAt])
  @@map("opportunity_bid_activities")
}

model BidOpportunity {
  id             String  @id @default(uuid())
  organizationId String?

  // Source tracking
  source    BidSource @default(MANUAL)
  sourceId  String?
  sourceUrl String?

  // Project details
  projectName   String
  projectNumber String?
  description   String? @db.Text
  scope         String?
  location      String?
  county        String?
  state         String? @default("MD")

  // Owner / GC info
  ownerName    String?
  gcName       String?
  contactName  String?
  contactEmail String?
  contactPhone String?

  // Financials
  estimatedValue Decimal? @db.Decimal(14, 2)
  bidBond        Decimal? @db.Decimal(14, 2)
  bidBondPercent Decimal? @db.Decimal(5, 2)

  // Key dates
  dueDate         DateTime?
  prebidDate      DateTime?
  prebidLocation  String?
  prebidMandatory Boolean   @default(false)
  awardDate       DateTime?
  startDate       DateTime?

  // Status tracking
  status     BidPipelineStatus @default(NEW)
  priority   BidPriority       @default(MEDIUM)
  assignedTo String?
  confidence Int?

  // Classification flags
  isGovernment   Boolean  @default(false)
  isFederal      Boolean  @default(false)
  isStateLocal   Boolean  @default(false)
  requiresMBE    Boolean  @default(false)
  requiresDBE    Boolean  @default(false)
  mbeGoalPercent Decimal? @db.Decimal(5, 2)
  dbeGoalPercent Decimal? @db.Decimal(5, 2)
  prevailingWage Boolean  @default(false)
  bondRequired   Boolean  @default(false)

  // Evaluation scores (0-100)
  scopeScore    Int?
  locationScore Int?
  valueScore    Int?
  mbeScore      Int?
  overallScore  Int?

  // AI Analysis
  aiAnalysis   Json?
  aiStrategy   Json?
  aiAnalyzedAt DateTime?

  // Notes
  notes         String? @db.Text
  internalNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  checklist   BidChecklistItem[]
  documents   BidDocument[]
  activities  BidActivity[]
  subRequests BidSubRequest[]

  @@index([status])
  @@index([source])
  @@index([priority])
  @@index([dueDate])
  @@index([organizationId])
  @@index([status, priority])
  @@index([source, status])
  @@index([assignedTo])
  @@map("bid_opportunities")
}

model BidChecklistItem {
  id          String             @id @default(uuid())
  bidId       String
  step        Int
  title       String
  description String?
  status      BidChecklistStatus @default(PENDING)
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  completedBy String?
  notes       String?            @db.Text
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  bid BidOpportunity @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, step])
  @@index([bidId])
  @@index([bidId, status])
  @@map("bid_checklist_items")
}

model BidDocument {
  id            String          @id @default(uuid())
  bidId         String
  type          BidDocumentType @default(OTHER)
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  uploadedBy    String?
  notes         String?
  metadata      Json?
  extractedText String?         @db.Text
  processedAt   DateTime?
  createdAt     DateTime        @default(now())

  bid BidOpportunity @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([bidId, type])
  @@map("bid_documents")
}

model BidActivity {
  id        String   @id @default(uuid())
  bidId     String
  action    String
  actor     String?
  details   Json?
  createdAt DateTime @default(now())

  bid BidOpportunity @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([bidId, createdAt])
  @@map("bid_activities")
}

model BidSubRequest {
  id              String              @id @default(uuid())
  bidId           String
  subName         String
  trade           String
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  requestedAmount Decimal?            @db.Decimal(14, 2)
  quotedAmount    Decimal?            @db.Decimal(14, 2)
  status          BidSubRequestStatus @default(PENDING)
  sentAt          DateTime?
  dueDate         DateTime?
  receivedAt      DateTime?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  bid BidOpportunity @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([bidId, status])
  @@map("bid_sub_requests")
}

// Chunked document embeddings for BidOpportunity (Windows pipeline)
model BidEmbedding {
  id         String   @id @default(uuid())
  bidId      String
  documentId String?
  content    String   @db.Text
  embedding  Float[]
  metadata   Json?
  chunkIndex Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([bidId])
  @@map("bid_embeddings")
}

model BidSimilarity {
  id              String   @id @default(cuid())
  sourceBidId     String
  similarBidId    String
  similarity      Decimal  @db.Decimal(5, 4)
  createdAt       DateTime @default(now())

  @@unique([sourceBidId, similarBidId])
  @@index([sourceBidId])
  @@index([similarity])
  @@map("bid_similarities")
}

model BidScanLog {
  id          String    @id @default(uuid())
  source      BidSource
  runType     String
  status      String
  bidsFound   Int       @default(0)
  bidsCreated Int       @default(0)
  bidsSkipped Int       @default(0)
  errors      Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  details     Json?

  @@index([source])
  @@index([startedAt])
  @@map("bid_scan_logs")
}
