// PM — BUDGET
// Domain: pm | Owner: OS-PM service

model BudgetEntry {
  id              String   @id @default(uuid())
  projectId       String
  category        String // LABOR, MATERIAL, EQUIPMENT, SUBCONTRACTOR, etc.
  description     String
  amount          Decimal? @db.Decimal(12, 2) // For simpler aggregation
  estimatedAmount Decimal  @db.Decimal(12, 2)
  actualAmount    Decimal  @default(0) @db.Decimal(12, 2)
  variance        Decimal  @default(0) @db.Decimal(12, 2)
  status          String   @default("ACTIVE") // ACTIVE, CLOSED, OVER_BUDGET

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([category])
  @@map("budget_entries")
}

model BudgetLine {
  id              String  @id @default(uuid())
  projectId       String
  category        String // LABOR, MATERIALS, EQUIPMENT, SUBCONTRACTOR, OVERHEAD, CONTINGENCY
  subcategory     String?
  description     String
  budgetedAmount  Decimal @db.Decimal(14, 2)
  committedAmount Decimal @default(0) @db.Decimal(14, 2)
  actualAmount    Decimal @default(0) @db.Decimal(14, 2)
  variance        Decimal @default(0) @db.Decimal(14, 2)
  variancePercent Decimal @default(0) @db.Decimal(5, 2)
  status          String  @default("ON_TRACK") // ON_TRACK, AT_RISK, OVER_BUDGET
  notes           String?
  sortOrder       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([category])
  @@index([status])
  @@map("budget_lines")
}

model BudgetSnapshot {
  id              String   @id @default(uuid())
  projectId       String
  snapshotDate    DateTime @default(now())
  totalBudget     Decimal  @db.Decimal(14, 2)
  totalCommitted  Decimal  @db.Decimal(14, 2)
  totalActual     Decimal  @db.Decimal(14, 2)
  totalVariance   Decimal  @db.Decimal(14, 2)
  percentComplete Decimal  @db.Decimal(5, 2)
  forecast        Decimal? @db.Decimal(14, 2)
  categories      Json // Breakdown by category
  notes           String?

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([snapshotDate])
  // ── Performance: Compound index for budget chart queries ──
  @@index([projectId, snapshotDate]) // Budget chart: project snapshots over time
  @@map("budget_snapshots")
}

model BudgetAlert {
  id             String    @id @default(uuid())
  projectId      String
  type           String // THRESHOLD_WARNING, OVER_BUDGET, FORECAST_RISK, CASH_FLOW
  severity       String    @default("WARNING") // INFO, WARNING, CRITICAL
  category       String?
  title          String
  message        String    @db.Text
  threshold      Decimal?  @db.Decimal(5, 2) // Percentage threshold that triggered alert
  currentValue   Decimal?  @db.Decimal(14, 2)
  budgetedValue  Decimal?  @db.Decimal(14, 2)
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  resolvedAt     DateTime?
  resolution     String?

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([type])
  @@index([severity])
  @@index([acknowledged])
  @@map("budget_alerts")
}

model BudgetItem {
  id              String         @id @default(cuid())
  projectId       String
  organizationId  String
  category        BudgetCategory
  description     String
  estimatedCost   Decimal        @db.Decimal(12, 2)
  actualCost      Decimal        @default(0) @db.Decimal(12, 2)
  committedCost   Decimal        @default(0) @db.Decimal(12, 2)
  varianceAmount  Decimal        @default(0) @db.Decimal(12, 2)
  variancePercent Decimal        @default(0) @db.Decimal(5, 2)
  estimateId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project      Project             @relation("ProjectBudgetItems", fields: [projectId], references: [id], onDelete: Cascade)
  transactions BudgetTransaction[]

  @@index([projectId])
  @@index([organizationId])
  @@index([category])
  @@map("budget_items")
}

model BudgetTransaction {
  id             String   @id @default(cuid())
  budgetItemId   String
  projectId      String
  organizationId String
  amount         Decimal  @db.Decimal(12, 2)
  type           String // ESTIMATED, COMMITTED, ACTUAL, ADJUSTMENT
  description    String?
  referenceType  String? // CHANGE_ORDER, PAYMENT, MANUAL
  referenceId    String?
  createdAt      DateTime @default(now())

  budgetItem BudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@index([budgetItemId])
  @@index([projectId])
  @@index([type])
  @@map("budget_transactions")
}

model CostCode {
  id          String  @id @default(uuid())
  code        String  @unique // CSI MasterFormat or custom
  name        String
  description String?
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([code])
  @@index([category])
  @@map("cost_codes")
}
