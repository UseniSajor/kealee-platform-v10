// PM — INSPECTIONS
// Domain: pm | Owner: OS-PM service

model Inspection {
  id               String  @id @default(uuid())
  inspectionNumber String? @unique
  permitId         String
  projectId        String
  jurisdictionId   String

  inspectionType InspectionType
  description    String?
  phaseRequired  String? // Construction phase

  // Preparation (Client-Side)
  checklistId     String?
  sitePhotos      String[] // Pre-inspection photos
  pmPreInspection DateTime? // PM verification date
  readyToSchedule Boolean   @default(false)
  notes           String? // Contractor notes about readiness

  // Scheduling (Jurisdiction-Side)
  requestedDate         DateTime
  requestedBy           String // User ID
  scheduledDate         DateTime?
  scheduledWindow       String? // "8:00-12:00", "1:00-5:00"
  inspectorId           String? // Jurisdiction inspector
  jurisdictionRefNumber String?

  // Remote Inspection (Dual-Side Extension)
  isRemote          Boolean @default(false)
  videoSessionId    String?
  videoRecordingUrl String?
  liveStreamUrl     String?
  aiVideoAnalysis   Json?

  // Results
  result         InspectionResult?
  inspectorNotes String?
  deficiencies   Json? // Array of deficiencies found
  passedItems    Int?
  failedItems    Int?
  totalItems     Int?
  completedAt    DateTime?

  // Reinspection Tracking
  parentInspectionId String?
  isReinspection     Boolean @default(false)

  // Relationships
  permit               Permit                @relation(fields: [permitId], references: [id])
  project              Project               @relation(fields: [projectId], references: [id])
  jurisdiction         Jurisdiction          @relation(fields: [jurisdictionId], references: [id])
  inspector            JurisdictionStaff?    @relation(fields: [inspectorId], references: [id])
  remoteSession        RemoteInspection?
  inspectionAssignment InspectionAssignment?

  // Command Center relations
  preparationItems InspectionPreparationItem[]
  findings         InspectionFinding[]

  // Phase milestone relations
  phaseMilestones PhaseMilestone[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permitId])
  @@index([projectId])
  @@index([jurisdictionId])
  @@index([scheduledDate])
  @@index([inspectorId])
  @@index([result])
}

model Issue {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String?   @db.Text
  type        String // DEFECT, DELAY, QUALITY, SAFETY, OTHER
  severity    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedTo  String?
  dueDate     DateTime?
  resolvedAt  DateTime?
  resolution  String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([severity])
  @@map("issues")
}

model QualityIssue {
  id           String    @id @default(uuid())
  projectId    String
  type         String // WORKMANSHIP, MATERIAL, SAFETY, CODE_VIOLATION
  severity     String    @default("MODERATE") // MINOR, MODERATE, MAJOR, CRITICAL
  status       String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, VERIFIED
  title        String
  description  String    @db.Text
  location     String?
  detectedBy   String // USER, AI_PHOTO_ANALYSIS, INSPECTION
  photos       String[]
  aiAnalysis   Json?
  aiConfidence Decimal?  @db.Decimal(5, 4)
  assignedTo   String?
  dueDate      DateTime?
  resolvedAt   DateTime?
  resolution   String?   @db.Text
  verifiedAt   DateTime?
  verifiedBy   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([severity])
  @@map("quality_issues")
}

model InspectionPreparationItem {
  id           String    @id @default(uuid())
  inspectionId String
  item         String
  description  String?
  required     Boolean   @default(true)
  completed    Boolean   @default(false)
  completedAt  DateTime?
  completedBy  String?
  notes        String?
  sortOrder    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@map("inspection_preparation_items")
}

model InspectionFinding {
  id             String    @id @default(uuid())
  inspectionId   String
  type           String // DEFICIENCY, OBSERVATION, RECOMMENDATION
  severity       String    @default("MODERATE") // MINOR, MODERATE, MAJOR, CRITICAL
  code           String? // Code reference
  description    String    @db.Text
  location       String?
  photos         String[]
  status         String    @default("OPEN") // OPEN, ADDRESSED, VERIFIED, WAIVED
  requiredAction String?   @db.Text
  dueDate        DateTime?
  resolvedAt     DateTime?
  resolution     String?   @db.Text
  verifiedAt     DateTime?
  verifiedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@index([status])
  @@index([severity])
  @@map("inspection_findings")
}

// APP-13: QA Inspection Result (Photo AI Analysis)
model QAInspectionResult {
  id          String  @id @default(uuid())
  projectId   String
  siteVisitId String?

  photoUrl       String
  analysisResult Json
  issuesFound    Json?
  overallScore   Decimal? @db.Decimal(5, 2)
  reviewedByPm   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([siteVisitId])
  @@map("qa_inspection_results")
}
