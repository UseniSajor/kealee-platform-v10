// PM — ESTIMATION
// Domain: pm | Owner: OS-PM service

model CostDatabase {
  id             String           @id @default(uuid())
  organizationId String?
  name           String
  description    String?
  region         String
  type           CostDatabaseType @default(CUSTOM)
  version        String           @default("1.0")
  effectiveDate  DateTime         @default(now())
  expirationDate DateTime?
  source         String?
  isActive       Boolean          @default(true)
  isDefault      Boolean          @default(false)
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // ── 3-Tier Cost Book Architecture ─────────────────────────────────
  tier         CostDatabaseTier     @default(ORGANIZATION)
  visibility   CostDataVisibility   @default(ORG_ONLY)
  reviewStatus CostDataReviewStatus @default(DRAFT)

  // Submission & Review tracking
  submittedById String? // User who uploaded / created
  reviewedById  String? // Kealee admin who approved/rejected
  reviewedAt    DateTime?
  reviewNotes   String?   @db.Text

  // Classification for organization
  tradeCategory String? // e.g. "concrete", "steel", "electrical"
  projectType   String? // e.g. "residential", "commercial", "industrial"
  methodology   String? // e.g. "tilt-up", "stick-frame", "CMU"

  // Standard book flags (Tier 1)
  isStandard Boolean @default(false) // true = Kealee base/standard cost book

  materials      MaterialCost[]
  laborRates     LaborRate[]
  equipmentRates EquipmentRate[]
  assemblies     Assembly[]
  estimates      Estimate[]
  importJobs     CostCodeImportJob[]
  reviews        CostDataReview[]

  submittedBy User? @relation("CostDatabaseSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User? @relation("CostDatabaseReviewer", fields: [reviewedById], references: [id])

  @@index([organizationId])
  @@index([region])
  @@index([isActive])
  @@index([tier])
  @@index([visibility])
  @@index([reviewStatus])
  @@index([tradeCategory])
  @@index([submittedById])
  @@map("cost_databases")
}

model MaterialCost {
  id             String           @id @default(uuid())
  costDatabaseId String
  csiCode        String?
  csiDivision    Int?
  category       MaterialCategory
  subcategory    String?
  name           String
  description    String?
  unit           String
  unitCost       Decimal          @db.Decimal(12, 2)
  minCost        Decimal?         @db.Decimal(12, 2)
  maxCost        Decimal?         @db.Decimal(12, 2)
  wasteFactor    Decimal          @default(1.05) @db.Decimal(5, 4)
  supplier       String?
  sku            String?
  leadTimeDays   Int?
  isActive       Boolean          @default(true)
  lastUpdated    DateTime         @default(now())
  priceHistory   Json?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  costDatabase  CostDatabase       @relation(fields: [costDatabaseId], references: [id])
  assemblyItems AssemblyItem[]
  lineItems     EstimateLineItem[]

  @@index([costDatabaseId])
  @@index([csiCode])
  @@index([category])
  @@index([name])
  @@map("material_costs")
}

model LaborRate {
  id                 String     @id @default(uuid())
  costDatabaseId     String
  trade              LaborTrade
  classification     String?
  description        String?
  baseRate           Decimal    @db.Decimal(10, 2)
  burdenRate         Decimal?   @db.Decimal(10, 2)
  totalRate          Decimal    @db.Decimal(10, 2)
  overtimeMultiplier Decimal    @default(1.5) @db.Decimal(5, 2)
  prevailingWage     Boolean    @default(false)
  unionRate          Boolean    @default(false)
  productivityFactor Decimal    @default(1.0) @db.Decimal(5, 4)
  region             String?
  effectiveDate      DateTime   @default(now())
  expirationDate     DateTime?
  isActive           Boolean    @default(true)
  metadata           Json?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  costDatabase  CostDatabase       @relation(fields: [costDatabaseId], references: [id])
  assemblyItems AssemblyItem[]
  lineItems     EstimateLineItem[]

  @@index([costDatabaseId])
  @@index([trade])
  @@index([region])
  @@map("labor_rates")
}

model EquipmentRate {
  id                 String            @id @default(uuid())
  costDatabaseId     String
  category           EquipmentCategory
  name               String
  description        String?
  dailyRate          Decimal           @db.Decimal(10, 2)
  weeklyRate         Decimal?          @db.Decimal(10, 2)
  monthlyRate        Decimal?          @db.Decimal(10, 2)
  operatorRequired   Boolean           @default(false)
  operatorRate       Decimal?          @db.Decimal(10, 2)
  fuelCostPerHour    Decimal?          @db.Decimal(6, 2)
  mobilizationCost   Decimal?          @db.Decimal(10, 2)
  demobilizationCost Decimal?          @db.Decimal(10, 2)
  minRentalDays      Int               @default(1)
  isActive           Boolean           @default(true)
  metadata           Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  costDatabase  CostDatabase       @relation(fields: [costDatabaseId], references: [id])
  assemblyItems AssemblyItem[]
  lineItems     EstimateLineItem[]

  @@index([costDatabaseId])
  @@index([category])
  @@map("equipment_rates")
}

model Assembly {
  id             String             @id @default(uuid())
  costDatabaseId String
  csiCode        String?
  code           String?            @unique // Marketplace code: "KIT-CAB-STD", "BATH-TILE-FLR"
  category       AssemblyCategory
  subcategory    String?
  name           String
  description    String?
  unit           String
  unitCost       Decimal            @db.Decimal(12, 2)
  laborCost      Decimal            @db.Decimal(12, 2)
  materialCost   Decimal            @db.Decimal(12, 2)
  equipmentCost  Decimal            @default(0) @db.Decimal(12, 2)
  laborHours     Decimal            @db.Decimal(8, 2)
  productionRate Decimal?           @db.Decimal(8, 2)
  crewSize       Decimal?           @db.Decimal(4, 2)
  complexity     AssemblyComplexity @default(STANDARD)
  isActive       Boolean            @default(true)
  isTemplate     Boolean            @default(false)
  tags           String[]           @default([])
  notes          String?
  metadata       Json?

  // Marketplace pricing tiers (low / mid / high quality)
  materialCostLow   Decimal? @db.Decimal(10, 2)
  materialCostMid   Decimal? @db.Decimal(10, 2)
  materialCostHigh  Decimal? @db.Decimal(10, 2)
  laborCostLow      Decimal? @db.Decimal(10, 2)
  laborCostMid      Decimal? @db.Decimal(10, 2)
  laborCostHigh     Decimal? @db.Decimal(10, 2)
  laborHoursPerUnit Decimal? @db.Decimal(6, 2)

  // Regional cost multipliers (JSON map: { "DC": 1.15, "Baltimore": 1.0, ... })
  regionMultiplier Json?

  // Trades required for this assembly
  tradesRequired String[] @default([])

  // CTC (Construction Task Catalog) fields
  ctcTaskNumber  String?  // e.g. "01-001", "03-210" — CTC/Gordian task number
  ctcModifierOf  String?  // Parent task number if this is a modifier task
  sourceDatabase String?  // Origin identifier: "CTC-Gordian-MD-DGS-2023", "Kealee-Marketplace", etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  costDatabase CostDatabase       @relation(fields: [costDatabaseId], references: [id])
  items        AssemblyItem[]
  lineItems    EstimateLineItem[]

  @@index([costDatabaseId])
  @@index([csiCode])
  @@index([code])
  @@index([category])
  @@index([name])
  @@index([ctcTaskNumber])
  @@map("assemblies")
}

model AssemblyItem {
  id          String           @id @default(uuid())
  assemblyId  String
  itemType    AssemblyItemType
  materialId  String?
  laborRateId String?
  equipmentId String?
  description String?
  quantity    Decimal          @db.Decimal(12, 4)
  unit        String
  unitCost    Decimal          @db.Decimal(12, 2)
  totalCost   Decimal          @db.Decimal(12, 2)
  laborHours  Decimal?         @db.Decimal(8, 2)
  sortOrder   Int              @default(0)
  notes       String?
  createdAt   DateTime         @default(now())

  assembly  Assembly       @relation(fields: [assemblyId], references: [id], onDelete: Cascade)
  material  MaterialCost?  @relation(fields: [materialId], references: [id])
  laborRate LaborRate?     @relation(fields: [laborRateId], references: [id])
  equipment EquipmentRate? @relation(fields: [equipmentId], references: [id])

  @@index([assemblyId])
  @@map("assembly_items")
}

model Estimate {
  id               String         @id @default(uuid())
  organizationId   String
  projectId        String?
  clientId         String?
  costDatabaseId   String?
  bidRequestId     String?
  name             String
  description      String?
  type             EstimateType
  status           EstimateStatus @default(DRAFT_ESTIMATE)
  version          Int            @default(1)
  parentEstimateId String?

  // Project Details
  projectName    String?
  projectAddress String?
  projectCity    String?
  projectState   String?
  projectZip     String?
  squareFootage  Decimal? @db.Decimal(12, 2)
  projectType    String?
  buildingType   String?
  stories        Int?

  // Cost Summary
  subtotalMaterial      Decimal @default(0) @db.Decimal(14, 2)
  subtotalLabor         Decimal @default(0) @db.Decimal(14, 2)
  subtotalEquipment     Decimal @default(0) @db.Decimal(14, 2)
  subtotalSubcontractor Decimal @default(0) @db.Decimal(14, 2)
  subtotalOther         Decimal @default(0) @db.Decimal(14, 2)
  subtotalDirect        Decimal @default(0) @db.Decimal(14, 2)

  // Markups
  overhead           Decimal  @default(0) @db.Decimal(14, 2)
  overheadPercent    Decimal  @default(10) @db.Decimal(5, 2)
  profit             Decimal  @default(0) @db.Decimal(14, 2)
  profitPercent      Decimal  @default(10) @db.Decimal(5, 2)
  contingency        Decimal  @default(0) @db.Decimal(14, 2)
  contingencyPercent Decimal  @default(5) @db.Decimal(5, 2)
  bondCost           Decimal  @default(0) @db.Decimal(14, 2)
  bondPercent        Decimal? @db.Decimal(5, 2)
  permitFees         Decimal  @default(0) @db.Decimal(14, 2)
  insuranceCost      Decimal  @default(0) @db.Decimal(14, 2)
  taxRate            Decimal  @default(0) @db.Decimal(5, 4)
  salesTax           Decimal  @default(0) @db.Decimal(14, 2)

  // Totals
  totalCost   Decimal  @default(0) @db.Decimal(14, 2)
  costPerSqFt Decimal? @db.Decimal(10, 2)

  // Timeline
  estimatedDuration Int?
  startDate         DateTime?
  endDate           DateTime?

  // AI Analysis
  aiGenerated   Boolean  @default(false)
  aiConfidence  Decimal? @db.Decimal(5, 4)
  aiNotes       String?
  aiComparisons Json?

  // Workflow
  preparedById String?
  reviewedById String?
  approvedById String?
  preparedAt   DateTime?
  reviewedAt   DateTime?
  approvedAt   DateTime?
  sentAt       DateTime?
  sentTo       String[]  @default([])
  expiresAt    DateTime?

  // Service Info
  serviceType      EstimationServiceType?
  turnaroundHours  Int?
  revisionsAllowed Int                    @default(1)
  revisionsUsed    Int                    @default(0)

  notes          String?
  internalNotes  String?
  assumptions    Json?
  exclusions     Json?
  clarifications Json?
  attachments    Json?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  costDatabase   CostDatabase?        @relation(fields: [costDatabaseId], references: [id])
  parentEstimate Estimate?            @relation("EstimateRevisions", fields: [parentEstimateId], references: [id])
  revisions      Estimate[]           @relation("EstimateRevisions")
  sections       EstimateSection[]
  lineItems      EstimateLineItem[]
  comparisons    EstimateComparison[] @relation("EstimateComparisons")
  comparedTo     EstimateComparison[] @relation("ComparedEstimates")
  takeoffJobs    TakeoffJob[]

  @@index([organizationId])
  @@index([projectId])
  @@index([clientId])
  @@index([status])
  @@index([type])
  @@map("estimates")
}

model EstimateSection {
  id                    String   @id @default(uuid())
  estimateId            String
  csiDivision           Int?
  csiCode               String?
  name                  String
  description           String?
  subtotalMaterial      Decimal  @default(0) @db.Decimal(14, 2)
  subtotalLabor         Decimal  @default(0) @db.Decimal(14, 2)
  subtotalEquipment     Decimal  @default(0) @db.Decimal(14, 2)
  subtotalSubcontractor Decimal  @default(0) @db.Decimal(14, 2)
  subtotalOther         Decimal  @default(0) @db.Decimal(14, 2)
  total                 Decimal  @default(0) @db.Decimal(14, 2)
  sortOrder             Int      @default(0)
  isExpanded            Boolean  @default(true)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  estimate  Estimate           @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  lineItems EstimateLineItem[]

  @@index([estimateId])
  @@map("estimate_sections")
}

model EstimateLineItem {
  id         String       @id @default(uuid())
  estimateId String
  sectionId  String?
  itemType   LineItemType

  // Source references
  materialId  String?
  laborRateId String?
  equipmentId String?
  assemblyId  String?

  // Item details
  csiCode     String?
  category    String?
  description String
  location    String?

  // Quantities
  quantity      Decimal       @db.Decimal(12, 4)
  unit          String
  takeoffSource TakeoffSource @default(MANUAL)
  takeoffNotes  String?

  // Costs
  unitCost          Decimal  @db.Decimal(12, 2)
  totalCost         Decimal  @db.Decimal(14, 2)
  laborHours        Decimal? @db.Decimal(8, 2)
  laborCost         Decimal? @db.Decimal(14, 2)
  materialCostAmt   Decimal? @db.Decimal(14, 2)
  equipmentCostAmt  Decimal? @db.Decimal(14, 2)
  subcontractorCost Decimal? @db.Decimal(14, 2)

  // Adjustments
  wasteFactor      Decimal @default(1.0) @db.Decimal(5, 4)
  difficultyFactor Decimal @default(1.0) @db.Decimal(5, 4)
  markup           Decimal @default(0) @db.Decimal(5, 2)
  discount         Decimal @default(0) @db.Decimal(5, 2)

  // Flags
  isAlternate Boolean @default(false)
  isAllowance Boolean @default(false)
  isExcluded  Boolean @default(false)
  isByOwner   Boolean @default(false)

  sortOrder Int      @default(0)
  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  estimate  Estimate         @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  section   EstimateSection? @relation(fields: [sectionId], references: [id])
  material  MaterialCost?    @relation(fields: [materialId], references: [id])
  laborRate LaborRate?       @relation(fields: [laborRateId], references: [id])
  equipment EquipmentRate?   @relation(fields: [equipmentId], references: [id])
  assembly  Assembly?        @relation(fields: [assemblyId], references: [id])

  @@index([estimateId])
  @@index([sectionId])
  @@index([itemType])
  @@map("estimate_line_items")
}

model CostCodeImportJob {
  id             String          @id @default(uuid())
  costDatabaseId String?
  userId         String
  fileName       String
  fileUrl        String?
  fileSize       Int?
  mimeType       String          @default("application/pdf")
  status         ImportJobStatus @default(PENDING)
  progress       Int             @default(0) // 0-100

  // 3-Tier routing — determines where imported data lands
  targetTier    CostDatabaseTier @default(ORGANIZATION) // Which tier this import targets
  isAdminUpload Boolean          @default(false) // true = Kealee admin uploading standard book

  // Results
  totalPages      Int?
  processedPages  Int?
  materialsFound  Int   @default(0)
  laborRatesFound Int   @default(0)
  equipmentFound  Int   @default(0)
  assembliesFound Int   @default(0)
  totalImported   Int   @default(0)
  totalSkipped    Int   @default(0)
  errors          Json? // Array of error messages

  // AI extraction metadata
  extractedText  String? @db.Text
  structuredData Json? // Final structured output from AI

  // AI classification (auto-tagged on import)
  aiTradeCategory String? // AI-detected trade category
  aiProjectType   String? // AI-detected project type
  aiMethodology   String? // AI-detected construction methodology
  aiConfidence    Decimal? @db.Decimal(5, 4) // AI classification confidence 0-1

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  costDatabase CostDatabase? @relation(fields: [costDatabaseId], references: [id])
  user         User          @relation("CostCodeImportJobs", fields: [userId], references: [id])

  @@index([userId])
  @@index([costDatabaseId])
  @@index([status])
  @@index([targetTier])
  @@map("cost_code_import_jobs")
}

model QuickEstimate {
  id        String  @id @default(uuid())
  projectId String?
  leadId    String?
  createdBy String? // userId or null for anonymous/marketing

  // Inputs
  projectType String // "kitchen_renovation", "bathroom_remodel", etc.
  sqft        Decimal? @db.Decimal(10, 2)
  location    String // city/region for multiplier
  qualityTier String   @default("mid") // "low", "mid", "high"
  description String?  @db.Text

  // Results
  materialTotal Decimal @db.Decimal(12, 2)
  laborTotal    Decimal @db.Decimal(12, 2)
  subtotal      Decimal @db.Decimal(12, 2)
  overhead      Decimal @db.Decimal(12, 2)
  profit        Decimal @db.Decimal(12, 2)
  contingency   Decimal @db.Decimal(12, 2)
  grandTotal    Decimal @db.Decimal(12, 2)

  // Price range
  priceLow  Decimal @db.Decimal(12, 2)
  priceMid  Decimal @db.Decimal(12, 2)
  priceHigh Decimal @db.Decimal(12, 2)

  breakdown   Json // detailed line-by-line breakdown
  assumptions Json? // what was assumed

  status    String   @default("draft") // "draft", "sent", "accepted"
  createdAt DateTime @default(now())

  lead Lead? @relation(fields: [leadId], references: [id])

  @@index([projectId])
  @@index([leadId])
  @@index([projectType])
  @@index([createdAt])
  @@map("quick_estimates")
}

// Estimate Comparisons — compare estimates against each other or historical data
model EstimateComparison {
  id           String         @id @default(uuid())
  estimateId   String
  comparedToId String?
  type         ComparisonType
  name         String?

  // Comparison data
  baseCost        Decimal @db.Decimal(14, 2)
  comparedCost    Decimal @db.Decimal(14, 2)
  variance        Decimal @db.Decimal(14, 2)
  variancePercent Decimal @db.Decimal(8, 4)

  // Breakdown
  materialVariance  Decimal? @db.Decimal(14, 2)
  laborVariance     Decimal? @db.Decimal(14, 2)
  equipmentVariance Decimal? @db.Decimal(14, 2)

  // Analysis
  factors         Json?
  recommendations Json?
  aiAnalysis      String?

  createdAt DateTime @default(now())

  estimate   Estimate  @relation("EstimateComparisons", fields: [estimateId], references: [id], onDelete: Cascade)
  comparedTo Estimate? @relation("ComparedEstimates", fields: [comparedToId], references: [id])

  @@index([estimateId])
  @@map("estimate_comparisons")
}

// Estimate History — audit trail for status changes and edits
model EstimateHistory {
  id             String          @id @default(uuid())
  estimateId     String
  action         EstimateAction
  userId         String?
  previousStatus EstimateStatus?
  newStatus      EstimateStatus?
  changes        Json?
  notes          String?
  createdAt      DateTime        @default(now())

  @@index([estimateId])
  @@index([createdAt])
  @@map("estimate_history")
}

// Takeoffs — plan-based quantity extraction sessions
model Takeoff {
  id          String        @id @default(uuid())
  estimateId  String?
  projectId   String?
  name        String
  description String?
  type        TakeoffType
  status      TakeoffStatus @default(NOT_STARTED)

  // Source documents
  documentUrls Json?
  pageCount    Int?
  scale        String?

  // Totals
  totalItems  Int      @default(0)
  totalArea   Decimal? @db.Decimal(14, 2)
  totalLinear Decimal? @db.Decimal(14, 2)
  totalCount  Int?

  // AI processing
  aiProcessed  Boolean  @default(false)
  aiConfidence Decimal? @db.Decimal(5, 4)
  aiNotes      String?

  completedAt   DateTime?
  completedById String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  measurements TakeoffMeasurement[]

  @@index([estimateId])
  @@index([projectId])
  @@map("takeoffs")
}

// Takeoff Measurements — individual measurements within a takeoff
model TakeoffMeasurement {
  id          String  @id @default(uuid())
  takeoffId   String
  category    String
  subcategory String?
  description String
  location    String?
  floor       String?

  // Measurement data
  measurementType MeasurementType
  length          Decimal?        @db.Decimal(12, 4)
  width           Decimal?        @db.Decimal(12, 4)
  height          Decimal?        @db.Decimal(12, 4)
  depth           Decimal?        @db.Decimal(12, 4)
  area            Decimal?        @db.Decimal(14, 2)
  volume          Decimal?        @db.Decimal(14, 2)
  count           Int?

  unit     String
  quantity Decimal @db.Decimal(12, 4)

  // Source
  pageNumber   Int?
  coordinates  Json?
  sourceMethod TakeoffSource @default(MANUAL)
  confidence   Decimal?      @db.Decimal(5, 4)

  // Linking
  linkedToLineItem String?

  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  takeoff Takeoff @relation(fields: [takeoffId], references: [id], onDelete: Cascade)

  @@index([takeoffId])
  @@index([category])
  @@map("takeoff_measurements")
}

// Estimation Orders — service orders for estimation work
model EstimationOrder {
  id             String  @id @default(uuid())
  organizationId String?
  clientId       String?
  projectId      String?

  // Order details
  orderNumber String                @unique
  serviceType EstimationServiceType
  status      EstimationOrderStatus @default(ORDER_PENDING)
  priority    OrderPriority         @default(ORDER_NORMAL)

  // Pricing
  price           Decimal   @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  total           Decimal   @db.Decimal(10, 2)
  paidAt          DateTime?
  stripePaymentId String?

  // Project info
  projectName      String
  projectAddress   String?
  projectType      String?
  squareFootage    Decimal? @db.Decimal(12, 2)
  scopeDescription String?

  // Documents
  uploadedDocs Json?

  // Timeline
  requestedTurnaround Int?
  dueAt               DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  deliveredAt         DateTime?

  // Assignment
  assignedToId String?
  reviewedById String?

  // Output
  estimateId   String?
  deliverables Json?

  // Communication
  notes          String?
  internalNotes  String?
  clientFeedback String?
  feedbackRating Int?

  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([orderNumber])
  @@map("estimation_orders")
}

// Regional Cost Indices — regional cost adjustment factors
model RegionalCostIndex {
  id             String   @id @default(uuid())
  region         String
  city           String?
  state          String
  indexValue     Decimal  @db.Decimal(6, 4)
  laborIndex     Decimal? @db.Decimal(6, 4)
  materialIndex  Decimal? @db.Decimal(6, 4)
  equipmentIndex Decimal? @db.Decimal(6, 4)
  effectiveDate  DateTime
  source         String?
  createdAt      DateTime @default(now())

  @@unique([region, effectiveDate])
  @@index([region])
  @@index([state])
  @@map("regional_cost_indices")
}

// Historical Project Costs — benchmarking data from past projects
model HistoricalProjectCost {
  id             String  @id @default(uuid())
  organizationId String?
  projectType    String
  buildingType   String?
  region         String
  city           String?
  state          String?
  squareFootage  Decimal @db.Decimal(12, 2)
  totalCost      Decimal @db.Decimal(14, 2)
  costPerSqFt    Decimal @db.Decimal(10, 2)

  // Breakdown
  laborPercent     Decimal? @db.Decimal(5, 2)
  materialPercent  Decimal? @db.Decimal(5, 2)
  equipmentPercent Decimal? @db.Decimal(5, 2)

  // Context
  complexity AssemblyComplexity?
  quality    QualityLevel?
  year       Int
  quarter    Int?

  // Flags
  isVerified Boolean @default(false)
  source     String?

  notes     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([projectType])
  @@index([region])
  @@index([year])
  @@map("historical_project_costs")
}

model CostDataReview {
  id             String               @id @default(uuid())
  costDatabaseId String
  reviewerId     String // Kealee admin who performed the review
  action         CostDataReviewAction
  notes          String?              @db.Text
  previousStatus CostDataReviewStatus
  newStatus      CostDataReviewStatus

  // Quality metrics assessed during review
  dataQualityScore Int? // 1-100 quality score
  completeness     Int? // 1-100 how complete the data is
  accuracy         Int? // 1-100 estimated accuracy
  flaggedIssues    Json? // Array of issues found

  createdAt DateTime @default(now())

  costDatabase CostDatabase @relation(fields: [costDatabaseId], references: [id], onDelete: Cascade)
  reviewer     User         @relation("CostDataReviewAdmin", fields: [reviewerId], references: [id])

  @@index([costDatabaseId])
  @@index([reviewerId])
  @@index([action])
  @@map("cost_data_reviews")
}

model CostBookCustomization {
  id               String @id @default(uuid())
  organizationId   String
  sourceDatabaseId String // The standard/community database being customized
  targetDatabaseId String // The org-private database where customizations live

  // What was customized
  entityType       String // "material", "labor", "equipment", "assembly"
  sourceEntityId   String // ID of the original entity in the source database
  customizedFields Json // { "unitCost": 45.50, "wasteFactor": 1.08 } — only changed fields
  originalValues   Json // Original values before customization (for diff/rollback)

  notes          String?  @db.Text
  customizedById String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, sourceDatabaseId, entityType, sourceEntityId])
  @@index([organizationId])
  @@index([sourceDatabaseId])
  @@index([targetDatabaseId])
  @@index([entityType])
  @@index([customizedById])
  @@map("cost_book_customizations")
}

model SubcontractorQuote {
  id             String   @id @default(cuid())
  bidId          String
  subName        String
  subEmail       String?
  subPhone       String?
  trade          String
  scope          String?  @db.Text
  quoteAmount    Decimal  @db.Decimal(12, 2)
  notes          String?  @db.Text
  attachments    String[]
  receivedAt     DateTime @default(now())
  validUntil     DateTime?
  status         String   @default("RECEIVED")

  bid OpportunityBid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([trade])
  @@map("subcontractor_quotes")
}

model TakeoffJob {
  id             String          @id @default(uuid())
  organizationId String?
  userId         String
  estimateId     String?

  // Input files
  fileName     String
  fileUrl      String?
  fileSize     Int?
  mimeType     String   @default("application/pdf")
  pageCount    Int?

  // Processing state
  status   TakeoffJobStatus @default(TAKEOFF_PENDING)
  progress Int              @default(0) // 0-100

  // AI extraction results
  extractedScopes  Json?  // Array of detected scope items from plans
  extractedTasks   Json?  // Mapped CTC tasks with quantities
  confidence       Decimal? @db.Decimal(5, 4)

  // Mapping results
  ctcTasksMatched    Int @default(0)
  ctcTasksUnmatched  Int @default(0)
  lineItemsGenerated Int @default(0)

  // Review
  reviewedBy    String?
  reviewNotes   String?
  adjustments   Json?   // User modifications before confirmation

  // Errors
  errors Json?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user     User      @relation("TakeoffJobs", fields: [userId], references: [id])
  estimate Estimate? @relation(fields: [estimateId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([estimateId])
  @@index([status])
  @@map("takeoff_jobs")
}
