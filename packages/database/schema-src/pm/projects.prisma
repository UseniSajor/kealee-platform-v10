// PM — PROJECTS
// Domain: pm | Owner: OS-PM service

model Project {
  id         String  @id @default(uuid())
  name       String?
  clientId   String?
  orgId      String?
  propertyId String?
  pmId       String? // Project Manager ID
  ownerId    String?
  status     String  @default("ACTIVE")

  // SOP / Pipeline fields
  category         String?
  categoryMetadata Json?
  description      String?
  budgetTotal      Decimal?  @db.Decimal(14, 2)
  executionTier    String?
  startDate        DateTime?
  endDate          DateTime?

  // Project details
  address   String?
  city      String?
  state     String?
  zipCode   String?
  latitude  Float?
  longitude Float?

  // Schedule & Budget
  currentPhase       String?
  scheduledStartDate DateTime?
  scheduledEndDate   DateTime?
  projectedEndDate   DateTime?
  actualStartDate    DateTime?
  actualEndDate      DateTime?
  budget             Decimal?  @db.Decimal(14, 2)

  // Autonomy Configuration
  autonomyLevel     Int       @default(1) // 1=recommend, 2=routine-auto, 3=full-auto
  autonomyRules     Json? // Category overrides e.g. { changeOrders: { maxAutoApprove: 500 } }
  autonomyEnabledAt DateTime?
  autonomyEnabledBy String?

  // ── Canonical classification fields (additive) ────────────────────────────
  // Legacy: `category String?` is preserved; projectType is the canonical enum.
  // See ProjectType enum in schema-src/engagement/enums.prisma.
  projectType            ProjectType?
  // Tracks whether this project has passed the CONSTRUCTION_READY gate.
  // Gate rule: plans complete + permits submitted → CONSTRUCTION_READY.
  // Contractors may NOT be engaged before this status is reached.
  // See ConstructionReadinessStatus in schema-src/engagement/enums.prisma.
  constructionReadiness  ConstructionReadinessStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  permits          Permit[]
  inspections      Inspection[]
  contracts        ContractAgreement[]
  escrowAgreements EscrowAgreement[]
  disputes         Dispute[]
  leads            Lead[]
  client           Client?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  org              Org?                @relation(fields: [orgId], references: [id], onDelete: SetNull)
  property         Property?           @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  tasks            Task[]
  payments         Payment[]
  lienWaivers      LienWaiver[]

  // Command Center relationships
  bidRequests       BidRequest[]
  siteVisits        SiteVisit[]
  siteCheckIns      SiteCheckIn[]      @relation("ProjectCheckIns")
  changeOrders      ChangeOrder[]
  reports           Report[]
  budgetLines       BudgetLine[]
  budgetSnapshots   BudgetSnapshot[]
  budgetAlerts      BudgetAlert[]
  scheduledPayments ScheduledPayment[]
  projectManagers   ProjectManager[]

  // Command Center Infrastructure relations
  aiConversations      AIConversation[]
  automationTasks      AutomationTask[]
  bidEvaluations       BidEvaluation[]
  weeklyReports        WeeklyReport[]
  autonomousActionLogs AutonomousActionLog[]
  beforeAfterPairs     BeforeAfterPair[]

  // Project Phase tracking
  phases ProjectPhase[]

  // IoT Sensor Devices
  sensorDevices SensorDevice[] @relation("ProjectSensors")

  // User Responsibilities Tracking relations (from Kealee_User_Responsibilities_Guide.md)
  dailyLogs   DailyLog[]
  fileUploads FileUpload[]
  receipts    Receipt[]

  // PM Feature relations
  rfis            RFI[]
  submittals      Submittal[]
  meetings        Meeting[]
  selections      Selection[]
  warranties      Warranty[]
  warrantyClaims  WarrantyClaim[]
  timeEntries     TimeEntry[]
  safetyIncidents SafetyIncident[]
  toolboxTalks    ToolboxTalk[]

  // PM Module v4 relations
  fieldConflicts         FieldConflict[]
  mobilizationChecklists MobilizationChecklist[]

  // Kealee Messenger & Claws relations
  conversations Conversation[] @relation("ProjectConversations")
  budgetItems   BudgetItem[]   @relation("ProjectBudgetItems")

  // SOP & Membership relations
  memberships   ProjectMembership[]
  sopExecutions SOPExecution[]

  // Consolidation: v3 high-value models
  purchaseOrders PurchaseOrder[]
  bills          Bill[]
  rfqs           RFQ[]
  deliveries     Delivery[]
  closeoutItems  CloseoutItem[]
  lookaheadItems LookaheadItem[]

  // Spatial & Financing relations (Backend Consolidation v10)
  spatialScans            SpatialScan[]
  financingApplications   FinancingApplication[]
  items                   ProjectItem[]

  // GHL (GoHighLevel) CRM integration
  ghlOpportunityId String? @unique
  ghlPipelineId    String?
  ghlStageId       String?

  // V20 — DDTS & OS Service relations
  digitalTwin       DigitalTwin?       @relation("ProjectTwin")
  capitalStack      CapitalStack?
  investorReports   InvestorReport[]
  entitlements      Entitlement[]
  turnoverChecklists TurnoverChecklist[]
  maintenanceSchedules MaintenanceSchedule[]
  maintenanceWorkOrders MaintenanceWorkOrder[]
  escrowReconciliations EscrowReconciliation[]
  feasibilityStudies    FeasibilityStudy[]

  // Canonical Engagement relations (additive)
  engagements Engagement[] @relation("ProjectEngagements")

  @@index([clientId])
  @@index([orgId])
  @@index([propertyId])
  @@index([pmId])
  @@index([status])
  // ── Performance: Compound indexes for dashboard queries ──
  @@index([clientId, status]) // Client dashboard: "my active projects"
  @@index([pmId, status]) // PM dashboard: "my active projects"
  @@index([orgId, status]) // Org-scoped project listing
  @@index([status, createdAt]) // Admin: projects by status + time
}

model ProjectPhase {
  id        String @id @default(uuid())
  projectId String

  // Phase identification
  type        ProjectPhaseType
  name        String // Display name (can override type name)
  description String?
  sortOrder   Int              @default(0) // For ordering phases

  // Status tracking
  status          ProjectPhaseStatus @default(NOT_STARTED)
  percentComplete Int                @default(0) // 0-100

  // Schedule
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  // Budget allocation
  budgetAllocated Decimal? @db.Decimal(14, 2) // Allocated budget for this phase
  budgetSpent     Decimal? @db.Decimal(14, 2) // Actual spent

  // Responsible party
  assignedContractorId String?
  assignedPmId         String?

  // Dependencies (phases that must complete before this one)
  dependsOnPhaseIds String[] // Array of ProjectPhase IDs

  // Notes and metadata
  notes    String?
  metadata Json?

  // Audit fields
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  completedBy String? // User ID who marked as complete

  // Relations
  project            Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedContractor Contractor?           @relation(fields: [assignedContractorId], references: [id], onDelete: SetNull)
  milestones         PhaseMilestone[]
  phaseHistory       ProjectPhaseHistory[]

  @@unique([projectId, type]) // One phase of each type per project (unless CUSTOM)
  @@index([projectId])
  @@index([status])
  @@index([type])
  @@index([assignedContractorId])
}

model PhaseMilestone {
  id      String @id @default(uuid())
  phaseId String

  name        String
  description String?
  dueDate     DateTime?

  // Status
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?

  // Verification
  requiresInspection Boolean @default(false)
  inspectionId       String? // Link to Inspection if required

  // Payment trigger
  triggersPayment  Boolean  @default(false)
  paymentAmount    Decimal? @db.Decimal(14, 2)
  paymentTriggered Boolean  @default(false)

  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phase      ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  inspection Inspection?  @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  @@index([phaseId])
  @@index([isCompleted])
}

model ProjectPhaseHistory {
  id      String @id @default(uuid())
  phaseId String

  // What changed
  fromStatus ProjectPhaseStatus?
  toStatus   ProjectPhaseStatus

  // Who and when
  changedBy String?
  changedAt DateTime @default(now())

  // Context
  reason String?
  notes  String?

  phase ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  @@index([phaseId])
  @@index([changedAt])
}

// Pre-Construction Project - Main workflow entity
model PreConProject {
  id      String  @id @default(uuid())
  ownerId String
  orgId   String?

  // Project Details
  name        String
  category    String // KITCHEN, BATHROOM, ADDITION, etc.
  description String @db.Text

  // Location
  address   String?
  city      String?
  state     String?
  zipCode   String?
  latitude  Float?
  longitude Float?

  // Scope
  squareFootage Int?
  rooms         Int?
  floors        Int?
  features      String[] // Array of requested features
  complexity    String   @default("STANDARD") // BASIC, STANDARD, PREMIUM, LUXURY

  // Pre-Con Status
  phase              PreConPhase @default(INTAKE)
  intakeCompletedAt  DateTime?
  designStartedAt    DateTime?
  designApprovedAt   DateTime?
  srpGeneratedAt     DateTime?
  marketplaceReadyAt DateTime?
  biddingOpenedAt    DateTime?
  awardedAt          DateTime?
  contractRatifiedAt DateTime?

  // Design Package Selection
  designPackageTier   DesignPackageTier @default(STANDARD)
  designPackagePaid   Boolean           @default(false)
  designPackagePaidAt DateTime?

  // Design Concepts
  selectedConceptId String?

  // Pricing (SRP)
  suggestedRetailPrice Decimal?  @db.Decimal(12, 2)
  srpLaborCost         Decimal?  @db.Decimal(12, 2)
  srpMaterialCost      Decimal?  @db.Decimal(12, 2)
  srpContingency       Decimal?  @db.Decimal(12, 2)
  srpMarkup            Decimal?  @db.Decimal(12, 2)
  srpBreakdown         Json? // Detailed breakdown
  srpConfidence        Int? // 0-100 confidence score
  srpValidUntil        DateTime?

  // Marketplace Settings (Lead sale hidden from owner UI)
  allowBidding    Boolean   @default(true)
  minimumBid      Decimal?  @db.Decimal(12, 2)
  biddingDeadline DateTime?
  maxBids         Int       @default(5)

  // Internal: Lead Sale (NOT visible to project owner)
  leadSaleEnabled     Boolean   @default(false) // Admin/B2B only
  leadSalePrice       Decimal?  @db.Decimal(12, 2)
  leadSoldAt          DateTime?
  leadSoldToProfileId String?

  // Contract & Award
  awardedBidId        String?
  awardedContractorId String?
  contractAmount      Decimal? @db.Decimal(12, 2)

  // Links
  projectId  String? // Links to main Project after award
  estimateId String? // Links to estimation engine estimate

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  owner          User                 @relation("PreConProjectOwner", fields: [ownerId], references: [id])
  designConcepts DesignConcept[]
  bids           ContractorBid[]
  platformFees   PlatformFee[]
  phaseHistory   PreConPhaseHistory[]

  // Auto Design & Design Queue relations
  autoDesignSession AutoDesignSession?      @relation("PreConAutoDesign")
  queueAssignments  DesignQueueAssignment[] @relation("PreConDesignQueue")
  designHandoffs    DesignHandoff[]         @relation("PreConDesignHandoff")

  @@index([ownerId])
  @@index([phase])
  @@index([category])
  @@index([state])
  @@index([createdAt])
}

// Pre-Con Phase History - Audit trail of phase transitions
model PreConPhaseHistory {
  id              String @id @default(uuid())
  preConProjectId String

  fromPhase PreConPhase?
  toPhase   PreConPhase

  // Who triggered
  triggeredBy String? // User ID
  triggerType String  @default("USER") // USER, SYSTEM, AUTO

  // Context
  notes    String? @db.Text
  metadata Json?

  // Timestamps
  occurredAt DateTime @default(now())

  // Relationships
  preConProject PreConProject @relation(fields: [preConProjectId], references: [id], onDelete: Cascade)

  @@index([preConProjectId])
  @@index([toPhase])
  @@index([occurredAt])
}

model ProjectManager {
  id         String    @id @default(uuid())
  projectId  String
  userId     String
  role       String    @default("PM") // PM, ASSISTANT_PM, SUPERINTENDENT
  isPrimary  Boolean   @default(false)
  assignedAt DateTime  @default(now())
  removedAt  DateTime?

  // SOP v2: PM executes services from m-ops-services subscriptions
  pmSubscriptionId String?

  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pmSubscription PMServiceSubscription? @relation("PMServiceAssignments", fields: [pmSubscriptionId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([pmSubscriptionId])
  @@map("project_managers")
}

model ProjectMembership {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("ProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}
