{
  "name": "@kealee/ui",
  "version": "1.0.0",
  "description": "Kealee Platform Design System - UI Component Library",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./button": {
      "types": "./src/components/Button.tsx",
      "default": "./src/components/Button.tsx"
    },
    "./card": {
      "types": "./src/components/Card.tsx",
      "default": "./src/components/Card.tsx"
    },
    "./input": {
      "types": "./src/components/Input.tsx",
      "default": "./src/components/Input.tsx"
    },
    "./label": {
      "types": "./src/components/Label.tsx",
      "default": "./src/components/Label.tsx"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./components/scheduling/*": {
      "types": "./src/components/scheduling/*.tsx",
      "default": "./src/components/scheduling/*.tsx"
    },
    "./*": "./src/*"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/openai": "^1.3.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@sentry/nextjs": "^8.40.0",
    "@sentry/replay": "^7.116.0",
    "@sentry/tracing": "^7.120.4",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.562.0",
    "mixpanel-browser": "^2.50.0",
    "next": "14.2.35",
    "posthog-js": "^1.72.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.0.0",
    "web-vitals": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/mixpanel-browser": "^2.43.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "files": [
    "dist",
    "src",
    "tailwind.config.ts",
    "README.md"
  ]
}
