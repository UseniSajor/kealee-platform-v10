{
  "name": "@kealee/ai",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./exterior-concept": {
      "types": "./dist/exterior-concept/index.d.ts",
      "default": "./dist/exterior-concept/index.js"
    },
    "./rag/types": {
      "types": "./dist/rag/types.d.ts",
      "default": "./dist/rag/types.js"
    },
    "./rag/vector-store": {
      "types": "./dist/rag/vector-store.d.ts",
      "default": "./dist/rag/vector-store.js"
    },
    "./rag/retriever": {
      "types": "./dist/rag/retriever.d.ts",
      "default": "./dist/rag/retriever.js"
    },
    "./tools/retrieve-relevant-context": {
      "types": "./dist/tools/retrieve-relevant-context.d.ts",
      "default": "./dist/tools/retrieve-relevant-context.js"
    },
    "./design-engine": {
      "types": "./dist/design-engine.d.ts",
      "default": "./dist/design-engine.js"
    }
  },
  "typesVersions": {
    "*": {
      "exterior-concept": [
        "./dist/exterior-concept/index.d.ts"
      ],
      "rag/types": [
        "./dist/rag/types.d.ts"
      ],
      "rag/vector-store": [
        "./dist/rag/vector-store.d.ts"
      ],
      "rag/retriever": [
        "./dist/rag/retriever.d.ts"
      ],
      "tools/retrieve-relevant-context": [
        "./dist/tools/retrieve-relevant-context.d.ts"
      ],
      "design-engine": [
        "./dist/design-engine.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@anthropic-ai/sdk": "^0.39.0",
    "@kealee/database": "workspace:*",
    "@langchain/core": "^1.1.34",
    "@langchain/langgraph": "^1.2.3",
    "@langchain/openai": "^1.3.0",
    "ai": "^6.0.116",
    "openai": "^4.77.0",
    "replicate": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
