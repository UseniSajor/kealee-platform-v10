# ============================================================
# Kealee Command Center Workers — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Required variables are marked with (REQUIRED).
# ============================================================

# ── Database ─────────────────────────────────────────────────
# (REQUIRED) PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/kealee?schema=public"

# ── Redis ────────────────────────────────────────────────────
# (REQUIRED) Redis URL for BullMQ queues and EventBus pub/sub
REDIS_URL="redis://localhost:6379"

# Optional: separate Redis URL for BullMQ if you use a different instance
# BULLMQ_REDIS_URL="redis://localhost:6379"

# ── AI / LLM ────────────────────────────────────────────────
# (REQUIRED for AI-powered apps: Bid Engine, Predictive Engine, Decision Support)
ANTHROPIC_API_KEY="sk-ant-..."

# Optional: override default model
# ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# ── Supabase (auth token verification) ───────────────────────
# (REQUIRED) Used to verify JWT tokens in event payloads
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Email / Communication Hub ────────────────────────────────
# (REQUIRED for APP-08 Communication Hub)
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="notifications@kealee.com"

# Optional: SMS via Twilio
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER=""

# ── Storage (report PDFs, document generation) ───────────────
# (REQUIRED for APP-04 Report Generator, APP-10 Document Gen)
SUPABASE_STORAGE_BUCKET="documents"

# ── Logging & Monitoring ─────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL="info"

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=""

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV="development"
