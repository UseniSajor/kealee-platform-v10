{
  "name": "@kealee/shared",
  "version": "1.0.0",
  "description": "Shared types, constants, and utilities for the Kealee Platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./software-tiers": {
      "types": "./dist/software-tiers/index.d.ts",
      "import": "./dist/software-tiers/index.js",
      "require": "./dist/software-tiers/index.js",
      "default": "./dist/software-tiers/index.js"
    },
    "./feature-flags": {
      "types": "./dist/feature-flags/index.d.ts",
      "import": "./dist/feature-flags/index.js",
      "require": "./dist/feature-flags/index.js",
      "default": "./dist/feature-flags/index.js"
    },
    "./types/network": {
      "types": "./dist/types/network.d.ts",
      "import": "./dist/types/network.js",
      "require": "./dist/types/network.js",
      "default": "./dist/types/network.js"
    },
    "./intake": {
      "types": "./dist/intake/index.d.ts",
      "import": "./dist/intake/index.js",
      "require": "./dist/intake/index.js",
      "default": "./dist/intake/index.js"
    },
    "./pricing": {
      "types": "./dist/pricing.d.ts",
      "import": "./dist/pricing.js",
      "require": "./dist/pricing.js",
      "default": "./dist/pricing.js"
    }
  },
  "typesVersions": {
    "*": {
      "software-tiers": [
        "dist/software-tiers/index.d.ts"
      ],
      "feature-flags": [
        "dist/feature-flags/index.d.ts"
      ],
      "types/network": [
        "dist/types/network.d.ts"
      ],
      "intake": [
        "dist/intake/index.d.ts"
      ],
      "pricing": [
        "dist/pricing.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "zod": "^3.22.0"
  }
}