{
  "name": "kealee-platform",
  "version": "20.0.0",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "dev:portals": "concurrently --names \"owner,contractor,developer,cc,admin\" --prefix-colors \"cyan,magenta,yellow,green,blue\" \"pnpm --filter portal-owner dev\" \"pnpm --filter portal-contractor dev\" \"pnpm --filter portal-developer dev\" \"pnpm --filter command-center dev\" \"pnpm --filter admin-console dev\"",
    "dev:web": "pnpm --filter web-main dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "deploy": "bash scripts/deploy-all.sh",
    "deploy:api": "bash scripts/deploy-api.sh",
    "deploy:frontend": "bash scripts/deploy-frontend.sh",
    "setup:vercel": "bash scripts/setup-vercel.sh",
    "setup:railway": "bash scripts/setup-railway.sh",
    "verify": "bash scripts/verify-deployments.sh",
    "db:push": "cd services/api && pnpm db:push",
    "db:seed": "cd services/api && pnpm db:seed",
    "db:migrate": "cd services/api && pnpm db:migrate",
    "db:studio": "cd services/api && pnpm db:studio",
    "setup": "bash scripts/run-all-setup.sh",
    "setup:storage": "bash scripts/setup-s3-r2-storage.sh",
    "setup:env": "bash scripts/setup-vercel-env-vars.sh",
    "setup:monitoring": "bash scripts/monitor-first-transactions.sh",
    "setup:alerts": "bash scripts/setup-alerts.sh",
    "ssl:diagnose": "bash scripts/ssl-diagnose.sh",
    "ssl:fix": "bash scripts/ssl-fix-trust-chain.sh",
    "ssl:test": "bash scripts/ssl-test-subdomains.sh",
    "ssl:setup-renewal": "bash scripts/ssl-setup-auto-renewal.sh",
    "ssl:fix-all": "bash scripts/ssl-complete-fix.sh",
    "test:unit": "echo 'Run unit tests in individual apps'",
    "test:integration": "bash scripts/test-integrations.sh",
    "test:api": "bash scripts/test-integrations.sh",
    "test:payment": "cd apps/m-ops-services && npm run test:payment || echo 'Payment tests not configured'",
    "test:upload": "bash scripts/test-file-upload.sh",
    "test:subscription": "cd apps/m-ops-services && npm run test:subscription || echo 'Subscription tests not configured'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:performance": "echo 'Performance tests not configured'",
    "test:smoke": "bash scripts/test-integrations.sh",
    "test:smoke:production": "API_URL=https://api.kealee.com bash scripts/test-integrations.sh",
    "test:permit": "bash scripts/test-permit-applications.sh",
    "test:load": "bash scripts/load-testing.sh",
    "test:security": "bash scripts/security-hardening.sh",
    "optimize:performance": "bash scripts/performance-optimization.sh",
    "setup:uat": "bash scripts/user-acceptance-testing.sh",
    "setup:docs": "bash scripts/documentation-setup.sh",
    "setup:marketing": "bash scripts/marketing-launch-prep.sh",
    "setup:seo": "bash scripts/seo-optimization.sh",
    "setup:content": "bash scripts/content-deployment.sh",
    "setup:golive": "bash scripts/go-live.sh",
    "setup:support": "bash scripts/support-team-training.sh",
    "launch:all": "bash scripts/execute-all-launch-tasks.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh staging",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:all": "npm run deploy:staging && npm run test:smoke && npm run deploy:production",
    "railway:setup": "bash scripts/setup-railway-environments.sh",
    "railway:verify": "bash scripts/verify-railway-env-isolation.sh",
    "railway:deploy:staging": "bash scripts/deploy-api.sh staging",
    "railway:deploy:production": "bash scripts/deploy-api.sh production",
    "railway:migrate:staging": "bash scripts/railway-migrate.sh staging",
    "railway:migrate:production": "bash scripts/railway-migrate.sh production",
    "db:setup": "bash scripts/setup-dev-database.sh",
    "db:migrate:dev": "cd packages/database && npm run db:migrate:dev",
    "db:seed:legacy": "cd packages/database && npm run db:seed",
    "db:migrate:staging": "cd packages/database && npm run db:migrate:staging",
    "db:migrate:prod": "cd packages/database && npm run db:migrate:prod",
    "db:rollback:prod": "cd packages/database && npm run db:rollback:prod",
    "db:create:migration": "bash scripts/db-create-migration.sh",
    "go-live-check": "tsx scripts/go-live-check.ts",
    "platform-ai-test": "tsx scripts/platform-ai-test.ts",
    "automation-validation": "tsx scripts/automation-validation.ts",
    "production-deployment-check": "tsx scripts/production-deployment-check.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*",
    "bots/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jsonwebtoken": "^9.0.5",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.0.1",
    "dotenv": "^17.2.3",
    "ioredis": "^5.3.2",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "turbo": "^2.7.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@as-integrations/fastify": "^1.3.0",
    "@aws-sdk/client-s3": "^3.972.0",
    "@aws-sdk/s3-request-presigner": "^3.972.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/multipart": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.0.0",
    "@huggingface/transformers": "^3.8.1",
    "@kealee/observability": "workspace:^",
    "@sentry/nextjs": "^10.38.0",
    "@sentry/node": "^10.37.0",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.13.6",
    "bullmq": "^5.0.0",
    "csv-parse": "^6.2.1",
    "fastify": "^4.28.0",
    "fastify-raw-body": "^5.0.0",
    "graphql": "^16.12.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-tag": "^2.12.6",
    "next": "^14.2.35",
    "openai": "^6.32.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@as-integrations/fastify": {
      "fastify": "^4.28.0"
    }
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
