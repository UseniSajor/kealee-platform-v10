# =============================================================================
# KEALEE WEB-MAIN — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local dev, or paste into Vercel / Railway.
# [REQUIRED] = app will not function without this value.
# Variables prefixed NEXT_PUBLIC_ are baked into the client bundle at build time.

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development

# =============================================================================
# API URLs
# =============================================================================
# [REQUIRED] Public-facing API base URL (baked into client bundle)
NEXT_PUBLIC_API_URL=https://api.kealee.com

# Server-to-server API URL (used in Next.js API routes; skips public CDN/proxy)
# Falls back to NEXT_PUBLIC_API_URL if not set
INTERNAL_API_URL=https://api.kealee.com

# [REQUIRED] Public app origin (used for Stripe success/cancel redirect URLs)
NEXT_PUBLIC_APP_URL=https://kealee.com

# KeaCore service URL (server-side intake analysis)
KEACORE_URL=https://keacore.kealee.com
# Client-side KeaCore URL (only needed if keacore is called directly from the browser)
NEXT_PUBLIC_KEACORE_URL=

# =============================================================================
# SUPABASE (Auth + DB)
# =============================================================================
# [REQUIRED]
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# [REQUIRED] Server-side only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional — GET /api/intake/diagnostics?intakeId=… (header x-kealee-ops or Authorization: Bearer …)
# If unset, diagnostics accepts the same CRON_SECRET as /api/cron/* (no extra variable on Vercel).
KEALEE_OPS_SECRET=

# Pascal Editor (/api/editor/*) anonymous access. Default TRUE — anyone can use
# the editor without signing in (matches the public concept funnel). Set to
# 'false' to require a Supabase login for every editor API call.
ALLOW_ANONYMOUS_EDITOR=true

# =============================================================================
# STRIPE (Payments)
# =============================================================================
# [REQUIRED] Server-side Stripe secret key
STRIPE_SECRET_KEY=sk_test_...
# Vercel: Production (VERCEL_ENV=production) must use sk_live_… ; Preview must use sk_test_…
# (enforced in lib/stripe-vercel-guard.ts on checkout + webhook side effects)

# ── Concept Engine: Homeowner Exterior ───────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_ESSENTIAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM=price_xxx

# ── Concept Engine: Garden & Farming ─────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_GARDEN_BASIC=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_GARDEN_ADVANCED=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_GARDEN_FULL=price_xxx

# ── Concept Engine: Interior Renovation ──────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_INTERIOR_BASIC=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_INTERIOR_ADVANCED=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_INTERIOR_FULL=price_xxx

# ── Concept Engine: Whole Home ────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_WHOLE_HOME_BASIC=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_WHOLE_HOME_ADVANCED=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_WHOLE_HOME_FULL=price_xxx

# ── Pre-Design Session (Starter / Visualization / Pre-Design, per room type) ──
STRIPE_PRICE_DESIGN_STARTER=price_xxx
STRIPE_PRICE_DESIGN_STARTER_EXTERIOR=price_xxx
STRIPE_PRICE_DESIGN_STARTER_INTERIOR=price_xxx
STRIPE_PRICE_DESIGN_STARTER_LANDSCAPE=price_xxx
STRIPE_PRICE_DESIGN_VISUALIZATION=price_xxx
STRIPE_PRICE_DESIGN_VISUALIZATION_EXTERIOR=price_xxx
STRIPE_PRICE_DESIGN_VISUALIZATION_INTERIOR=price_xxx
STRIPE_PRICE_DESIGN_VISUALIZATION_LANDSCAPE=price_xxx
STRIPE_PRICE_DESIGN_PREDESIGN=price_xxx
STRIPE_PRICE_DESIGN_PREDESIGN_EXTERIOR=price_xxx
STRIPE_PRICE_DESIGN_PREDESIGN_INTERIOR=price_xxx
STRIPE_PRICE_DESIGN_PREDESIGN_LANDSCAPE=price_xxx

# ── Product Page Direct Checkout ──────────────────────────────────────────────
STRIPE_PRICE_CONCEPT_VALIDATION=price_xxx
STRIPE_PRICE_PERMIT_PACKAGE=price_xxx
STRIPE_PRICE_COST_ESTIMATE=price_xxx
STRIPE_PRICE_ADU_BUNDLE=price_xxx
STRIPE_PRICE_PM_ADVISORY=price_xxx
STRIPE_PRICE_CERTIFIED_ESTIMATE=price_xxx
STRIPE_PRICE_HISTORIC_RENOVATION=price_xxx
STRIPE_PRICE_WATER_MITIGATION=price_xxx
STRIPE_PRICE_BASEMENT_CONCEPT=price_xxx

# ── Full-Stack Design Bundle ($10 test product) ───────────────────────────────
# Product: prod_URjOchd9rqzg8y | Promo: KEALEE-BUNDLE-TEST (100% off)
STRIPE_PRICE_BUNDLE_TEST=price_1TSpveIQghAs8OOIHZwsAVsH

# ── Developer Services ────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PRICE_DEV_FEASIBILITY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_DEV_PROFORMA=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_DEV_CAPITAL=price_xxx

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# [REQUIRED] for contact form and newsletter signup
RESEND_API_KEY=re_your_resend_key
# Resend audience ID for newsletter subscriptions
RESEND_AUDIENCE_ID=your_audience_id

# =============================================================================
# AI — TEXT (Anthropic Claude) — Sonnet 4.5 default, Opus 4.1 for premium tiers
# =============================================================================
# [REQUIRED] for /api/ask, /api/search, /api/concept/generate, /api/editor/vision
# Models pinned in @kealee/core-rules AI_MODELS — verify against
# https://docs.anthropic.com/en/docs/about-claude/models before flipping.
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# =============================================================================
# AI — IMAGES (Replicate / Black Forest Labs Flux) — required for /api/editor/renders
# =============================================================================
# Default image model: black-forest-labs/flux-1.1-pro-ultra (4MP, ~$0.06/image)
# Override per-call via the `provider` request body field.
# Same token also powers Kling video when no OpenAI/Gemini key is set.
REPLICATE_API_TOKEN=r8_your_replicate_token

# =============================================================================
# AI — VIDEO (multi-provider, picked in this priority order)
# =============================================================================
# Provider selection (lib/ai-video.ts):
#   1. VIDEO_PROVIDER env override (sora-2-pro | sora-2 | veo-3.1 | kling-2.5)
#   2. OPENAI_API_KEY  → Sora 2 Pro    (highest quality, native audio, ~$0.30/s)
#   3. GEMINI_API_KEY  → Veo 3.1       (equal quality, 4K capable,    ~$0.40/s)
#   4. REPLICATE_API_TOKEN → Kling 2.5 (production-ready,             ~$0.10/s)
#
# Force a specific provider regardless of which keys are set:
# VIDEO_PROVIDER=kling-2.5

# Sora 2 (OpenAI)
# Required to use Sora; also enables transcription/embeddings if you build them.
OPENAI_API_KEY=

# Veo 3.1 (Google Gemini API)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# =============================================================================
# OWNER PORTAL — DELIVERABLES & REDIRECTS (set per environment)
# =============================================================================
# Used by middleware, intake success, Stripe customer email, and
# `lib/owner-portal-urls.ts`. MUST match the URL where users sign in to view
# design concepts (no trailing slash).
# Production: https://owner.kealee.com | Staging: your preview owner host
NEXT_PUBLIC_OWNER_PORTAL_URL=https://owner.kealee.com

# Optional: comma-separated free promo codes for POST /api/intake/redeem (concept checkout).
# Defaults to KEALEE-ALLIN-2026 if unset.
# INTAKE_FREE_CODES=KEALEE-ALLIN-2026,MY-QA-CODE

# Optional: override the MP4 used for tier 2+ until project-specific video pipeline ships.
# CONCEPT_PLACEHOLDER_VIDEO_URL=https://...

# =============================================================================
# PORTAL / APP URLs (baked into client for nav links)
# =============================================================================
NEXT_PUBLIC_CONTRACTOR_PORTAL_URL=https://contractor.kealee.com
NEXT_PUBLIC_DEVELOPER_PORTAL_URL=https://developer.kealee.com
# Aliases used by login page and contractor register page:
# (Keep NEXT_PUBLIC_PORTAL_OWNER_URL in sync with NEXT_PUBLIC_OWNER_PORTAL_URL.)
NEXT_PUBLIC_PORTAL_OWNER_URL=https://owner.kealee.com
NEXT_PUBLIC_PORTAL_CONTRACTOR_URL=https://contractor.kealee.com
NEXT_PUBLIC_PORTAL_DEVELOPER_URL=https://developer.kealee.com
NEXT_PUBLIC_COMMAND_CENTER_URL=https://cc.kealee.com
NEXT_PUBLIC_ADMIN_CONSOLE_URL=https://admin.kealee.com

# =============================================================================
# MONITORING (Sentry)
# =============================================================================
# Client-side DSN (baked into bundle)
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/1234567
# Server/edge DSN (same value as NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/1234567
# Supabase Storage bucket for mirrored concept videos (Sora returns binary —
# we upload here so the Owner Portal gets a permanent HTTPS URL).
# Create as **public** bucket or use signed URLs in the portal.
SUPABASE_CONCEPT_VIDEO_BUCKET=concept-videos
SENTRY_ORG=kealee
SENTRY_PROJECT=web-main

# =============================================================================
# ANALYTICS (Google Analytics)
# =============================================================================
# GA4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# RAILWAY (set automatically on Railway deployments)
# =============================================================================
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_SERVICE_NAME=web-main
RAILWAY_LOG_DRAIN_URL=

# =============================================================================
# MARKETING AUTOMATION (Phase 1–3)
# =============================================================================

# ── GoHighLevel (GHL) ──────────────────────────────────────────────────────
# [REQUIRED for marketing automation] Base API key from GHL app
GHL_API_KEY=
# [REQUIRED for marketing automation] Location ID from GHL dashboard
GHL_LOCATION_ID=
# Optional: GHL webhook secret for verifying incoming webhooks from GHL
GHL_WEBHOOK_SECRET=
# Optional: GHL workflow IDs for SMS qualification, cold nurture, etc.
GHL_WORKFLOW_ID_SMS_QUAL=
GHL_WORKFLOW_ID_COLD_NURTURE=

# ── Twilio (SMS Alerts) ────────────────────────────────────────────────────
# [REQUIRED for Phase 1: SMS alert on hot leads]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+1...
# Your personal number (receives lead alerts)
YOUR_SMS_NUMBER=+1...

# ── Calendly (Auto-Scheduling) ────────────────────────────────────────────
# [REQUIRED for Phase 2: AI qualification + auto-scheduling]
CALENDLY_API_TOKEN=
CALENDLY_CALENDAR_UUID=

# ── Slack (Lead Monitoring Feed) ──────────────────────────────────────────
# [OPTIONAL: Slack notifications for leads]
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# ── Facebook Ads (Phase 3: Multi-Channel) ────────────────────────────────
# [OPTIONAL: For native Facebook Lead Ads sync]
META_APP_ID=
META_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Google Ads (Phase 3: Conversion Tracking) ─────────────────────────────
# [OPTIONAL: For bi-directional Google Ads sync]
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_CONVERSION_ID=
