{
  "framework": "nextjs",
  "ignoreCommand": "exit 1",
  "installCommand": "cd ../.. && NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=web-main",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/marketing-drip",
      "schedule": "0 14 * * *"
    }
  ]
}
