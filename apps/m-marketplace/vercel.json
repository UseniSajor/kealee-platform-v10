{
  "buildCommand": "cd ../.. && npm run build --workspace=@kealee/m-marketplace",
  "installCommand": "cd ../.. && rm -rf node_modules package-lock.json && npm install --legacy-peer-deps",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://marketplace.kealee.com",
    "NEXT_PUBLIC_API_URL": "https://api.kealee.com",
    "NEXT_PUBLIC_GA_MEASUREMENT_ID": "G-XXXXXXXXXX",
    "NEXT_PUBLIC_HOTJAR_ID": "XXXXXXX",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "pk_live_XXXXXXXXXXXXXXXXXXXXXXXX"
  },
  "regions": [
    "sfo1"
  ],
  "github": {
    "enabled": true,
    "autoAlias": true,
    "silent": true
  },
  "public": false
}