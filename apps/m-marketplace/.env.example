# =============================================================================
# KEALEE MARKETPLACE (m-marketplace) - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Required vars are marked [REQUIRED]. All others are optional with defaults.
#
# Note: NEXT_PUBLIC_* vars are exposed to the browser.
# Never put secrets in NEXT_PUBLIC_* variables.

# =============================================================================
# SUPABASE (Auth & Realtime)
# =============================================================================
# [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED] Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Supabase service role key (server-side only, used in middleware)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# API
# =============================================================================
# [REQUIRED] Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side API URL (can differ from public URL in production)
API_URL=http://localhost:3001
# API base URL (alternative key used by some modules)
API_BASE_URL=http://localhost:3001

# =============================================================================
# APPLICATION
# =============================================================================
# [REQUIRED] Public-facing app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL for SEO (sitemap, robots.txt)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Runtime environment
NODE_ENV=development
# Application environment override
APP_ENV=development

# =============================================================================
# STRIPE (Payments - Server-Side)
# =============================================================================
# Stripe secret key (server-side API routes only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Stripe publishable key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Stripe Price IDs (used in checkout routes) ---
STRIPE_PRICE_PACKAGE_A=price_xxx
STRIPE_PRICE_PACKAGE_B=price_xxx
STRIPE_PRICE_PACKAGE_C=price_xxx
STRIPE_PRICE_PACKAGE_D=price_xxx

# =============================================================================
# DATABASE (Server-Side API Routes)
# =============================================================================
# PostgreSQL connection (used by server-side API routes if needed)
DATABASE_URL=postgresql://user:password@localhost:5432/kealee?schema=public

# =============================================================================
# EMAIL (Server-Side)
# =============================================================================
# Email provider: resend | sendgrid | console
EMAIL_PROVIDER=console
# Resend API key
RESEND_API_KEY=re_your_resend_key
# SendGrid API key
SENDGRID_API_KEY=SG.your_sendgrid_key
# SMTP settings (for permit email routes)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@kealee.com

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Google Places API key (used in permits address lookup)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIza_your_google_places_key

# =============================================================================
# AI SERVICES (Server-Side)
# =============================================================================
# OpenAI API key (used for permit AI review)
OPENAI_API_KEY=sk-your_openai_key
# AI review API URL (client-side)
NEXT_PUBLIC_AI_REVIEW_API_URL=/api/ai/review

# =============================================================================
# AWS / S3 (Server-Side, Permit Document Upload)
# =============================================================================
# AWS credentials for document storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# S3 bucket for documents
S3_BUCKET_NAME=kealee-documents

# =============================================================================
# REAL-TIME FEATURES
# =============================================================================
# WebSocket URL for PM real-time updates
NEXT_PUBLIC_PM_WS_URL=ws://localhost:3001/ws
# PM app URL (for cross-app navigation)
NEXT_PUBLIC_PM_URL=http://localhost:3000/pm
# CLAWS URL (AI assistant service)
NEXT_PUBLIC_CLAWS_URL=http://localhost:3002

# =============================================================================
# WEB PUSH NOTIFICATIONS
# =============================================================================
# VAPID public key (for push notification subscriptions)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# =============================================================================
# ANALYTICS (Optional)
# =============================================================================
# Google Analytics measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Facebook Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=your_fb_pixel_id
# Hotjar site ID and snippet version
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id
NEXT_PUBLIC_HOTJAR_SV=6
# PostHog analytics key
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key

# =============================================================================
# MONITORING (Optional)
# =============================================================================
# Sentry DSN for error tracking
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/1234567
