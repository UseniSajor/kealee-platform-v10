# M Marketplace - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# Required Variables
# =============================================================================

# App URL
NEXT_PUBLIC_APP_URL=https://marketplace.kealee.com

# API Configuration
NEXT_PUBLIC_API_URL=https://api.kealee.com

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Payment Configuration
# =============================================================================

# Stripe (for marketplace payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_XXXXXXXXXXXXXXXXXXXXXXXX

# =============================================================================
# Analytics & Tracking (Optional)
# =============================================================================

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Hotjar (for heatmaps and recordings)
NEXT_PUBLIC_HOTJAR_ID=

# Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# =============================================================================
# App Environment
# =============================================================================
APP_ENV=development
