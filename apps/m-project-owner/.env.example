# =============================================================================
# KEALEE PROJECT OWNER (m-project-owner) - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Required vars are marked [REQUIRED]. All others are optional with defaults.
#
# Note: NEXT_PUBLIC_* vars are exposed to the browser.
# Never put secrets in NEXT_PUBLIC_* variables.

# =============================================================================
# SUPABASE (Auth & Realtime)
# =============================================================================
# [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED] Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# API
# =============================================================================
# [REQUIRED] Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# APPLICATION
# =============================================================================
# Public-facing app URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Runtime environment
NODE_ENV=development
# Application environment override
APP_ENV=development

# =============================================================================
# AI ASSISTANT
# =============================================================================
# CLAWS AI assistant service URL
NEXT_PUBLIC_CLAWS_URL=http://localhost:3002

# =============================================================================
# STRIPE (Optional, server-side)
# =============================================================================
# Stripe secret key (for server-side API routes)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# =============================================================================
# EMAIL (Optional, server-side)
# =============================================================================
# SendGrid API key (for server-side email)
SENDGRID_API_KEY=SG.your_sendgrid_key

# =============================================================================
# AUTH (Optional, server-side)
# =============================================================================
# Supabase service role key (server-side only, used if middleware needs admin access)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
