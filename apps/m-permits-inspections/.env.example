# =============================================================================
# KEALEE PERMITS & INSPECTIONS (m-permits-inspections) - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Required vars are marked [REQUIRED]. All others are optional with defaults.

# =============================================================================
# SUPABASE (Auth)
# =============================================================================
# [REQUIRED] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED] Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Supabase service role key (server-side, used for admin API key management)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# API
# =============================================================================
# [REQUIRED] Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side API URL
API_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001

# =============================================================================
# APPLICATION
# =============================================================================
# Public-facing app URL (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
APP_ENV=development

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Google Places API key (for address autocomplete in permit applications)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIza_your_google_places_key

# =============================================================================
# AI SERVICES (Server-Side)
# =============================================================================
# OpenAI API key (for AI permit review)
OPENAI_API_KEY=sk-your_openai_key
# Client-side AI review endpoint
NEXT_PUBLIC_AI_REVIEW_API_URL=/api/ai/review
# OpenAI key exposed to client (for wizard step 5 review)
NEXT_PUBLIC_OPENAI_API_KEY=sk-your_openai_key

# =============================================================================
# AWS / S3 (Server-Side, Document Upload for AI Review)
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=kealee-documents

# =============================================================================
# EMAIL (SMTP for Permit Notifications)
# =============================================================================
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@kealee.com

# =============================================================================
# STRIPE (Optional)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# =============================================================================
# SENDGRID (Optional)
# =============================================================================
SENDGRID_API_KEY=SG.your_sendgrid_key
