{
  "name": "@kealee/api",
  "version": "1.0.0",
  "description": "Kealee Platform API Service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @kealee/database db:generate && pnpm --filter @kealee/shared run build && pnpm --filter @kealee/storage run build && pnpm --filter @kealee/estimating run build && pnpm --filter @kealee/workflow-engine run build && tsc --incremental false",
    "build:ts": "tsc --incremental false",
    "start": "node dist/index.js",
    "db:migrate:deploy": "pnpm --filter @kealee/database db:migrate:deploy",
    "db:generate": "pnpm --filter @kealee/database db:generate",
    "test": "vitest",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "test:e2e": "vitest run src/tests/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/csrf-protection": "^7.1.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.5.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@kealee/ai-chat": "workspace:*",
    "@kealee/analytics": "workspace:*",
    "@kealee/audit": "workspace:*",
    "@kealee/database": "workspace:*",
    "@kealee/estimating": "workspace:*",
    "@kealee/observability": "workspace:*",
    "@kealee/realtime": "workspace:*",
    "@kealee/scoring": "workspace:*",
    "@kealee/shared": "workspace:*",
    "@kealee/storage": "workspace:*",
    "@kealee/workflow-engine": "workspace:*",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.23.1",
    "docusign-esign": "^7.0.0",
    "fastify": "^4.26.0",
    "fastify-raw-body": "^4.3.0",
    "ioredis": "^5.3.2",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.3",
    "redis": "^4.6.11",
    "resend": "^3.2.0",
    "speakeasy": "^2.0.0",
    "stripe": "^14.14.0",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.3",
    "zod-validation-error": "^3.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.30",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
