{
  "name": "@kealee/api",
  "version": "1.0.0",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "stripe:setup-gc-products": "tsx scripts/stripe/setup-gc-products.ts",
    "stripe:setup-ops-products": "tsx scripts/stripe/setup-ops-products.ts",
    "stripe:setup-catalog": "tsx scripts/stripe/setup-complete-catalog.ts",
    "stripe:import": "tsx scripts/stripe/stripe-import.ts",
    "stripe:import:dry-run": "tsx scripts/stripe/stripe-import.ts --dry-run",
    "stripe:list": "tsx scripts/stripe/stripe-list.ts",
    "stripe:list:json": "tsx scripts/stripe/stripe-list.ts --json",
    "db:push": "cd ../database && pnpm prisma db push",
    "db:migrate": "cd ../database && pnpm prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "cd ../database && pnpm prisma studio",
    "db:reset": "cd ../database && pnpm prisma migrate reset && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.1",
    "@apollo/server": "^4.10.0",
    "@as-integrations/fastify": "^2.1.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^2.1.0",
    "@kealee/compliance": "workspace:*",
    "@kealee/database": "workspace:*",
    "@kealee/workflow-engine": "workspace:*",
    "@supabase/supabase-js": "^2.39.0",
    "apollo-server-fastify": "^3.12.1",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "commander": "^11.1.0",
    "docusign-esign": "^8.5.0",
    "fastify": "^4.26.0",
    "fastify-raw-body": "^4.0.0",
    "graphql": "^16.8.1",
    "graphql-subscriptions": "^2.0.0",
    "graphql-tag": "^2.12.6",
    "ioredis": "^5.3.2",
    "pino-pretty": "^10.3.1",
    "stripe": "^20.1.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.22.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.0",
    "@vitest/coverage-v8": "^1.2.0",
    "dotenv": "^17.2.3",
    "tsx": "^4.7.0",
    "typescript": "^5.9.0",
    "vitest": "^1.2.0"
  },
  "bin": {
    "kealee-sdk-generator": "./dist/sdk/cli.js"
  }
}
