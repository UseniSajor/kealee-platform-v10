{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": false, // Temporarily disabled to bypass some errors
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/**/*",
    "**/__tests__/**/*",
    "**/*.test.ts",
    "src/__tests__/**/*",
    "src/modules/tasks/**/*",
    "src/services/ai.service.ts",
    "src/sdk/**/*",
    "src/graphql/**/*"
  ]
}
