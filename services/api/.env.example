# =============================================================================
# KEALEE API SERVICE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# Required vars are marked [REQUIRED]. All others are optional with defaults.

# =============================================================================
# APPLICATION
# =============================================================================
# [REQUIRED] Runtime environment
NODE_ENV=development
# Application environment (overrides NODE_ENV for Kealee-specific logic)
APP_ENV=development
# Server port
PORT=3001
# Server bind address
HOST=0.0.0.0
# Logging level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# DATABASE
# =============================================================================
# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/kealee?schema=public
# Test database (used by test suite)
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/kealee_test

# =============================================================================
# SUPABASE (Auth)
# =============================================================================
# [REQUIRED] Supabase project URL
SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED] Supabase anonymous/public key (safe for client-side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# [REQUIRED] Supabase service role key (server-side only, full access)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# STRIPE (Payments)
# =============================================================================
# [REQUIRED] Stripe secret API key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Stripe publishable key (pk_test_... or pk_live_...)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# [REQUIRED] Stripe webhook signing secret (whsec_...)
# Production webhook URL: POST https://api.kealee.com/webhooks/stripe
# Deprecated paths (/billing/stripe/webhook, /payments/webhooks/stripe) now 301-redirect.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Stripe Connect webhook secret (for connected account events)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret
# Stripe test key (used in non-production environments)
STRIPE_TEST_KEY=sk_test_your_stripe_test_key
# Stripe test price ID (for webhook testing)
STRIPE_TEST_PRICE_ID=price_xxx

# --- Stripe Price IDs (Service Packages) ---
STRIPE_PRICE_PACKAGE_A=price_xxx
STRIPE_PRICE_PACKAGE_B=price_xxx
STRIPE_PRICE_PACKAGE_C=price_xxx
STRIPE_PRICE_PACKAGE_D=price_xxx

# --- Stripe Price IDs (Permit & Marketplace) ---
STRIPE_PRICE_PERMIT=price_xxx
STRIPE_PRICE_MARKETPLACE_BASIC=price_xxx
STRIPE_PRICE_MARKETPLACE_PRO=price_xxx
STRIPE_PRICE_MARKETPLACE_PREMIUM=price_xxx

# --- Stripe Price IDs (Pro Plans) ---
STRIPE_PRICE_ARCHITECT_PRO=price_xxx
STRIPE_PRICE_PERMIT_PRO=price_xxx
STRIPE_PRICE_API_ACCESS=price_xxx
STRIPE_PRICE_WHITE_LABEL=price_xxx

# =============================================================================
# REDIS (Queues, Rate Limiting, Caching)
# =============================================================================
# [REQUIRED in production] Redis is needed for BullMQ job queues, rate limiting,
# and caching. The worker service will NOT start without a valid Redis URL.
# The API service logs a warning if Redis is absent but continues (degraded mode).
# Local dev: docker run -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379
# Or connect via individual params:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# =============================================================================
# AI - ANTHROPIC (Claude)
# =============================================================================
# Anthropic API key for AI features (takeoff, document analysis, task generation)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here
# Anthropic model to use (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# AI - OPENAI (Optional, used for bid RAG features)
# =============================================================================
# OpenAI API key (for embeddings / bid analysis)
OPENAI_API_KEY=sk-your_openai_key_here

# =============================================================================
# EMAIL - RESEND
# =============================================================================
# Resend API key for transactional email
RESEND_API_KEY=re_your_resend_key
# From address for outgoing email
EMAIL_FROM=noreply@kealee.com
# Resend from email (alternative)
RESEND_FROM_EMAIL=Kealee Platform <noreply@kealee.com>

# =============================================================================
# SMS - TWILIO
# =============================================================================
# Twilio account SID
TWILIO_ACCOUNT_SID=AC_your_account_sid
# Twilio auth token
TWILIO_AUTH_TOKEN=your_auth_token
# Twilio phone number (E.164 format)
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# FILE STORAGE (S3-Compatible / Cloudflare R2)
# =============================================================================
# S3/R2 access credentials
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
# S3 bucket name
S3_BUCKET_NAME=kealee-uploads
# S3-compatible endpoint (for R2 or MinIO)
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# S3 region
S3_REGION=us-east-1
# Architect-specific bucket (optional, falls back to S3_BUCKET_NAME)
ARCHITECT_BUCKET_NAME=kealee-architect-files
# CDN / public URL for uploaded files
CDN_URL=https://cdn.kealee.com
# R2-specific alternatives (if using Cloudflare R2)
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# =============================================================================
# DOCUSIGN (Contract Signing)
# =============================================================================
# DocuSign integration key (OAuth client ID)
DOCUSIGN_INTEGRATION_KEY=your_integration_key
# DocuSign user ID (impersonated user)
DOCUSIGN_USER_ID=your_user_id
# DocuSign account ID
DOCUSIGN_ACCOUNT_ID=your_account_id
# DocuSign RSA private key (PEM format, newlines as \n)
DOCUSIGN_RSA_PRIVATE_KEY=your_rsa_private_key
# DocuSign REST API base path
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
# DocuSign OAuth base path
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com

# =============================================================================
# GOOGLE SERVICES
# =============================================================================
# Google Maps / Places API key
GOOGLE_MAPS_API_KEY=AIza_your_google_maps_key

# =============================================================================
# WEB PUSH NOTIFICATIONS (VAPID)
# =============================================================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@kealee.com

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# =============================================================================
# SECURITY
# =============================================================================
# JWT secret for API authentication
JWT_SECRET=your-secret-key-change-in-production-min-64-chars
# JWT refresh token secret
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-64-chars
# JWT token expiry
JWT_EXPIRY=15m
# JWT refresh token expiry
JWT_REFRESH_EXPIRY=7d
# CSRF secret
CSRF_SECRET=your_csrf_secret
# Field-level encryption master key
ENCRYPTION_MASTER_KEY=your_encryption_master_key_hex

# =============================================================================
# MONITORING & ERROR TRACKING
# =============================================================================
# Sentry DSN for error reporting
SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/1234567
# Sentry environment label
SENTRY_ENVIRONMENT=development

# =============================================================================
# AUDIT LOGGING (Optional)
# =============================================================================
# HMAC signing key for audit log integrity
AUDIT_SIGNING_KEY=your_audit_signing_key
# Audit log retention in days (default: 2555 = ~7 years)
AUDIT_RETENTION_DAYS=2555
# Enable archiving old audit records
AUDIT_ARCHIVE_ENABLED=false
AUDIT_ARCHIVE_AFTER_DAYS=365
# Include request/response bodies in audit logs
AUDIT_INCLUDE_REQUEST_BODY=true
AUDIT_INCLUDE_RESPONSE_BODY=false
# Hash sensitive data in logs
AUDIT_HASH_SENSITIVE_DATA=true
# Store audit logs in separate database
AUDIT_SEPARATE_STORAGE=false

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================
# Rate limit window in milliseconds (default: 60000 = 1 min)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window (default: 100)
RATE_LIMIT_GLOBAL_MAX=100
# Enable per-API-key rate limiting (default: true)
RATE_LIMIT_USE_KEY_LIMIT=true

# =============================================================================
# COMPLIANCE / OFAC SCREENING (Optional)
# =============================================================================
# ComplyAdvantage API credentials
COMPLYADVANTAGE_API_KEY=your_comply_advantage_key
COMPLYADVANTAGE_API_URL=https://api.complyadvantage.com

# =============================================================================
# INTEGRATIONS (Optional)
# =============================================================================
# BuildingConnected API
BUILDINGCONNECTED_API_KEY=your_bc_api_key
BUILDINGCONNECTED_API_URL=https://api.buildingconnected.com/v1
# n8n webhook URL for bid automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook/bids
# Bid alert notification email
BID_ALERT_EMAIL=timc@kealee.com
# Command Center internal URL
COMMAND_CENTER_URL=http://localhost:3001/api/v1

# =============================================================================
# GOHIGHLEVEL CRM (Optional)
# =============================================================================
# GHL Private Integration Token (Settings > Integrations > Private Integrations)
GHL_API_KEY=your_ghl_api_key
# GHL Location ID (Settings > Business Profile)
GHL_LOCATION_ID=your_location_id
# GHL API base URL
GHL_BASE_URL=https://services.leadconnectorhq.com
# GHL webhook signing secret
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# =============================================================================
# APPLICATION URLs
# =============================================================================
# API base URL (public-facing)
API_BASE_URL=http://localhost:3001
# Frontend app base URL
APP_BASE_URL=http://localhost:3000
# Frontend URL (alternative key)
FRONTEND_URL=http://localhost:3000
# File storage URL prefix
FILE_STORAGE_URL=https://storage.kealee.com

# =============================================================================
# RAILWAY (Set automatically on Railway deployments)
# =============================================================================
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_SERVICE_NAME=kealee-api
