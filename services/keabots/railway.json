{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter @kealee/keabots-service build"
  },
  "deploy": {
    "startCommand": "node dist/orchestrator.js",
    "healthcheckPath": "/api/v1/keabots/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
