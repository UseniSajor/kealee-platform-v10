{
  "name": "@kealee/os-dev",
  "version": "1.0.0",
  "description": "OS-Dev Service — Capital stacks, draw tracking, investor reporting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "require": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./capital.routes": { "require": "./dist/capital.routes.js", "types": "./dist/capital.routes.d.ts" },
    "./capital.service": { "require": "./dist/capital.service.js", "types": "./dist/capital.service.d.ts" }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @kealee/database db:generate && tsc --incremental false",
    "start": "node dist/index.js",
    "test": "vitest"
  },
  "dependencies": {
    "@kealee/core-auth": "workspace:*",
    "@kealee/database": "workspace:*",
    "@kealee/shared": "workspace:*",
    "@kealee/core-events": "workspace:*",
    "@kealee/core-ddts": "workspace:*",
    "@prisma/client": "^5.22.0",
    "fastify": "^4.26.0",
    "@fastify/cors": "^8.5.0",
    "zod": "^3.22.4",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
