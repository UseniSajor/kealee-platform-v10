# =============================================================================
# KEALEE WORKER SERVICE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values.
# Required vars are marked [REQUIRED]. All others are optional with defaults.

# =============================================================================
# DATABASE
# =============================================================================
# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/kealee?schema=public

# =============================================================================
# REDIS (BullMQ Queues)
# =============================================================================
# [REQUIRED] Redis is mandatory for the worker service. All job queues
# (email, webhook, ML, reports, sales, spatial verification, concept delivery)
# use BullMQ which requires Redis. The worker will EXIT with code 1 if Redis
# is unreachable on startup.
# Local dev: docker run -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# =============================================================================
# API
# =============================================================================
API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORTAL_BASE_URL=http://localhost:3000

# =============================================================================
# AI (Anthropic Claude)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
SPATIAL_AI_MODEL=claude-sonnet-4-20250514

# =============================================================================
# FILE STORAGE (Cloudflare R2 — primary)
# =============================================================================
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_BUCKET_NAME=kealee-documents
R2_REGION=auto

# AWS S3 Storage (fallback)
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
S3_BUCKET_NAME=kealee-documents
S3_REGION=us-east-1

# =============================================================================
# EMAIL (SendGrid)
# =============================================================================
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@kealee.com
SENDGRID_FROM_NAME=Kealee

# =============================================================================
# REPORTS
# =============================================================================
REPORTS_DIR=/tmp/reports
REPORTS_URL_PREFIX=https://api.kealee.com/reports
GC_REPORT_EMAILS=pm@kealee.com
WEEKLY_GC_REPORT_EMAILS=team@kealee.com

# =============================================================================
# CLEANUP (Scheduled jobs)
# =============================================================================
FILE_CLEANUP_AGE_DAYS=30
INCOMPLETE_UPLOAD_AGE_HOURS=24

# =============================================================================
# WEBHOOKS
# =============================================================================
WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development
APP_ENV=development
