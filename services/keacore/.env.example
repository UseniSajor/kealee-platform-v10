# =============================================================================
# KEALEE KEACORE SERVICE — ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values.

# =============================================================================
# SERVER
# =============================================================================
PORT=3010
NODE_ENV=development
LOG_LEVEL=info
HOSTNAME=0.0.0.0
ALLOWED_ORIGINS=http://localhost:3000,https://kealee.com

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# =============================================================================
# LLM STACK (internal Qwen + external Claude/GPT)
# =============================================================================
# Default provider: internal | claude | gpt
LLM_DEFAULT_PROVIDER=claude
LLM_FALLBACK_PROVIDER=claude

# Claude (Anthropic)
CLAUDE_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / GPT
GPT_ENABLED=false
OPENAI_API_KEY=sk-...

# Internal Qwen (requires vLLM/Ollama running locally)
INTERNAL_LLM_ENABLED=false
INTERNAL_TEXT_BASE_URL=http://localhost:8000
INTERNAL_TEXT_MODEL=qwen2.5-72b-instruct
INTERNAL_VL_BASE_URL=http://localhost:8001
INTERNAL_VL_MODEL=qwen2-vl-7b-instruct
INTERNAL_EMBED_BASE_URL=http://localhost:8002
INTERNAL_EMBED_MODEL=bge-m3
INTERNAL_RERANK_BASE_URL=http://localhost:8003
INTERNAL_RERANK_MODEL=bge-reranker-v2-m3
