{
  "name": "@kealee/command-center",
  "version": "1.0.0",
  "description": "Kealee PM Command Center - 14 Automation Mini-Apps",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch gateway/src/server.ts",
    "dev:workers": "tsx watch workers/src/main.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:workers\"",
    "start": "node dist/gateway/src/server.js",
    "workers": "tsx workers/src/main.ts",
    "workers:start": "node dist/workers/src/main.js",
    "build": "tsc -b",
    "lint": "eslint . --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@google-cloud/vision": "^4.3.2",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@kealee/database": "workspace:*",
    "@kealee/observability": "workspace:*",
    "@prisma/client": "^5.20.0",
    "@sendgrid/mail": "^8.1.3",
    "axios": "^1.7.7",
    "bullmq": "^5.23.1",
    "date-fns": "^4.1.0",
    "docusign-esign": "^8.0.0",
    "fastify": "^4.28.1",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.15.0",
    "pino-pretty": "^11.0.0",
    "puppeteer": "^23.5.3",
    "twilio": "^5.3.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.0.1",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
