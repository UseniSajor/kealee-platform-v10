{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "paths": {
      "@shared/*": ["./shared/*"],
      "@apps/*": ["./apps/*"]
    }
  },
  "include": [
    "shared/**/*.ts",
    "apps/**/*.ts",
    "gateway/**/*.ts",
    "workers/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
