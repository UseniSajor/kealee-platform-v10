# ============================================================
# CONTRACTOR ACQUISITION AUTOMATION — ENVIRONMENT VARIABLES
# ============================================================
# Copy relevant vars to your Railway service env config.
# Required = must be set. Optional = has graceful no-op fallback.

# ─── Zoho CRM (api service) ──────────────────────────────────
# Required to create leads, update pipeline stages, and upsert contacts.
# Setup: https://accounts.zoho.com → Developer Console → Self-Client OAuth
# Scopes needed: ZohoCRM.modules.ALL, ZohoCRM.settings.ALL

ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_DOMAIN=com                          # com | eu | in | au | jp

# Webhook security token — set this in both Zoho webhook config and here
ZOHO_WEBHOOK_TOKEN=random_32_char_secret

# ─── SendGrid (command-center service) ───────────────────────
# Required to send email sequences.
# Setup: https://app.sendgrid.com → Settings → API Keys → Create Full Access

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=hello@kealee.com
SENDGRID_FROM_NAME=Kealee Platform

# Optional: SendGrid Dynamic Template IDs
# If set, uses your SendGrid templates instead of inline HTML.
# Create templates at: https://mc.sendgrid.com/dynamic-templates
SENDGRID_TEMPLATE_RECRUIT_1=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_RECRUIT_2=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_RECRUIT_3=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ONBOARDING_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_REGISTRATION_REMINDER=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_VERIFICATION_REMINDER=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ACTIVATION_WELCOME=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Twilio (command-center service) ─────────────────────────
# Required to send SMS messages.
# Setup: https://console.twilio.com → Phone Numbers → Buy a Number

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+14155552671         # E.164 format

# Optional: use Messaging Service SID for higher throughput / local number pools
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Internal API (command-center → api service bridge) ──────
# command-center calls the api service to perform Zoho CRM operations.
# On Railway this is the internal hostname of the api service.

INTERNAL_API_URL=http://api:3000
INTERNAL_API_KEY=your_internal_service_key  # Set same value in api service

# ─── App URLs (for links in emails/SMS) ──────────────────────
WEB_MAIN_URL=https://kealee.com
PORTAL_CONTRACTOR_URL=https://contractor.kealee.com

# ─── Already required (existing) ─────────────────────────────
REDIS_URL=redis://...
DATABASE_URL=postgresql://...
ANTHROPIC_API_KEY=sk-ant-...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
