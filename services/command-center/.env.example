# KEALEE COMMAND CENTER - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://kealee:kealee_dev@localhost:5432/kealee_command_center

# ============================================================================
# REDIS (Job Queues & Event Bus)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# AI - CLAUDE (Anthropic)
# ============================================================================
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================================================
# EMAIL - SENDGRID
# ============================================================================
# Get your API key at https://sendgrid.com/
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@kealee.com
SENDGRID_FROM_NAME=Kealee Platform

# ============================================================================
# SMS - TWILIO
# ============================================================================
# Get your credentials at https://twilio.com/
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ============================================================================
# GOOGLE MAPS
# ============================================================================
# Get your API key at https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=AIza...

# ============================================================================
# GOOGLE CALENDAR
# ============================================================================
# Set up OAuth at https://console.cloud.google.com/
GOOGLE_CALENDAR_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=...
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/auth/google/callback

# ============================================================================
# WEATHER - OPENWEATHERMAP
# ============================================================================
# Get your API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=...

# ============================================================================
# CORS
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret for API authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_AI_FEATURES=true
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_WEATHER_CHECKS=true
