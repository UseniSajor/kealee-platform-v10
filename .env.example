# Kealee Platform V10 - Master Environment Variables Template
# Copy this to .env.local and fill in your actual values
# DO NOT COMMIT .env.local TO GIT

# ============================================================================
# SUPABASE (Authentication & Database)
# ============================================================================
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# ============================================================================
# DATABASE (Backend Only - DO NOT add to frontend)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/kealee

# ============================================================================
# REDIS (Backend Only — REQUIRED for worker service)
# ============================================================================
# Required in production for: BullMQ job queues, rate limiting, caching
# Worker service will NOT start without a valid Redis connection.
# Local dev: install Redis or use Docker: docker run -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# ============================================================================
# API URLS
# ============================================================================
# Development
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# Production (Railway)
# NEXT_PUBLIC_API_URL=https://api.kealee.com
# API_URL=https://api.kealee.com

# ============================================================================
# APP ENVIRONMENT
# ============================================================================
NODE_ENV=development
APP_ENV=development
PORT=3001

# ============================================================================
# SECURITY SECRETS (Backend Only)
# ============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
AUDIT_SIGNING_KEY=your-audit-signing-key-here

# ============================================================================
# STRIPE (Payments)
# ============================================================================
# Backend (Secret Keys)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Frontend (Publishable Keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook Secret (from Stripe Dashboard → Webhooks)
# IMPORTANT: Configure ONE webhook URL in Stripe Dashboard:
#   Production: https://api.kealee.com/webhooks/stripe
#   Local dev:  Use `stripe listen --forward-to localhost:3001/webhooks/stripe`
# Deprecated paths (/billing/stripe/webhook, /payments/webhooks/stripe)
# now 301-redirect to /webhooks/stripe. Update Stripe Dashboard if still using them.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Stripe Connect webhook secret (for connected account events)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret_here

# Product Price IDs (from create-complete-catalog.ts output)
STRIPE_PRICE_PACKAGE_A=price_xxx
STRIPE_PRICE_PACKAGE_B=price_xxx
STRIPE_PRICE_PACKAGE_C=price_xxx
STRIPE_PRICE_PACKAGE_D=price_xxx

# ============================================================================
# STRIPE — PM Service Package Price IDs (Monthly + Annual)
# Run: node services/api/scripts/stripe/setup-ops-products.ts to auto-create
# ============================================================================
STRIPE_PRICE_PACKAGE_A_MONTHLY=price_xxx
STRIPE_PRICE_PACKAGE_A_ANNUAL=price_xxx
STRIPE_PRICE_PACKAGE_B_MONTHLY=price_xxx
STRIPE_PRICE_PACKAGE_B_ANNUAL=price_xxx
STRIPE_PRICE_PACKAGE_C_MONTHLY=price_xxx
STRIPE_PRICE_PACKAGE_C_ANNUAL=price_xxx
STRIPE_PRICE_PACKAGE_D_MONTHLY=price_xxx
STRIPE_PRICE_PACKAGE_D_ANNUAL=price_xxx

# Marketplace Subscription Price IDs
STRIPE_PRICE_MARKETPLACE_BASIC=price_xxx
STRIPE_PRICE_MARKETPLACE_PRO=price_xxx
STRIPE_PRICE_MARKETPLACE_PREMIUM=price_xxx

# Other Product Price IDs
STRIPE_PRICE_PERMIT=price_xxx
STRIPE_PRICE_PERMIT_PRO=price_xxx
STRIPE_PRICE_ARCHITECT_PRO=price_xxx
STRIPE_PRICE_API_ACCESS=price_xxx
STRIPE_PRICE_WHITE_LABEL=price_xxx

# ============================================================================
# EMAIL (Resend — primary email provider)
# ============================================================================
# Sign up at: https://resend.com
# EMAIL_PROVIDER controls m-ops-services: 'resend', 'sendgrid', or 'console'
EMAIL_PROVIDER=console
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=Kealee Platform <noreply@kealee.com>

# ============================================================================
# EXTERNAL SERVICES (Optional — features degrade gracefully if missing)
# ============================================================================

# Anthropic Claude (AI Features — chat, scope analysis, estimation)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+12025551234

# DocuSign (E-Signatures — os-pm documents)
DOCUSIGN_INTEGRATION_KEY=your_integration_key
DOCUSIGN_SECRET_KEY=your_secret_key
DOCUSIGN_ACCOUNT_ID=your_account_id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi

# Google Places (Address autocomplete — permits app)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_api_key_here

# ============================================================================
# FILE STORAGE (S3 / Cloudflare R2)
# ============================================================================
# Either set S3_* for AWS S3 or R2_* for Cloudflare R2
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=kealee-uploads
S3_REGION=us-east-1
# S3_ENDPOINT=  # Leave empty for AWS S3, set for R2/MinIO

# Cloudflare R2 alternative:
# R2_ACCESS_KEY_ID=your_r2_key
# R2_SECRET_ACCESS_KEY=your_r2_secret
# R2_BUCKET_NAME=kealee-uploads
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com

# ============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# ============================================================================
# Generate keys: node -e "const wp = require('web-push'); const k = wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@kealee.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key

# ============================================================================
# GOHIGHLEVEL CRM (Optional — sync users, leads, milestones to GHL)
# ============================================================================
# GHL Private Integration Token (Settings > Integrations > Private Integrations)
GHL_API_KEY=your_ghl_api_key
# GHL Location ID (Settings > Business Profile)
GHL_LOCATION_ID=your_location_id
# GHL API base URL (default: https://services.leadconnectorhq.com)
GHL_BASE_URL=https://services.leadconnectorhq.com
# GHL webhook signing secret (for verifying inbound GHL webhooks)
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# ============================================================================
# KEABOT (AI Bot Service Client)
# ============================================================================
# API URL for KeaBot tool handlers to call OS service endpoints
KEALEE_API_URL=http://localhost:3001
# Service auth token for bot-to-API calls
KEALEE_BOT_TOKEN=your_bot_service_token

# ============================================================================
# APP-SPECIFIC URLS (for each frontend app)
# ============================================================================
# Set the appropriate URL for each app

# m-marketplace
NEXT_PUBLIC_APP_URL=http://localhost:3000

# m-ops-services  
# NEXT_PUBLIC_APP_URL=http://localhost:3003

# m-permits-inspections
# NEXT_PUBLIC_APP_URL=http://localhost:3004

# And so on for each app...

# ============================================================================
# PRODUCTION URLS (Set these in Vercel/Railway)
# ============================================================================
# Production API
# NEXT_PUBLIC_API_URL=https://api.kealee.com

# Production App URLs
# https://kealee.com (marketplace)
# https://ops.kealee.com (ops-services)
# https://permits.kealee.com (permits)
# https://finance.kealee.com (finance-trust)
# etc.
